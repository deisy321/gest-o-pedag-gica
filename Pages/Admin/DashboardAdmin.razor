@page "/admin/DashboardAdmin"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using Microsoft.AspNetCore.Components.Authorization
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AdminService AdminService
@inject AuthenticationStateProvider AuthStateProvider
@inject DisciplinaService DisciplinaService
@inject NavigationManager Nav

<AuthorizeView Roles="Administrador">
    <Authorized>
        <div class="page-admin animate-fade-in">

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    @((MarkupString)successMessage)
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Cabeçalho e Pesquisa *@
            <div class="admin-header-row mb-4">
                <div class="header-title">
                    <h3 class="fw-bold mb-0">Painel de Controlo</h3>
                    <p class="text-muted small mb-0">Gestão administrativa do sistema</p>
                </div>
                <div class="search-bar-container">
                    <i class="bi bi-search"></i>
                    <input type="text"
                           class="form-control shadow-sm"
                           placeholder="Pesquisar professor ou turma..."
                           @bind="searchTerm"
                           @bind:event="oninput" />
                </div>
            </div>

            @* Cards de Estatísticas *@
            <div class="row g-4 mb-4">
                <div class="col-md-6 col-xl-2">
                    <div class="stat-card card-yellow shadow-sm">
                        <div class="icon"><i class="bi bi-people-fill fs-2"></i></div>
                        <div class="data">
                            <span>Alunos</span>
                            <h2 class="fw-bold">@TotalAlunos</h2>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-2">
                    <div class="stat-card card-blue shadow-sm">
                        <div class="icon"><i class="bi bi-person-badge-fill fs-2"></i></div>
                        <div class="data">
                            <span>Professores</span>
                            <h2 class="fw-bold">@TotalProfessores</h2>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="stat-card card-white border-start-warning shadow-sm">
                        <div class="data w-100">
                            <span class="text-muted small fw-bold">Gestão de Turmas</span>
                            <p class="small text-muted mb-2">Criar turmas e alunos</p>
                            <a href="/admin/GerirTurmas" class="btn btn-outline-warning btn-sm rounded-pill w-100">Ir para Turmas</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="stat-card card-white border-start-purple shadow-sm">
                        <div class="data w-100">
                            <span class="text-muted small fw-bold">Disciplinas</span>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="badge bg-light text-dark border">@TotalDisciplinas</span>
                                <a href="/admin/GerirDisciplinas" class="btn btn-outline-primary btn-sm rounded-pill">Ver Todas</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-12 col-xl-2">
                    <div class="stat-card card-white border-start-primary shadow-sm">
                        <div class="data w-100">
                            <span class="text-muted small fw-bold">Atribuição</span>
                            <a href="/admin/AtribuirTurma" class="btn btn-primary btn-sm rounded-pill w-100 mt-2">Configurar</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                @* Tabela *@
                <div class="col-lg-8">
                    <div class="admin-card shadow-sm border-0">
                        <div class="card-header-custom">
                            <h5 class="fw-bold mb-0 text-primary">Professores e Módulos Ativos</h5>
                        </div>
                        <div class="table-responsive p-3">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Professor</th>
                                        <th>Turma</th>
                                        <th>Disciplina</th>
                                        <th class="text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (FilteredAtribuicoes != null && FilteredAtribuicoes.Any())
                                    {
                                        @foreach (var item in FilteredAtribuicoes)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@item.ProfessorNome</td>
                                                <td><span class="badge bg-light text-dark border">@item.TurmaNome</span></td>
                                                <td>@item.ModuloNome</td>
                                                <td class="text-center">
                                                    <a href="/admin/GerirTurmas" class="btn btn-action shadow-sm">
                                                        <i class="bi bi-pencil-square"></i> Editar
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted p-4">Nenhum resultado encontrado.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* Ações Rápidas *@
                <div class="col-lg-4">
                    <div class="admin-card shadow-sm border-0">
                        <div class="card-header-custom">
                            <h5 class="fw-bold mb-0 text-primary">Ações Rápidas</h5>
                        </div>
                        <div class="quick-actions p-3">
                            <a href="/admin/RelatoriosGlobais" class="qa-item orange mb-2" style="background-color: #fff3e0; border-left: 4px solid #ff9800; color: #ff9800 !important;">
                                <i class="bi bi-graph-up-arrow"></i> <strong>Relatórios Globais</strong>
                            </a>
                            <a href="/admin/GerirDisciplinas" class="qa-item purple">
                                <i class="bi bi-collection"></i> Gerir Disciplinas
                            </a>
                            <a href="/admin/GerirModulos" class="qa-item green">
                                <i class="bi bi-journal-text"></i> Gerir Módulos
                            </a>
                            <a href="/admin/RegisterAdmin" class="qa-item blue">
                                <i class="bi bi-person-plus"></i> Registar Utilizador
                            </a>
                            <a href="/admin/GerirUtilizadores" class="qa-item dark-blue">
                                <i class="bi bi-people"></i> Gerir Utilizadores
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private string successMessage = "";
    private string searchTerm = "";
    private int TotalAlunos;
    private int TotalProfessores;
    private int TotalDisciplinas;
    private List<ResumoAtribuicao> ListaAtribuicoes = new();

    private IEnumerable<ResumoAtribuicao> FilteredAtribuicoes =>
        string.IsNullOrWhiteSpace(searchTerm)
        ? ListaAtribuicoes
        : ListaAtribuicoes.Where(x =>
            (x.ProfessorNome?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (x.TurmaNome?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (x.ModuloNome?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            TotalAlunos = await AdminService.GetTotalAlunosAsync();
            TotalProfessores = await AdminService.GetTotalProfessoresAsync();
            var listaD = await DisciplinaService.GetDisciplinasAsync();
            TotalDisciplinas = listaD?.Count ?? 0;
            ListaAtribuicoes = await AdminService.GetAtribuicoesAtivasAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }
    }
}