@page "/admin/GerirCursos"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject CursoService CursoService
@inject NavigationManager Nav

<div class="container mt-4 animate-fade-in">
    @* Cabeçalho *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-book-half me-2"></i>Gestão de Cursos</h3>
            <p class="text-muted small">Adicione ou remova as áreas de ensino da instituição</p>
        </div>
        <button class="btn btn-outline-secondary rounded-pill px-4" @onclick='() => Nav.NavigateTo("/admin/GerirTurmas")'>
            <i class="bi bi-arrow-left me-2"></i>Voltar às Turmas
        </button>
    </div>

    @* Formulário de Adição *@
    <div class="card shadow-sm mb-4 border-0" style="border-radius: 15px;">
        <div class="card-body p-4 bg-light">
            <h5 class="fw-bold mb-3 text-secondary">Novo Curso</h5>
            <div class="row g-2">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                            <i class="bi bi-pencil-square text-primary"></i>
                        </span>
                        <input class="form-control border-start-0 rounded-end-pill shadow-none"
                               placeholder="Nome do Curso (ex: Informática de Gestão)"
                               @bind="NovoCurso.Nome"
                               @bind:event="oninput"
                               @onkeyup='(e) => { if (e.Key == "Enter") SalvarCurso(); }' />
                    </div>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success rounded-pill w-100 fw-bold shadow-sm" @onclick="SalvarCurso">
                        <i class="bi bi-plus-circle me-2"></i>Adicionar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* Listagem de Cursos *@
    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="ps-4 py-3">Nome da Formação / Curso</th>
                        <th class="text-center py-3" style="width: 150px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Cursos != null && Cursos.Any())
                    {
                        @foreach (var c in Cursos)
                        {
                            <tr class="course-row">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            <i class="bi bi-bookmark-star"></i>
                                        </div>
                                        <span class="fw-semibold text-dark">@c.Nome</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-action-delete" @onclick="() => Eliminar(c)" title="Eliminar Curso">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center p-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                Nenhum curso registado no sistema.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Estilos locais para esta página */
    .course-row {
        transition: all 0.2s;
    }

        .course-row:hover {
            background-color: #f8f9fa !important;
        }

    .btn-action-delete {
        background: #fff5f5;
        color: #e74c3c;
        border: 1px solid #ffc9c9;
        padding: 5px 12px;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .btn-action-delete:hover {
            background: #e74c3c;
            color: white;
            transform: scale(1.1);
        }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    List<Curso> Cursos = new();
    Curso NovoCurso = new();

    protected override async Task OnInitializedAsync() => await CarregarCursos();

    async Task CarregarCursos()
    {
        Cursos = await CursoService.GetCursosAsync() ?? new();
        StateHasChanged();
    }

    async Task SalvarCurso()
    {
        if (string.IsNullOrWhiteSpace(NovoCurso.Nome)) return;

        await CursoService.AddCursoAsync(NovoCurso);
        NovoCurso = new Curso(); // Limpa o campo
        await CarregarCursos();
    }

    async Task Eliminar(Curso c)
    {
        // Sugestão: Adicionar um confirm do JS para evitar cliques acidentais
        await CursoService.RemoveCursoAsync(c);
        await CarregarCursos();
    }
}