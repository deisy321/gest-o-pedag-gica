@page "/admin/GerirModulos"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject ModuloService ModuloService
@inject ProfessorService ProfessorService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-admin">
    <!-- Cabeçalho -->
    <div class="admin-header-row">
        <div>
 <h1 class="page-title">Gestăo de Módulos</h1>
    <p class="page-subtitle">Administraçăo do plano curricular e formadores</p>
        </div>
        <div class="d-flex gap-2" style="flex-wrap: wrap;">
 <a href="/admin/DashboardAdmin" class="btn btn-custom btn-custom-outline">
  <i class="bi bi-arrow-left"></i> Voltar
        </a>
      <button class="btn btn-custom btn-custom-success" @onclick='() => Nav.NavigateTo("/admin/CriarModulo")'>
                <i class="bi bi-plus-lg"></i> Novo Módulo
            </button>
  </div>
    </div>

    <!-- Mensagem de Status -->
    @if (!string.IsNullOrEmpty(Message))
 {
        <div class="alert-custom alert-info" style="margin-bottom: 1.5rem;">
            <i class="bi bi-info-circle-fill"></i>
            <div>@Message</div>
            <button type="button" style="background: none; border: none; color: inherit; cursor: pointer; margin-left: auto; font-size: 1.2rem;" @onclick='() => Message = ""'>×</button>
      </div>
    }

    <!-- Card Tabela -->
    <div class="custom-card elevation-2">
@if (Modulos == null || !Modulos.Any())
        {
            <div class="card-body-custom text-center py-5">
     <i class="bi bi-search" style="font-size: 3rem; color: #ccc;"></i>
    <p class="mt-3 text-muted">Nenhum módulo encontrado</p>
</div>
        }
  else
        {
        <div style="overflow-x: auto;">
              <table class="custom-table">
         <thead>
      <tr>
   <th style="width: 15%;">Nş / UFCD</th>
                <th style="width: 35%;">Nome do Módulo</th>
              <th style="width: 35%;">Professor</th>
    <th style="width: 15%;" class="text-center">Açőes</th>
      </tr>
             </thead>
         <tbody>
            @foreach (var m in Modulos)
               {
         <tr>
    <td>
        <span class="badge badge-custom badge-primary">@m.Numero</span>
               </td>
 <td>
              <strong>@m.Nome</strong>
        </td>
    <td>
      @if (m.Professor != null)
       {
       <div class="d-flex align-items-center">
      <div class="avatar-circle me-2" style="width: 28px; height: 28px; font-size: 0.8rem;">
         @m.Professor.Nome.Substring(0, 1).ToUpper()
         </div>
      <span>@m.Professor.Nome</span>
 </div>
                  }
  else
    {
      <span class="text-muted small">Năo definido</span>
       }
     </td>
     <td class="text-center">
        <div class="d-flex justify-content-center gap-1">
     <button class="btn btn-custom btn-custom-primary" style="padding: 6px 12px;"
           @onclick="() => Editar(m)" title="Editar">
        <i class="bi bi-pencil"></i>
   </button>
    <button class="btn btn-custom btn-custom-danger" style="padding: 6px 12px;"
  @onclick="() => Remover(m.Id)" title="Remover">
     <i class="bi bi-trash"></i>
   </button>
  </div>
     </td>
            </tr>
        }
      </tbody>
         </table>
            </div>
        }
    </div>
</div>

<!-- Modal Ediçăo -->
@if (MostrarModal)
{
    <div class="modal-bg animate-fade-in">
        <div class="modal-card animate-slide-up">
     <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 class="text-gradient" style="margin: 0; font-weight: 700;">Editar Módulo</h3>
 <button type="button" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;" @onclick="Cancelar">×</button>
            </div>

            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label"><i class="bi bi-tag"></i> Nome do Módulo</label>
            <input class="form-control" @bind="EditarModulo.Nome" placeholder="Digite o nome" />
</div>

      <div class="form-group" style="margin-bottom: 0;">
         <label class="form-label"><i class="bi bi-hash"></i> Número/UFCD</label>
          <input class="form-control" @bind="EditarModulo.Numero" placeholder="Ex: 0778" />
     </div>

 <div class="form-group" style="margin-bottom: 0;">
       <label class="form-label"><i class="bi bi-person"></i> Professor</label>
             <InputSelect @bind-Value="EditarModulo.ProfessorId" class="form-select">
          <option value="0">Selecione um professor...</option>
   @foreach (var p in Professores)
          {
     <option value="@p.Id">@p.Nome</option>
        }
         </InputSelect>
     </div>
          </div>

      <div class="d-flex gap-2" style="margin-top: 2rem;">
       <button class="btn btn-custom btn-custom-outline" style="flex: 1;" @onclick="Cancelar">
                <i class="bi bi-x"></i> Cancelar
       </button>
            <button class="btn btn-custom btn-custom-success" style="flex: 1;" @onclick="Salvar">
  <i class="bi bi-check2"></i> Guardar
        </button>
   </div>
     </div>
    </div>
}

@code {
    private List<Modulo> Modulos = new();
  private List<Professor> Professores = new();
    private Modulo EditarModulo = new();
    private bool MostrarModal = false;
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        try
        {
     var resProfs = await ProfessorService.GetProfessoresAsync();
      Professores = resProfs ?? new List<Professor>();

       await CarregarModulos();
        }
 catch (Exception ex)
   {
            Message = "Erro ao carregar dados: " + ex.Message;
        }
    }

    private async Task CarregarModulos()
    {
        try
        {
   var resMods = await ModuloService.GetModulosComProfessorAsync();
            Modulos = resMods ?? new List<Modulo>();
 }
        catch
        {
    Modulos = new List<Modulo>();
}
    }

    private void Editar(Modulo m)
  {
        EditarModulo = new Modulo
        {
            Id = m.Id,
  Nome = m.Nome,
            Numero = m.Numero,
        ProfessorId = m.ProfessorId
        };
        MostrarModal = true;
    }

    private async Task Salvar()
    {
     if (string.IsNullOrWhiteSpace(EditarModulo.Nome)) return;
        try
     {
      await ModuloService.UpdateModuloAsync(EditarModulo);
   Message = "? Módulo atualizado!";
      MostrarModal = false;
  await CarregarModulos();
      }
        catch (Exception ex)
        {
       Message = "? Erro ao salvar: " + ex.Message;
  }
    }

    private async Task Remover(int id)
    {
      if (!await JS.InvokeAsync<bool>("confirm", "Tem a certeza que deseja remover este módulo?"))
     return;

        try
        {
var modulo = Modulos.FirstOrDefault(m => m.Id == id);
       if (modulo != null)
            {
       await ModuloService.RemoveModuloAsync(modulo);
            Message = "? Módulo removido com sucesso!";
                await CarregarModulos();
      }
        }
        catch (Exception ex)
        {
      Message = "? Erro ao remover: " + ex.Message;
        }
    }

    private void Cancelar() => MostrarModal = false;
}
