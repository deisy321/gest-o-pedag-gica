@page "/admin/RegisterAdmin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using gestaopedagogica.Data
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.RegularExpressions
@attribute [Authorize(Roles = "Administrador")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ProfessorService ProfessorService
@inject AlunoService AlunoService
@inject NavigationManager Navigation
@inject ILogger<RegisterAdmin> Logger
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

<div class="main-content">
    <div class="page-admin">
        <AuthorizeView Roles="Administrador">
            <Authorized Context="authContext">

      @* Cabeēalho *@
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
   <h2 class="fw-bold text-gradient mb-0">Registar Utilizador</h2>
                   <p class="text-muted">Crie novos acessos para Alunos, Professores ou Administradores.</p>
                </div>
       <button class="user-profile-btn border" @onclick='() => Navigation.NavigateTo("/admin/DashboardAdmin")'>
              <i class="bi bi-arrow-left me-2"></i> Dashboard
     </button>
        </div>

           <div class="row justify-content-center">
   <div class="col-lg-8">
  <div class="custom-card shadow-sm p-4 p-md-5">

           @if (!string.IsNullOrEmpty(ErrorMessage))
         {
      <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 12px;">
  <i class="bi bi-exclamation-octagon me-2"></i> @ErrorMessage
           </div>
        }

          @if (ShowSuccessMessage)
           {
       <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 12px;">
      <i class="bi bi-check-circle me-2"></i> Utilizador registado com sucesso no sistema!
     </div>
     }

    <EditForm EditContext="new EditContext(Input)" OnValidSubmit="HandleRegisterAsync">
            <DataAnnotationsValidator />

<div class="row g-3">
  <div class="col-md-12">
         <label class="form-label small fw-bold text-muted text-uppercase">Nome Completo</label>
       <InputText @bind-Value="Input.Nome" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="Ex: Joćo Silva" />
     <ValidationMessage For="@(() => Input.Nome)" class="text-danger small" />
      </div>

   <div class="col-md-12">
        <label class="form-label small fw-bold text-muted text-uppercase">Email de Acesso</label>
     <InputText @bind-Value="Input.Email" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="exemplo@escola.pt" />
        <ValidationMessage For="@(() => Input.Email)" class="text-danger small" />
        </div>

                <div class="col-md-12 my-3">
          <label class="form-label small fw-bold text-muted text-uppercase d-block mb-3">Tipo de Perfil</label>
    <div class="d-flex flex-wrap gap-3">
  <InputRadioGroup @bind-Value="SelectedRole">
         @foreach (var role in UserRoles.AllRoles)
   {
     <div class="form-check form-check-inline m-0">
            <InputRadio Value="@role.Key" class="form-check-input" id="@role.Key" />
         <label class="form-check-label ms-1" for="@role.Key">
             <span class="badge rounded-pill border py-2 px-3 @(SelectedRole == role.Key ? "bg-primary text-white border-primary" : "bg-white text-dark")" style="cursor:pointer; transition: 0.3s;">
         @role.Value.DisplayName
          </span>
     </label>
          </div>
          }
                  </InputRadioGroup>
      </div>
                </div>

        <div class="col-md-6">
   <label class="form-label small fw-bold text-muted text-uppercase">Senha</label>
   <InputText type="password" @bind-Value="Input.Password" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="Mķnimo 6 caracteres" />
            <ValidationMessage For="@(() => Input.Password)" class="text-danger small" />
           </div>

       <div class="col-md-6">
   <label class="form-label small fw-bold text-muted text-uppercase">Confirmar Senha</label>
         <InputText type="password" @bind-Value="Input.ConfirmPassword" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="Repita a senha" />
 <ValidationMessage For="@(() => Input.ConfirmPassword)" class="text-danger small" />
                </div>
         </div>

       <div class="mt-5">
     <button type="submit" class="qa-item blue border-0 w-100 py-3 shadow-sm"
          style="margin-bottom:0; border-radius:12px; color: white !important;"
disabled="@IsSubmitting">
 @if (IsSubmitting)
     {
       <span class="spinner-border spinner-border-sm me-2"></span>
    @("A processar...")
               }
        else
             {
        <i class="bi bi-person-check me-2"></i>
   @("Finalizar Registo")
         }
     </button>
</div>
                </EditForm>
      </div>
      </div>
     </div>

  </Authorized>
            <NotAuthorized>
             <div class="alert alert-warning">Nćo tem permissćo para aceder a esta pįgina.</div>
    </NotAuthorized>
   </AuthorizeView>
    </div>
</div>

@code {
    private RegisterAdminInputModel Input { get; set; } = new();
    private string SelectedRole { get; set; } = "Aluno";
    private string ErrorMessage { get; set; } = string.Empty;
    private bool ShowSuccessMessage { get; set; } = false;
    private bool IsSubmitting { get; set; } = false;

    public class RegisterAdminInputModel
    {
        [Required(ErrorMessage = "O nome é obrigatório.")]
        public string Nome { get; set; } = string.Empty;

        [Required(ErrorMessage = "O email é obrigatório.")]
        [EmailAddress(ErrorMessage = "Email invįlido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "A senha é obrigatória.")]
  [MinLength(6, ErrorMessage = "A senha deve ter pelo menos 6 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Compare("Password", ErrorMessage = "As senhas nćo correspondem.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    public static class UserRoles
    {
        public record RoleInfo(string DisplayName, string CssClass);
     public static readonly Dictionary<string, RoleInfo> AllRoles = new() {
   { "Aluno", new RoleInfo("Aluno", "bg-success") },
       { "Professor", new RoleInfo("Professor", "bg-primary") },
{ "Administrador", new RoleInfo("Administrador", "bg-danger") }
        };
    }

    private async Task HandleRegisterAsync()
    {
 IsSubmitting = true;
        ErrorMessage = string.Empty;
  ShowSuccessMessage = false;

      try
        {
            // Validaēćo: Verifique se o email jį existe
            var usuarioExistente = await UserManager.FindByEmailAsync(Input.Email);
       if (usuarioExistente != null)
    {
         ErrorMessage = "Este email jį estį registado no sistema.";
            IsSubmitting = false;
        return;
          }

      string cleanUserName = Regex.Replace(Input.Nome.Normalize(System.Text.NormalizationForm.FormD), @"[^a-zA-z0-9]", "");

            // Garanta que o username seja śnico
    int counter = 0;
            string originalUserName = cleanUserName;
            while (await UserManager.FindByNameAsync(cleanUserName) != null)
       {
    cleanUserName = $"{originalUserName}{++counter}";
     }

  var user = new ApplicationUser
       {
      UserName = cleanUserName,
          Email = Input.Email,
      EmailConfirmed = true
            };

            var result = await UserManager.CreateAsync(user, Input.Password);

          if (result.Succeeded)
            {
          // Adiciona o utilizador ą role
         var roleResult = await UserManager.AddToRoleAsync(user, SelectedRole);

     if (!roleResult.Succeeded)
     {
        ErrorMessage = "Erro ao atribuir perfil: " + string.Join(", ", roleResult.Errors.Select(e => e.Description));
         IsSubmitting = false;
        return;
         }

              // Cria o registo correspondente (Professor ou Aluno)
             try
   {
      if (SelectedRole == "Professor")
            {
      var novoProf = new Professor
  {
        Nome = Input.Nome,
     Email = Input.Email,
          UserId = user.Id
     };
               await ProfessorService.AddProfessorAsync(novoProf);
     }
 else if (SelectedRole == "Aluno")
          {
      var novoAluno = new Aluno
   {
             Nome = Input.Nome,
 Email = Input.Email,
             UserId = user.Id,
            TurmaId = null
      };
        await AlunoService.AddAlunoAsync(novoAluno);
                    }
         // Se for Administrador, nćo precisa de registo adicional

       ShowSuccessMessage = true;
Input = new RegisterAdminInputModel();
          SelectedRole = "Aluno";

    // Limpa a mensagem de sucesso após 4 segundos
     _ = Task.Delay(4000).ContinueWith(_ =>
              {
    ShowSuccessMessage = false;
          StateHasChanged();
          });
     }
            catch (Exception serviceEx)
    {
       ErrorMessage = $"Utilizador criado, mas erro ao registar dados adicionais: {serviceEx.Message}";
        Logger.LogError($"Erro ao registar {SelectedRole}: {serviceEx.Message}");
    }
          }
         else
    {
    ErrorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
      Logger.LogWarning($"Falha ao criar utilizador: {ErrorMessage}");
  }
        }
     catch (Exception ex)
        {
ErrorMessage = "Erro inesperado: " + ex.Message;
 Logger.LogError($"Erro geral no registo: {ex.Message}");
     }
     finally
  {
            IsSubmitting = false;
        }
    }
}
