@page "/aluno/DashboardAluno"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject TurmaService TurmaService
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject DisciplinaService DisciplinaService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@layout MainLayout

<div class="page-student p-4">
    @if (IsLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Carregando seu dashboard...</p>
        </div>
    }
    else
    {
        <div class="admin-header-row d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title fw-bold">Meu Dashboard</h1>
                <p class="page-subtitle text-muted">Acompanhe seus trabalhos, notas e progresso</p>
            </div>
            <div class="d-flex gap-2" style="flex-wrap: wrap;">
                <button class="btn btn-outline-secondary rounded-pill px-4" @onclick="IrParaMinhasNotas">
                    <i class="bi bi-graph-up"></i> Minhas Notas
                </button>
                <button class="btn btn-primary rounded-pill px-4" @onclick="IrParaHistorico">
                    <i class="bi bi-clock-history"></i> Histórico
                </button>
            </div>
        </div>

        @* Alerta de Plano de Recuperação *@
        @if (TodosTrabalhos != null && TodosTrabalhos.Any(t => t.IsPlanoRecuperacao && (CalcularNotaTrabalho(t.TrabalhoVertentes) == null || CalcularNotaTrabalho(t.TrabalhoVertentes) <= 9.0)))
        {
            <div class="alert alert-danger shadow-sm border-0 mb-4 animate__animated animate__pulse" style="border-radius: 15px; border-left: 8px solid #dc3545 !important;">
                <h5 class="fw-bold"><i class="bi bi-lightning-charge-fill"></i> Tens Planos de Recuperação Ativos!</h5>
                <p>O teu professor enviou atividades específicas para melhorar as tuas notas nas vertentes críticas.</p>
                <div class="d-flex gap-2" style="flex-wrap: wrap;">
                    @foreach (var plano in TodosTrabalhos.Where(t => t.IsPlanoRecuperacao && (CalcularNotaTrabalho(t.TrabalhoVertentes) == null || CalcularNotaTrabalho(t.TrabalhoVertentes) <= 9.0)))
                    {
                        <button class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm" @onclick="() => ResolverTrabalho(plano.Id)">
                            <i class="bi bi-pencil-square"></i> Resolver: @plano.Titulo
                        </button>
                    }
                </div>
            </div>
        }

        @* Cards de Estatísticas *@
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-yellow p-3 shadow-sm rounded-4 d-flex align-items-center">
                    <i class="bi bi-clipboard-check fs-1 me-3 text-warning"></i>
                    <div>
                        <h6 class="mb-0 text-muted">Trabalhos Pendentes</h6>
                        <h3 class="fw-bold mb-0">@TrabalhosPendentes.Count</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-blue p-3 shadow-sm rounded-4 d-flex align-items-center">
                    <i class="bi bi-book fs-1 me-3 text-primary"></i>
                    <div>
                        <h6 class="mb-0 text-muted">Disciplinas</h6>
                        <h3 class="fw-bold mb-0">@DisciplinasUnicas.Count</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-green p-3 shadow-sm rounded-4 d-flex align-items-center">
                    <i class="bi bi-graph-up fs-1 me-3 text-success"></i>
                    <div>
                        <h6 class="mb-0 text-muted">Média Geral</h6>
                        <h3 class="fw-bold mb-0">@MediaGeral.ToString("F1")</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card bg-white p-3 shadow-sm rounded-4 d-flex align-items-center border">
                    <i class="bi bi-people-fill fs-1 me-3 text-info"></i>
                    <div>
                        <h6 class="mb-0 text-muted">Turma</h6>
                        <h3 class="fw-bold mb-0 text-dark">@(TurmaAtual?.Nome ?? "N/D")</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Filtros *@
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body">
                <h5 class="mb-3 fw-bold"><i class="bi bi-funnel"></i> Filtros</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Disciplina</label>
                        <select class="form-select rounded-pill" @onchange="OnDisciplinaChanged">
                            <option value="">Todas as Disciplinas</option>
                            @foreach (var d in DisciplinasUnicas)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Módulo</label>
                        <select class="form-select rounded-pill" @bind="ModuloSelecionado" @bind:after="FiltrarTrabalhos">
                            <option value="">Todos os Módulos</option>
                            @foreach (var m in ModulosDisponiveis)
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @* Tabela de Trabalhos *@
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h5 class="fw-bold"><i class="bi bi-list-task"></i> Meus Trabalhos</h5>
            </div>
            <div class="card-body p-0">
                @if (!TrabalhosFiltrados.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="mt-3 text-muted">Nenhum trabalho encontrado</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Título</th>
                                    <th>Disciplina</th>
                                    <th>Módulo</th>
                                    <th>Progresso</th>
                                    <th>Nota</th>
                                    <th class="text-center pe-4">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in TrabalhosFiltrados)
                                {
                                    var perc = CalcularPercentualConclusao(t.TrabalhoVertentes);
                                    var nota = CalcularNotaTrabalho(t.TrabalhoVertentes);
                                    <tr class="@(t.IsPlanoRecuperacao ? "table-danger-light" : "")">
                                        <td class="ps-4">
                                            <span class="fw-bold d-block">@t.Titulo</span>
                                            @if (t.IsPlanoRecuperacao)
                                            {
                                                <span class="badge bg-danger" style="font-size: 0.65rem;">RECUPERAÇÃO</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-primary rounded-pill px-3">@(t.Disciplina?.Nome ?? "N/D")</span></td>
                                        <td><span class="text-muted">@t.Modulo?.Nome</span></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2" style="min-width: 120px;">
                                                <div class="progress w-100" style="height: 6px;">
                                                    <div class="progress-bar bg-success" style="width:@perc%"></div>
                                                </div>
                                                <small class="fw-bold">@perc.ToString("F0")%</small>
                                            </div>
                                        </td>
                                        <td>
                                            @if (nota.HasValue)
                                            {
                                                <span class="fw-bold" style="color: @(nota.Value >= 9.5 ? "#198754" : nota.Value >= 8 ? "#fd7e14" : "#dc3545");">
                                                    @nota.Value.ToString("F1")
                                                </span>
                                            }
                                            else
                                            {

                                                <span class="text-muted">--</span>
                                            }
                                        </td>
                                        <td class="text-center pe-4">
                                            <button class="btn btn-sm @(t.IsPlanoRecuperacao ? "btn-danger" : "btn-primary") rounded-pill px-3" @onclick="() => ResolverTrabalho(t.Id)">
                                                <i class="bi bi-eye"></i> Abrir
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* Seção de Badges *@
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h5 class="fw-bold mb-4">
                <i class="bi bi-award-fill text-warning"></i> Meus Badges
                <span class="badge bg-light text-primary ms-2">@BadgesConquistados.Count / @TodosBadges.Count</span>
            </h5>

            <div class="row g-4 justify-content-center">
                @foreach (var badge in TodosBadges)
                {
                    bool conquistado = BadgesConquistados.Contains(badge.Key);
                    string imagemBadge = badge.Key switch
                    {
                        "Entrega no Prazo" => "/images/EntregaNoPrazo.png",
                        "Notas Altas" => "/images/NotasAltas.png",
                        "Envio Consistente" => "/images/EnvioConsistente.png",
                        "Engajamento Diário" => "/images/EngajamentoDiário.png",
                        "Top Performer" => "/images/TopPerformer.png",
                        "Participação Ativa" => "/images/ParticipaçãoAtiva.png",
                        _ => "/images/TopPerformer.png"
                    };

                    <div class="col-6 col-md-4 col-lg-2 text-center">
                        <div class="badge-container @(conquistado ? "conquistado" : "bloqueado")">
                            <img src="@imagemBadge" alt="@badge.Key" class="img-fluid mb-2 badge-img" />
                            <h6 class="small fw-bold mb-1">@badge.Key</h6>
                            @if (conquistado)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill" style="font-size: 0.65rem;">✓ Conquistado</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border rounded-pill" style="font-size: 0.65rem;">🔒 Bloqueado</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private Aluno? AlunoAtual;
    private Turma? TurmaAtual;
    private List<Trabalho> TodosTrabalhos = new();
    private List<Trabalho> TrabalhosPendentes = new();
    private List<Trabalho> TrabalhosFiltrados = new();
    private List<string> DisciplinasUnicas = new();
    private List<string> ModulosDisponiveis = new();
    private string DisciplinaSelecionada = "";
    private string ModuloSelecionado = "";
    private double MediaGeral = 0;
    private string? AlunoUserId;
    private bool IsLoading = true;

    private Dictionary<string, (string Icon, string Descricao, string Tooltip)> TodosBadges = new()
    {
        { "Entrega no Prazo", ("", "Entregue todos os trabalhos dentro do prazo", "") },
        { "Notas Altas", ("", "Obtenha notas altas nos módulos", "") },
        { "Envio Consistente", ("", "Seja consistente nos envios", "") },
        { "Engajamento Diário", ("", "Envie trabalhos todos os dias", "") },
        { "Top Performer", ("", "Seja destaque em uma disciplina", "") },
        { "Participação Ativa", ("", "Participe ativamente", "") }
    };

    private List<string> BadgesConquistados = new();

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            AlunoUserId = auth.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            await CarregarDados();

            BadgesConquistados.Clear();

            if (TodosTrabalhos.Any() && TodosTrabalhos.All(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.All(v => !string.IsNullOrEmpty(v.ConteudoTextoAluno))))
                BadgesConquistados.Add("Entrega no Prazo");

            if (MediaGeral >= 15.0)
                BadgesConquistados.Add("Notas Altas");

            if (TodosTrabalhos.Any() && TodosTrabalhos.All(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.Any(v => !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null)))
                BadgesConquistados.Add("Envio Consistente");

            if (TodosTrabalhos.Count(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.Any(v => v.Nota.HasValue && v.Nota.Value >= 15)) >= 3)
                BadgesConquistados.Add("Top Performer");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar dashboard: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CarregarDados()
    {
        var alunos = await AlunoService.GetAlunosAsync();
        AlunoAtual = alunos.FirstOrDefault(a => a.UserId == AlunoUserId);

        if (AlunoAtual?.TurmaId != null)
            TurmaAtual = await TurmaService.GetTurmaByIdAsync(AlunoAtual.TurmaId.Value);

        TodosTrabalhos = await TrabalhoService.GetTrabalhosDisponiveisParaAlunoAsync(AlunoUserId ?? "");
        TrabalhosPendentes = TodosTrabalhos.Where(t => t.TrabalhoVertentes == null || t.TrabalhoVertentes.Any(v => !v.Nota.HasValue)).ToList();

        DisciplinasUnicas = TodosTrabalhos.Select(t => t.Disciplina?.Nome).Where(n => !string.IsNullOrEmpty(n)).Distinct().ToList()!;
        ModulosDisponiveis = TodosTrabalhos.Select(t => t.Modulo?.Nome).Where(n => !string.IsNullOrEmpty(n)).Distinct().ToList()!;

        var notas = TodosTrabalhos.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                                 .Where(v => v.Nota.HasValue)
                                 .Select(v => (double)v.Nota!.Value);
        MediaGeral = notas.Any() ? notas.Average() : 0;

        FiltrarTrabalhos();
    }

    private void OnDisciplinaChanged(ChangeEventArgs e)
    {
        DisciplinaSelecionada = e.Value?.ToString() ?? "";
        // Atualiza módulos disponíveis conforme a disciplina para facilitar o filtro
        ModulosDisponiveis = TodosTrabalhos
            .Where(t => string.IsNullOrEmpty(DisciplinaSelecionada) || t.Disciplina?.Nome == DisciplinaSelecionada)
            .Select(t => t.Modulo?.Nome).Where(n => !string.IsNullOrEmpty(n)).Distinct().ToList()!;

        ModuloSelecionado = "";
        FiltrarTrabalhos();
    }

    private void FiltrarTrabalhos()
    {
        TrabalhosFiltrados = TodosTrabalhos
            .Where(t =>
                (string.IsNullOrEmpty(DisciplinaSelecionada) || t.Disciplina?.Nome == DisciplinaSelecionada) &&
                (string.IsNullOrEmpty(ModuloSelecionado) || t.Modulo?.Nome == ModuloSelecionado))
            .ToList();
    }

    private double CalcularPercentualConclusao(ICollection<TrabalhoVertente>? v)
    {
        if (v == null || !v.Any()) return 0;
        var done = v.Count(x => !string.IsNullOrEmpty(x.ConteudoTextoAluno) || x.FicheiroBytes != null);
        return (double)done / v.Count * 100;
    }

    private double? CalcularNotaTrabalho(ICollection<TrabalhoVertente>? v)
    {
        if (v == null || !v.Any()) return null;
        var notas = v.Where(x => x.Nota.HasValue).Select(x => (double)x.Nota.Value);
        return notas.Any() ? notas.Average() : null;
    }

    private void ResolverTrabalho(int id) => Nav.NavigateTo($"/aluno/EnviarTrabalho/{id}");
    private void IrParaMinhasNotas() => Nav.NavigateTo("/aluno/MinhasNotas");
    private void IrParaHistorico() => Nav.NavigateTo("/aluno/Historico");
}

<style>
    .table-danger-light {
        background-color: rgba(220, 53, 69, 0.03) !important;
    }

    .badge-img {
        width: 60px;
        height: 60px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .badge-container.bloqueado {
        opacity: 0.4;
        filter: grayscale(1);
    }

    .badge-container.conquistado .badge-img {
        filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.5));
        transform: scale(1.1);
    }

    .stat-card {
        transition: transform 0.2s;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .card-yellow {
        background-color: #fffdf0;
    }

    .card-blue {
        background-color: #f0f7ff;
    }

    .card-green {
        background-color: #f0fff4;
    }
</style>