@page "/professor/FichaAluno/{AlunoId}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject TrabalhoService TrabalhoService
@inject NavigationManager Navigation

<div class="container">
    <h3>Gestão de Plano de Recuperação</h3>

    @if (carregando)
    {
        <div class="text-center">
            <div class="spinner-border" role="status"></div>
            <p>A carregar dados...</p>
        </div>
    }
    else
    {
        <div class="card p-4 shadow-sm">
            <EditForm Model="@novoPlano" OnValidSubmit="GravarPlanoRecuperacao">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label fw-bold">Título do Plano</label>
                    <InputText @bind-Value="novoPlano.Titulo" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Descrição / Instruções</label>
                    <InputTextArea @bind-Value="novoPlano.ConteudoTexto" class="form-control" rows="3" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Horas Atribuídas</label>
                        <InputNumber @bind-Value="novoPlano.HorasAtribuidas" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Prazo de Entrega</label>
                        <InputDate @bind-Value="novoPlano.PrazoEntrega" class="form-control" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success" disabled="@estaProcessando">
                        @if (estaProcessando)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span> A gravar...</span>
                        }
                        else
                        {
                            <span>Criar Plano de Recuperação</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public string AlunoId { get; set; }

    [SupplyParameterFromQuery] public int ModuloIdAtual { get; set; }
    [SupplyParameterFromQuery] public int DisciplinaIdAtual { get; set; }
    [SupplyParameterFromQuery] public string ProfessorIdAtual { get; set; }

    private Trabalho novoPlano = new Trabalho();
    private bool carregando = true;
    private bool estaProcessando = false;

    protected override void OnInitialized()
    {
        novoPlano.AlunoId = AlunoId;
        novoPlano.ProfessorId = ProfessorIdAtual;
        novoPlano.ModuloId = ModuloIdAtual > 0 ? ModuloIdAtual : null;
        novoPlano.DisciplinaId = DisciplinaIdAtual > 0 ? DisciplinaIdAtual : null;
        novoPlano.PrazoEntrega = DateTime.Now.AddDays(7);
        novoPlano.Titulo = "Plano de Recuperação";

        carregando = false;
    }

    private async Task GravarPlanoRecuperacao()
    {
        if (estaProcessando) return;

        try
        {
            estaProcessando = true;

            int novoTrabalhoId = await TrabalhoService.CriarTrabalhoAsync(novoPlano);

            if (novoTrabalhoId > 0)
            {
                var vertenteRecuperacao = new TrabalhoVertente
                {
                    TrabalhoId = novoTrabalhoId,
                    Tipo = "Recuperação",
                    ConteudoTexto = novoPlano.ConteudoTexto ?? "Avaliação referente ao plano de recuperação.",
                    Feedback = ""
                    // DataCriacao removida para evitar o erro anterior
                };

                await TrabalhoService.AddVertenteAsync(vertenteRecuperacao);
                Navigation.NavigateTo($"/trabalhos-professor/{ProfessorIdAtual}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }
        finally
        {
            estaProcessando = false;
        }
    }
}