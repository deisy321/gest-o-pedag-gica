@page "/admin/GerirUtilizadores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using gestaopedagogica.Data
@using Microsoft.EntityFrameworkCore
@using gestaopedagogica.Services

@attribute [Authorize(Roles = "Administrador")]
@inject RoleManager<IdentityRole> RoleManager
@inject UserManager<ApplicationUser> UserManager
@inject UserService UserService
@inject IJSRuntime JS
@inject NavigationManager Nav

@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

<div class="main-content">
    <div class="page-admin">
        @* Cabeçalho com Gradiente *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-gradient mb-0">Gestão de Utilizadores</h2>
                <p class="text-muted">Administre as contas de acesso e permissões do sistema.</p>
            </div>
            <div class="d-flex gap-2">
                <button class="user-profile-btn border" @onclick='() => Nav.NavigateTo("/admin/DashboardAdmin")'>
                    <i class="bi bi-arrow-left me-2"></i> Voltar
                </button>
                @* Botão alterado para navegar para a página de registo completa *@
                <button class="qa-item green border-0 shadow-sm px-4"
                        style="margin-bottom:0; height: 45px; display: flex; align-items: center;"
                        @onclick='() => Nav.NavigateTo("/admin/RegisterAdmin")'>
                    <i class="bi bi-person-plus me-2"></i> Novo Utilizador
                </button>
            </div>
        </div>

        @* Tabela Customizada *@
        <div class="custom-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="custom-table mb-0">
                    <thead>
                        <tr>
                            <th>UTILIZADOR</th>
                            <th>EMAIL</th>
                            <th>PERFIL / ROLE</th>
                            <th class="text-center">AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Usuarios == null || !Usuarios.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-people fs-2 d-block mb-2"></i>
                                    Nenhum utilizador encontrado.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Usuarios)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2" style="width:30px; height:30px;">
                                                @(user.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                            </div>
                                            <span class="fw-bold">@user.UserName</span>
                                        </div>
                                    </td>
                                    <td>@user.Email</td>
                                    <td>
                                        @{
                                            var roles = UserRoles.ContainsKey(user.Id) ? UserRoles[user.Id] : new List<string> { "Sem Perfil" };
                                            foreach (var role in roles)
                                            {
                                                <span class="badge rounded-pill bg-light text-dark border me-1">@role</span>
                                            }
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <button class="btn btn-sm btn-outline-warning rounded-pill" title="Resetar Senha" @onclick="() => ResetarSenha(user)">
                                                <i class="bi bi-key"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill" title="Remover" @onclick="() => Remover(user)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ApplicationUser> Usuarios = new();
    private Dictionary<string, List<string>> UserRoles = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarUsuarios();
    }

    private async Task CarregarUsuarios()
    {
        try
        {
            // Carregamos a lista de utilizadores
            Usuarios = await UserManager.Users.AsNoTracking().ToListAsync();
            UserRoles.Clear();

            foreach (var u in Usuarios)
            {
                var rolesForUser = await UserManager.GetRolesAsync(u);
                UserRoles[u.Id] = rolesForUser.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erro ao carregar utilizadores: " + ex.Message);
        }
    }

    private async Task ResetarSenha(ApplicationUser user)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja resetar a senha de {user.UserName} para 'Temp123!'?");
        if (!confirmado) return;

        var dbUser = await UserManager.FindByIdAsync(user.Id);
        if (dbUser != null)
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(dbUser);
            var result = await UserManager.ResetPasswordAsync(dbUser, token, "Temp123!");
            await JS.InvokeVoidAsync("alert", result.Succeeded ? "Senha alterada com sucesso!" : "Falha ao resetar senha.");
        }
    }

    private async Task Remover(ApplicationUser user)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"ATENÇÃO: Deseja remover permanentemente o utilizador {user.UserName}?");
        if (!confirmado) return;

        try
        {
            // Utiliza o serviço para garantir que a limpeza nas tabelas Aluno/Professor também ocorra
            await UserService.ExcluirUsuarioAsync(user.Id);
            await CarregarUsuarios();
            await JS.InvokeVoidAsync("alert", "Utilizador removido.");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro ao remover: " + ex.Message);
        }
    }
}