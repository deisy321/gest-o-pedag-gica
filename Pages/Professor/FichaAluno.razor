@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject TrabalhoService TrabalhoService
@inject AlunoService AlunoService

<div class="container-fluid animate-fade-in">
    @if (aluno == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else
    {
        <h2 class="mb-4">Ficha de Desempenho: <span class="text-primary">@aluno.Nome</span></h2>

        @foreach (var m in ModulosProcessados)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span><strong>Módulo:</strong> @m.Nome</span>
                    <span class="badge bg-info">@m.HorasConsumidas / @m.HorasTotais Horas</span>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Trabalho</th>
                                <th>Status</th>
                                <th>Nota Média</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in m.TrabalhosWrapper)
                            {
                                <tr>
                                    <td>@t.Dados.Titulo</td>
                                    <td>
                                        <span class="badge @(t.Dados.Status == "Avaliado" ? "bg-success" : "bg-warning")">
                                            @t.Dados.Status
                                        </span>
                                    </td>
                                    @* ✅ Agora usamos a nota calculada localmente *@
                                    <td>@(t.NotaCalculada > 0 ? t.NotaCalculada.ToString("F2") : "---")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="mt-3 p-3 border-top d-flex justify-content-end">
                        @if (m.ProntoParaMediaFinal)
                        {
                            <div class="text-end">
                                <span class="text-muted me-2">Média Global do Módulo:</span>
                                <h3 class="d-inline text-success">@m.MediaGlobal.ToString("F2")</h3>
                            </div>
                        }
                        else if (m.HorasConsumidas >= m.HorasTotais)
                        {
                            <div class="alert alert-warning py-2 mb-0">
                                <i class="fas fa-clock me-2"></i>
                                <strong>Aguardando Correção:</strong> A carga horária foi atingida, mas existem trabalhos pendentes.
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">Progresso: @((m.HorasConsumidas * 100) / m.HorasTotais)% (Faltam horas)</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? aluno;
    private List<ModuloResumo> ModulosProcessados = [];

    protected override async Task OnInitializedAsync()
    {
        aluno = await AlunoService.GetAlunoByIdAsync(AlunoId);
        if (aluno != null)
        {
            var trabalhos = await TrabalhoService.GetTrabalhosByAlunoAsync(aluno.UserId);
            ProcessarLogicaModulos(trabalhos);
        }
    }

    private void ProcessarLogicaModulos(List<Trabalho> trabalhos)
    {
        ModulosProcessados = trabalhos
            .GroupBy(t => t.ModuloId)
            .Select(grupo =>
            {
                var moduloInfo = grupo.First().Modulo;
                double horasConsumidas = grupo.Sum(t => t.HorasAtribuidas);

                // Criamos uma lista de "TrabalhoComNota" para calcular a nota sem mexer no modelo original
                var trabalhosComNota = grupo.Select(t => new TrabalhoComNota
                {
                    Dados = t,
                    NotaCalculada = (t.TrabalhoVertentes != null && t.TrabalhoVertentes.Any(v => v.Nota.HasValue))
                                    ? (double)t.TrabalhoVertentes.Where(v => v.Nota.HasValue).Average(v => (double)v.Nota!.Value)
                                    : 0
                }).ToList();

                bool cargaCompleta = horasConsumidas >= (moduloInfo?.TotalHoras ?? 0);
                bool todosAvaliados = grupo.All(t => t.Status == "Avaliado");
                bool pronto = cargaCompleta && todosAvaliados;

                double mediaGlobal = pronto ? trabalhosComNota.Average(tn => tn.NotaCalculada) : 0;

                return new ModuloResumo
                {
                    Nome = moduloInfo?.Nome ?? "Indefinido",
                    HorasTotais = moduloInfo?.TotalHoras ?? 0,
                    HorasConsumidas = (int)horasConsumidas,
                    TrabalhosWrapper = trabalhosComNota,
                    MediaGlobal = mediaGlobal,
                    ProntoParaMediaFinal = pronto
                };
            }).ToList();
    }

    // Estruturas auxiliares apenas para esta página
    public class ModuloResumo
    {
        public string Nome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public List<TrabalhoComNota> TrabalhosWrapper { get; set; } = [];
        public double MediaGlobal { get; set; }
        public bool ProntoParaMediaFinal { get; set; }
    }

    public class TrabalhoComNota
    {
        public Trabalho Dados { get; set; } = default!;
        public double NotaCalculada { get; set; }
    }
}