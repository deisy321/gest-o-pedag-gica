@page "/professor/DashboardProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject AlunoService AlunoService
@inject TurmaService TurmaService
@inject NavigationManager Nav
@inject IJSRuntime JS

<h2 class="fw-bold mb-4">Dashboard do Professor</h2>

@if (IsLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
        <p>Carregando dados...</p>
    </div>
}
else
{
    <!-- CARDS DE RESUMO NO TOPO -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-lg-2">
            <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #4e73df; border-radius: 15px;">
                <h6>Total de Alunos</h6>
                <h2>@Alunos.Count</h2>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #1cc88a; border-radius: 15px;">
                <h6>Total de Turmas</h6>
                <h2>@Turmas.Count</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- TABELA DE ALUNOS -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                <h5 class="fw-bold mb-3">Alunos</h5>

                <!-- FILTRO DE TURMA -->
                <div class="mb-3 d-flex align-items-center gap-3">
                    <select class="form-select shadow-sm" style="border-radius: 12px; width: 200px;" @onchange="FiltrarTurma">
                        <option value="">Todas as Turmas</option>
                        @foreach (var turma in Turmas)
                        {
                            <option value="@turma.Id">@turma.Nome</option>
                        }
                    </select>
                    <span class="text-muted small">Filtrar por turma</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Email</th>
                                <th>Turma</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (AlunosFiltrados != null && AlunosFiltrados.Any())
                            {
                                @foreach (var aluno in AlunosFiltrados)
                                {
                                    <tr>
                                        <td>@aluno.Email</td>
                                        <td>@(aluno.Turma?.Nome ?? "Sem turma")</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm"
                                                    @onclick='() => Nav.NavigateTo("/professor/FichaAluno/" + aluno.Id)'>
                                                Ver Ficha
                                            </button>
                                            <button class="btn btn-sm btn-success rounded-pill px-3 ms-2"
                                                    @onclick='() => Nav.NavigateTo("/professor/AvaliarAlunos/" + aluno.Id)'>
                                                Avaliar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted p-4">Nenhum aluno encontrado.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- AÇÕES RÁPIDAS DO PROFESSOR -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                <h5 class="fw-bold mb-4">Ações Rápidas</h5>

                <!-- CARD ESTILO TOPO PARA CRIAR TRABALHO -->
                <div class="card border-0 shadow-sm p-3 bg-white border-start border-primary border-4 mb-3" style="border-radius: 15px;">
                    <h6 class="text-muted small">Trabalhos</h6>
                    <p class="small text-muted mb-2">Criar novos trabalhos para alunos</p>
                    <button class="btn btn-outline-primary btn-sm rounded-pill w-100" @onclick="CriarTrabalho">Criar Trabalho</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Aluno> Alunos = new();
    private List<Aluno> AlunosFiltrados = new();
    private List<Turma> Turmas = new();
    private bool IsLoading = true;
    private int TurmaSelecionadaId = 0;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        Alunos = await AlunoService.GetAlunosAsync();
        Turmas = await TurmaService.GetTurmasAsync();
        AlunosFiltrados = Alunos;

        IsLoading = false;
    }

    private void FiltrarTurma(ChangeEventArgs e)
    {
        var turmaIdStr = e.Value?.ToString();
        if (string.IsNullOrEmpty(turmaIdStr))
        {
            AlunosFiltrados = Alunos;
            TurmaSelecionadaId = 0;
        }
        else
        {
            if (int.TryParse(turmaIdStr, out int turmaId))
            {
                TurmaSelecionadaId = turmaId;
                AlunosFiltrados = Alunos.Where(a => a.TurmaId == turmaId).ToList();
            }
            else
            {
                AlunosFiltrados = Alunos;
                TurmaSelecionadaId = 0;
            }
        }
    }

    private async Task CriarTrabalho()
    {
        if (TurmaSelecionadaId > 0)
        {
            Nav.NavigateTo("/professor/CriarRoteiro/" + TurmaSelecionadaId);
        }
        else
        {
            // Exibir mensagem de alerta se nenhuma turma selecionada
            await JS.InvokeVoidAsync("alert", "❌ Selecione uma turma antes de criar o trabalho.");
        }
    }
}