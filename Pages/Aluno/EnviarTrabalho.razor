@page "/aluno/EnviarTrabalho/{Id:int}"
@namespace gestaopedagogica.Pages.Aluno
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.IO

@inject TrabalhoService TrabalhoService
@inject PushService PushService
@inject NavigationManager Nav

<div class="page-student animate-fade-in">
    @if (Trabalho == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">A carregar detalhes do trabalho...</p>
        </div>
    }
    else
    {
        <div class="admin-header-row">
            <div>
                <h1 class="page-title">Entrega de Trabalho</h1>
                <p class="page-subtitle">Submissão para: <span class="text-gradient">@Trabalho.Titulo</span></p>
            </div>
            <button class="btn-custom btn-custom-outline" @onclick='() => Nav.NavigateTo("/aluno/DashboardAluno")'>
                <i class="fas fa-arrow-left"></i> Voltar
            </button>
        </div>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            var alertClass = StatusMessage.Contains("sucesso") ? "alert-success" : (StatusMessage.Contains("IA") ? "alert-info" : "alert-danger");
            var alertIcon = StatusMessage.Contains("sucesso") ? "fa-check-circle" : "fa-exclamation-triangle";

            <div class="alert-custom @alertClass mb-4 animate-slide-up">
                <i class="fas @alertIcon me-2"></i>
                <span>@StatusMessage</span>
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <EditForm Model="Vertentes">
                    @foreach (var vert in Vertentes)
                    {
                        <div class="custom-card mb-4 elevation-2 border-start-primary">
                            <div class="card-header-custom d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-primary">@vert.Tipo</h5>
                                @if (vert.Nota.HasValue)
                                {
                                    <span class="badge-custom badge-success">Nota Atual: @vert.Nota</span>
                                }
                            </div>

                            <div class="card-body-custom">
                                @if (!string.IsNullOrWhiteSpace(vert.ConteudoTextoProfessor))
                                {
                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold">ORIENTAÇÕES DO PROFESSOR</label>
                                        <div class="p-3 bg-light rounded-lg border-start border-4 border-info" style="white-space: pre-line;">
                                            <i class="fas fa-chalkboard-teacher text-info me-2"></i>
                                            @vert.ConteudoTextoProfessor
                                        </div>
                                    </div>
                                }

                                <div class="form-group mt-4">
                                    <label class="form-label fw-bold">Sua Resposta / Desenvolvimento</label>
                                    <textarea class="form-control" rows="10" @bind="vert.ConteudoTextoAluno"
                                              placeholder="Escreva seu trabalho aqui..."></textarea>
                                </div>

                                <div class="mt-4 p-3 border rounded-lg bg-light shadow-sm">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-paperclip me-2 text-primary"></i>Anexar Documento (Opcional)
                                    </label>
                                    <InputFile OnChange="async e => await UploadArquivo(e, vert)" class="form-control mt-2" />

                                    @if (!string.IsNullOrEmpty(vert.ArquivoNome))
                                    {
                                        <div class="badge-custom badge-primary mt-2 d-inline-flex align-items-center">
                                            <i class="fas fa-file-alt me-2"></i> @vert.ArquivoNome
                                        </div>
                                    }
                                </div>

                                <div class="mt-4 pt-3 border-top">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="feedback_@vert.Id" @bind="vert.SolicitarFeedback" />
                                        <label class="form-check-label fw-600 ms-2" for="feedback_@vert.Id">
                                            Solicitar revisão da IA antes do envio oficial
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </EditForm>
            </div>

            <div class="col-lg-4">
                <div class="custom-card elevation-3 sticky-top" style="top: 100px;">
                    <div class="card-header-custom bg-white">
                        <h5>Resumo da Entrega</h5>
                    </div>
                    <div class="card-body-custom">
                        <div class="mb-3">
                            <small class="text-muted">Tipo de Trabalho:</small>
                            @if (Trabalho.IsPlanoRecuperacao)
                            {
                                <div class="badge bg-danger text-white d-block p-2 mt-1">
                                    <i class="fas fa-retweet"></i> PLANO DE RECUPERAÇÃO
                                </div>
                            }
                            else
                            {
                                <div class="fw-bold text-primary">Avaliação Normal</div>
                            }
                        </div>

                        <div class="d-grid gap-3 mt-4">
                            <button class="btn-custom btn-custom-secondary w-100 justify-content-center"
                                    @onclick="GerarFeedbackSelecionadoAsync" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="fas fa-robot me-2"></i> Gerar Feedback IA
                            </button>

                            <button class="btn-custom btn-custom-primary w-100 justify-content-center py-3"
                                    @onclick="EnviarVertentesAsync" disabled="@IsSaving">
                                <i class="fas fa-paper-plane me-2"></i> Submeter Trabalho
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* MODAL DE FEEDBACK IA *@
@if (MostrarModalFeedback)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-robot me-2"></i>Feedback da IA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalFeedback"></button>
                </div>
                <div class="modal-body p-4" style="max-height: 60vh; overflow-y: auto;">
                    @foreach (var fb in FeedbacksGerados)
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-primary">@fb.Tipo</h6>
                            <div class="p-3 bg-light rounded border-start border-4 border-primary">
                                @((MarkupString)fb.Texto.Replace("\n", "<br/>"))
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" @onclick="FecharModalFeedback">Voltar e Editar</button>
                    <button class="btn btn-primary" @onclick="AceitarFeedback">Submeter Agora</button>
                </div>
            </div>
        </div>
    </div>
}

@* MODAL DE SUCESSO *@
@if (MostrarModalSucesso)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.7); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 text-center p-4">
                <div class="modal-body">
                    <div class="text-success mb-3">
                        <i class="fas fa-check-circle fa-5x animate-bounce"></i>
                    </div>
                    <h3 class="fw-bold">Enviado com Sucesso!</h3>
                    <p class="text-muted">O teu trabalho foi entregue ao professor e registado no sistema.</p>
                    <div class="spinner-border spinner-border-sm text-muted mt-2"></div>
                    <small class="d-block mt-1 text-muted">A redirecionar para o dashboard...</small>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Trabalho? Trabalho;
    private List<AlunoVertenteModel> Vertentes = new();
    private string StatusMessage = "";
    private bool IsSaving = false;
    private bool MostrarModalFeedback = false;
    private bool MostrarModalSucesso = false;
    private List<FeedbackModel> FeedbacksGerados = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Trabalho = await TrabalhoService.GetTrabalhoPorIdAsync(Id);
            if (Trabalho != null)
            {
                var vertentesDb = await TrabalhoService.GetVertentesDoTrabalhoAsync(Trabalho.Id);
                if (vertentesDb == null || !vertentesDb.Any())
                {
                    Vertentes.Add(new AlunoVertenteModel
                    {
                        Id = 0,
                        Tipo = Trabalho.IsPlanoRecuperacao ? "Recuperação de Nota" : "Desenvolvimento",
                        ConteudoTextoProfessor = Trabalho.ConteudoTexto ?? Trabalho.Descricao ?? "Siga as orientações.",
                        ConteudoTextoAluno = Trabalho.ConteudoTextoAluno ?? "",
                        ArquivoNome = Trabalho.FicheiroNome,
                        Nota = Trabalho.Nota
                    });
                }
                else
                {
                    Vertentes = vertentesDb.Select(v => new AlunoVertenteModel
                    {
                        Id = v.Id,
                        Tipo = v.Tipo,
                        ConteudoTextoProfessor = v.ConteudoTexto,
                        ConteudoTextoAluno = v.ConteudoTextoAluno ?? "",
                        ArquivoNome = v.FicheiroNome,
                        Nota = v.Nota
                    }).ToList();
                }
            }
        }
        catch (Exception ex) { StatusMessage = "Erro ao carregar: " + ex.Message; }
    }

    private async Task EnviarVertentesAsync()
    {
        if (IsSaving) return;
        IsSaving = true;
        StatusMessage = "";

        try
        {
            var dataAtualUtc = DateTime.UtcNow;

            foreach (var vert in Vertentes)
            {
                if (vert.Id > 0)
                {
                    var vertDb = await TrabalhoService.GetVertentePorIdAsync(vert.Id);
                    if (vertDb != null)
                    {
                        vertDb.ConteudoTextoAluno = vert.ConteudoTextoAluno;
                        vertDb.DataEnvio = dataAtualUtc;
                        if (vert.ArquivoBytes != null)
                        {
                            vertDb.FicheiroNome = vert.ArquivoNome;
                            vertDb.FicheiroBytes = vert.ArquivoBytes;
                            vertDb.FicheiroContentType = vert.ArquivoContentType;
                        }
                        await TrabalhoService.AtualizarVertenteAsync(vertDb);
                    }
                }
                else if (Trabalho != null)
                {
                    // AQUI ESTAVA O ERRO: Precisamos garantir que as propriedades do Trabalho sejam atualizadas
                    Trabalho.ConteudoTextoAluno = vert.ConteudoTextoAluno;
                    Trabalho.DataEntrega = dataAtualUtc;
                    if (vert.ArquivoBytes != null)
                    {
                        Trabalho.FicheiroNome = vert.ArquivoNome;
                        Trabalho.FicheiroBytes = vert.ArquivoBytes;
                        Trabalho.FicheiroContentType = vert.ArquivoContentType;
                    }
                    // Chamada ao service para salvar no banco
                    await TrabalhoService.AtualizarTrabalhoAsync(Trabalho);
                }
            }

            // Notificação Push para o Professor
            if (Trabalho != null && !string.IsNullOrEmpty(Trabalho.ProfessorId))
            {
                try
                {
                    var push = await TrabalhoService.GetProfessorPushSubscriptionAsync(Trabalho.ProfessorId);
                    if (!string.IsNullOrEmpty(push))
                        await PushService.EnviarNotificacaoAsync(push, $"Nova entrega de {Trabalho.Aluno?.UserName}: {Trabalho.Titulo}");
                }
                catch { }
            }

            StatusMessage = "Trabalho submetido com sucesso!";
            MostrarModalSucesso = true;
            StateHasChanged();

            await Task.Delay(2000);
            Nav.NavigateTo("/aluno/DashboardAluno");
        }
        catch (Exception ex)
        {
            StatusMessage = "Erro no servidor: " + (ex.InnerException?.Message ?? ex.Message);
            IsSaving = false;
            MostrarModalSucesso = false;
        }
    }

    private async Task GerarFeedbackSelecionadoAsync()
    {
        if (IsSaving || Trabalho == null) return;

        StatusMessage = "";
        FeedbacksGerados.Clear();
        var selecionadas = Vertentes.Where(x => x.SolicitarFeedback).ToList();

        if (!selecionadas.Any())
        {
            StatusMessage = "Selecione 'Solicitar revisão' em pelo menos uma vertente.";
            return;
        }

        IsSaving = true;
        try
        {
            foreach (var v in selecionadas)
            {
                var feedbackIA = await TrabalhoService.GerarFeedbackIAAsync(
                    Trabalho.AlunoId,
                    v.ConteudoTextoAluno,
                    v.ArquivoBytes,
                    Trabalho.Id,
                    v.Id.ToString()
                );

                FeedbacksGerados.Add(new FeedbackModel
                {
                    Tipo = v.Tipo,
                    Texto = feedbackIA ?? "A IA não conseguiu processar o feedback no momento."
                });
            }
            MostrarModalFeedback = true;
        }
        catch (Exception ex)
        {
            StatusMessage = "Erro ao contactar IA: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task UploadArquivo(InputFileChangeEventArgs e, AlunoVertenteModel vert)
    {
        try
        {
            var file = e.File;
            if (file != null)
            {
                vert.ArquivoNome = file.Name;
                vert.ArquivoContentType = file.ContentType;
                using var ms = new MemoryStream();
                // Limite de 10MB
                await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
                vert.ArquivoBytes = ms.ToArray();
            }
        }
        catch (Exception ex) { StatusMessage = "Erro no upload: " + ex.Message; }
    }

    private void FecharModalFeedback() => MostrarModalFeedback = false;

    private async Task AceitarFeedback()
    {
        MostrarModalFeedback = false;
        await EnviarVertentesAsync();
    }

    public class AlunoVertenteModel
    {
        public int Id { get; set; }
        public string Tipo { get; set; } = "";
        public string ConteudoTextoProfessor { get; set; } = "";
        public string ConteudoTextoAluno { get; set; } = "";
        public string? ArquivoNome { get; set; }
        public byte[]? ArquivoBytes { get; set; }
        public string? ArquivoContentType { get; set; }
        public bool SolicitarFeedback { get; set; } = false;
        public decimal? Nota { get; set; }
    }

    public class FeedbackModel
    {
        public string Tipo { get; set; } = "";
        public string Texto { get; set; } = "";
    }
}