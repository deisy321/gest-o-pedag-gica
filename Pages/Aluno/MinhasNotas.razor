@page "/aluno/MinhasNotas"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject TrabalhoService TrabalhoService

<div class="container mt-4">
    <h3 class="fw-bold mb-4">O Meu Desempenho</h3>

    @* --- SECÇÃO 1: RESUMO POR MÓDULO --- *@
    <div class="row mb-4">
        @if (ResumoModulos.Any())
        {
            @foreach (var modulo in ResumoModulos)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm border-0 @(modulo.EstaBloqueado ? "border-start border-danger border-5" : "")" style="border-radius: 12px;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="text-muted small text-uppercase mb-1">@modulo.DisciplinaNome</h6>
                                    <h5 class="fw-bold">@modulo.ModuloNome</h5>
                                </div>
                                <div class="text-end">
                                    @if (modulo.EstaBloqueado)
                                    {
                                        <div class="text-danger" title="Módulo retido por negativa em vertente específica">
                                            <i class="bi bi-lock-fill fs-5"></i>
                                            <span class="d-block fw-bold" style="font-size: 0.7rem;">BLOQUEADO</span>
                                        </div>
                                    }
                                    else if (modulo.Concluido)
                                    {
                                        <span class="badge bg-success fs-6 shadow-sm">Nota Final: @modulo.Media.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Em Curso</span>
                                    }
                                </div>
                            </div>

                            @if (modulo.EstaBloqueado)
                            {
                                <div class="alert alert-danger py-1 px-2 mb-2" style="font-size: 0.8rem;">
                                    <i class="bi bi-exclamation-circle me-1"></i>
                                    Necessita recuperação em: <strong>@string.Join(", ", modulo.VertentesCriticas)</strong>
                                </div>
                            }

                            <div class="mt-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Carga Horária: @modulo.HorasAtuais / @modulo.HorasTotais h</span>
                                    <span>@((modulo.HorasAtuais * 100 / modulo.HorasTotais))%</span>
                                </div>
                                <div class="progress" style="height: 8px; border-radius: 4px; background-color: #e9ecef;">
                                    <div class="progress-bar @(modulo.EstaBloqueado ? "bg-warning" : (modulo.Concluido ? "bg-success" : "bg-primary"))"
                                         role="progressbar"
                                         style="width: @(Math.Min(100, modulo.HorasAtuais * 100 / modulo.HorasTotais))%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @* --- SECÇÃO 2: DETALHE DAS VERTENTES --- *@
    <div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
        <h5 class="fw-bold mb-3">Histórico de Avaliações</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Trabalho / Módulo</th>
                        <th>Vertente</th>
                        <th class="text-center">Nota</th>
                        <th>Feedback do Professor</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @if (trabalhos?.Count > 0)
                    {
                        @foreach (var trabalho in trabalhos.OrderByDescending(t => t.DataCriacao))
                        {
                            @foreach (var vert in trabalho.TrabalhoVertentes.Where(v => v.Nota.HasValue || !string.IsNullOrEmpty(v.Feedback)))
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@trabalho.Titulo</div>
                                        <small class="text-muted">@trabalho.Modulo?.Nome</small>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@vert.Tipo</span></td>
                                    <td class="text-center">
                                        <span class="fw-bold @(vert.Nota >= 9.5m ? "text-success" : "text-danger")">
                                            @(vert.Nota.HasValue? vert.Nota.Value.ToString("F1") : "-")
                                        </span>
                                    </td>
                                    <td class="small text-muted" style="max-width: 300px;">
                                        @(!string.IsNullOrEmpty(vert.Feedback) ? vert.Feedback : "Sem comentários")
                                    </td>
                                    <td><small>@(vert.DataEnvio?.ToShortDateString() ?? "-")</small></td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center p-4 text-muted">Ainda não tens avaliações registadas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Trabalho> trabalhos = new();
    private List<ModuloResumo> ResumoModulos = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(userId);
            ProcessarResumoPorModulo();
        }
    }

    private void ProcessarResumoPorModulo()
    {
        ResumoModulos = trabalhos
            .GroupBy(t => new
            {
                t.ModuloId,
                Nome = t.Modulo?.Nome ?? "Geral",
                Disciplina = t.Disciplina?.Nome ?? "N/A",
                HorasMembro = t.Modulo?.TotalHoras ?? 25
            })
            .Select(g =>
            {
                // Todas as vertentes avaliadas deste módulo
                var todasAsVertentes = g.SelectMany(t => t.TrabalhoVertentes)
                                        .Where(v => v.Nota.HasValue)
                                        .ToList();

                // Lógica de Bloqueio: Agrupar por TIPO de vertente e ver se a média de algum tipo é < 9.5
                var mediasPorTipo = todasAsVertentes
                    .GroupBy(v => v.Tipo)
                    .Select(vType => new
                    {
                        Tipo = vType.Key,
                        MediaTipo = vType.Average(x => (double)x.Nota!.Value)
                    })
                    .ToList();

                var criticas = mediasPorTipo.Where(x => x.MediaTipo < 9.5).Select(x => x.Tipo).ToList();

                return new ModuloResumo
                {
                    ModuloNome = g.Key.Nome,
                    DisciplinaNome = g.Key.Disciplina,
                    HorasTotais = g.Key.HorasMembro,
                    HorasAtuais = g.Sum(t => t.HorasAtribuidas), // Agora usa a carga horária real do trabalho
                    Media = todasAsVertentes.Any() ? todasAsVertentes.Average(v => (double)v.Nota!.Value) : 0,
                    VertentesCriticas = criticas
                };
            }).ToList();
    }

    public class ModuloResumo
    {
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasAtuais { get; set; }
        public double Media { get; set; }
        public List<string> VertentesCriticas { get; set; } = new();
        public bool EstaBloqueado => VertentesCriticas.Any();
        public bool Concluido => HorasAtuais >= HorasTotais && !EstaBloqueado;
    }
}