@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject PushService PushService

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Ficha do Aluno</h2>
        <button class="btn btn-outline-secondary rounded-pill" @onclick="VoltarParaDashboard">
            <i class="bi bi-arrow-left me-2"></i> Voltar ao Painel
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">A analisar dados do aluno...</p>
        </div>
    }
    else if (AlunoSelecionado == null)
    {
        <div class="alert alert-warning shadow-sm">
            <i class="bi bi-exclamation-triangle me-2"></i> Aluno não encontrado.
        </div>
    }
    else
    {
        @* Cabeçalho e Stats Rapidas *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 p-3 d-flex align-items-center justify-content-center h-100" style="border-radius: 15px; cursor:pointer;" @onclick="ToggleDetalhes">
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center mb-2 shadow-sm" style="width:60px; height:60px; border-radius:50%; font-size:24px; font-weight: bold;">
                        @(AlunoSelecionado.Nome?[0].ToString().ToUpper() ?? "?")
                    </div>
                    <div class="fw-bold text-center">@AlunoSelecionado.Nome</div>
                    @if (MostrarDetalhes)
                    {
                        <div class="mt-3 border-top pt-2 text-start w-100">
                            <small class="d-block text-truncate"><strong>Email:</strong> @AlunoSelecionado.Email</small>
                            <small class="d-block"><strong>Turma:</strong> @(AlunoSelecionado.Turma?.Nome ?? "N/A")</small>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-9">
                <div class="row g-3 h-100">
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0 p-3 h-100 border-bottom border-success border-4" style="border-radius: 15px; background:#f8fff9;">
                            <h6 class="text-muted small text-uppercase">Média Geral Atual</h6>
                            <h4 class="fw-bold mb-0">@CalcularMediaGeral().ToString("F1")</h4>
                        </div>
                    </div>
                    @* ... Outros stats podem ser mantidos aqui ... *@
                </div>
            </div>
        </div>

        @* SECÇÃO NOIVA: NOTAS FINAIS POR MÓDULO (CONDIÇÃO DE CARGA HORÁRIA) *@
        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px;">
            <h5 class="fw-bold mb-3 text-muted small text-uppercase">Notas Finais por Módulo</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Módulo</th>
                            <th>Disciplina</th>
                            <th>Carga Horária</th>
                            <th class="text-center">Nota Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in PanoramaModulos)
                        {
                            <tr>
                                <td><strong>@m.ModuloNome</strong></td>
                                <td><span class="badge bg-light text-dark">@m.DisciplinaNome</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="me-2 small">@m.HorasConsumidas/@m.HorasTotais h</span>
                                        <div class="progress flex-grow-1" style="height: 6px;">
                                            <div class="progress-bar @(m.ModuloConcluido ? "bg-success" : "bg-primary")"
                                                 style="width: @(Math.Min(100, m.HorasConsumidas * 100 / m.HorasTotais))%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (m.ModuloConcluido)
                                    {
                                        <span class="badge @(m.Media >= 9.5 ? "bg-success" : "bg-danger") fs-6">
                                            @m.Media.ToString("F1")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border">Em Curso</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ANÁLISE DE RECUPERAÇÃO (VERTENTES CRÍTICAS - CONTINUA A FUNCIONAR) *@
        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px; border-left: 5px solid #dc3545;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-danger m-0"><i class="bi bi-exclamation-octagon me-2"></i> Vertentes Críticas (Alertas)</h5>
                @if (VertentesAbaixoDaMedia.Any())
                {
                    <span class="badge bg-danger pulse-animation">Ação Recomendada</span>
                }
            </div>

            @if (VertentesAbaixoDaMedia.Any())
            {
                <p class="text-muted small">Alertas preventivos baseados em vertentes com média atual insuficiente:</p>
                <div class="row g-2">
                    @foreach (var v in VertentesAbaixoDaMedia)
                    {
                        <div class="col-md-6">
                            <div class="card border d-flex flex-row justify-content-between align-items-center p-3 shadow-sm">
                                <div>
                                    <span class="badge bg-secondary me-1">@v.DisciplinaNome</span>
                                    <strong class="text-uppercase small">@v.Tipo</strong>
                                    <div class="text-danger fw-bold">Média: @v.Media.ToString("F1")</div>
                                </div>
                                <button class="btn btn-danger btn-sm rounded-pill" @onclick="() => IniciarPlano(v)">Criar Plano</button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted small"><i class="bi bi-check-circle-fill text-success"></i> Sem vertentes críticas detetadas.</div>
            }
        </div>

        @* ... Modais de Plano de Recuperação e Barra de Progresso Geral ... *@
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoSelecionado;
    private List<TrabalhoAlunoCustom> TrabalhosAluno = new();
    private List<ModuloAnalise> PanoramaModulos = new();
    private List<VertenteAnalise> VertentesAbaixoDaMedia = new();
    private bool IsLoading = true;
    private bool MostrarDetalhes = false;
    private VertenteAnalise? VertenteEmFoco;
    private string DescricaoNovoPlano = "";
    private bool IsSaving = false;

    protected override async Task OnInitializedAsync() => await CarregarFichaCompleta();

    private async Task CarregarFichaCompleta()
    {
        IsLoading = true;
        try
        {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado != null)
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                if (trabalhos != null)
                {
                    TrabalhosAluno = trabalhos.Select(t => new TrabalhoAlunoCustom
                    {
                        TrabalhoId = t.Id,
                        DisciplinaId = t.DisciplinaId,
                        DisciplinaNome = t.Disciplina?.Nome ?? "N/A",
                        ModuloId = t.ModuloId, // Assume que adicionaste ModuloId ao Trabalho
                        ModuloNome = t.Modulo?.Nome ?? "Módulo Geral",
                        ModuloHorasTotais = t.Modulo?.TotalHoras ?? 25,
                        IsPlanoRecuperacao = t.IsPlanoRecuperacao,
                        Vertentes = t.TrabalhoVertentes?.Select(v => new VertenteStatusCustom
                        {
                            Tipo = v.Tipo ?? "Geral",
                            Enviado = v.Nota.HasValue || v.FicheiroBytes != null,
                            Nota = v.Nota
                        }).ToList() ?? new()
                    }).ToList();

                    ProcessarDados();
                }
            }
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void ProcessarDados()
    {
        // 1. ANÁLISE POR MÓDULO (Para Notas Finais)
        PanoramaModulos = TrabalhosAluno
            .GroupBy(t => new { t.ModuloId, t.ModuloNome, t.DisciplinaNome, t.ModuloHorasTotais })
            .Select(g =>
            {
                var notas = g.SelectMany(t => t.Vertentes).Where(v => v.Nota.HasValue).Select(v => (double)v.Nota!).ToList();
                return new ModuloAnalise
                {
                    ModuloNome = g.Key.ModuloNome,
                    DisciplinaNome = g.Key.DisciplinaNome,
                    HorasTotais = g.Key.ModuloHorasTotais,
                    HorasConsumidas = g.Count() * 5, // Lógica: Cada trabalho vale 5h (ajustar conforme regra)
                    Media = notas.Any() ? notas.Average() : 0
                };
            }).ToList();

        // 2. VERTENTES CRÍTICAS (Para Alertas preventivos) - Mantém a lógica original
        VertentesAbaixoDaMedia = TrabalhosAluno
            .SelectMany(t => t.Vertentes.Select(v => new { v, t.DisciplinaNome, t.DisciplinaId, t.IsPlanoRecuperacao }))
            .GroupBy(x => new { x.v.Tipo, x.DisciplinaNome })
            .Select(g =>
            {
                var notas = g.Where(x => x.v.Nota.HasValue).Select(x => (double)x.v.Nota!).ToList();
                return new VertenteAnalise
                {
                    Tipo = g.Key.Tipo,
                    DisciplinaNome = g.Key.DisciplinaNome,
                    Media = notas.Any() ? notas.Average() : 0,
                    TemNotas = notas.Any()
                };
            })
            .Where(v => v.TemNotas && v.Media < 9.5) // Alerta preventivo
            .ToList();
    }

    private double CalcularMediaGeral() => TrabalhosAluno.SelectMany(t => t.Vertentes).Where(v => v.Nota.HasValue).Average(v => (double?)v.Nota) ?? 0;
    private void ToggleDetalhes() => MostrarDetalhes = !MostrarDetalhes;
    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");
    private void IniciarPlano(VertenteAnalise v) { VertenteEmFoco = v; DescricaoNovoPlano = ""; }

    // Classes de Apoio
    public class ModuloAnalise
    {
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public double Media { get; set; }
        public bool ModuloConcluido => HorasConsumidas >= HorasTotais;
    }

    public class TrabalhoAlunoCustom
    {
        public int TrabalhoId { get; set; }
        public int? ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public int ModuloHorasTotais { get; set; }
        public string DisciplinaNome { get; set; } = "";
        public int? DisciplinaId { get; set; }
        public bool IsPlanoRecuperacao { get; set; }
        public List<VertenteStatusCustom> Vertentes { get; set; } = new();
    }

    public class VertenteStatusCustom
    {
        public string Tipo { get; set; } = "";
        public bool Enviado { get; set; }
        public decimal? Nota { get; set; }
    }

    public class VertenteAnalise
    {
        public string Tipo { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int DisciplinaId { get; set; }
        public double Media { get; set; }
        public bool TemNotas { get; set; }
    }
}