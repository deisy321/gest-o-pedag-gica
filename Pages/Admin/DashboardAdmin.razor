@page "/admin/DashboardAdmin"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using Microsoft.AspNetCore.Components.Authorization
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AdminService AdminService
@inject DisciplinaService DisciplinaService
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView Roles="Administrador">
    <Authorized>
        <div class="container-fluid bg-light p-4">

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @((MarkupString)successMessage)
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-4">
               
                <div class="search-bar w-25">
                    <input type="text" class="form-control rounded-pill shadow-sm" placeholder="Pesquisar...">
                </div>
            </div>

            <!-- 5 CARDS DE RESUMO NO TOPO -->
            <div class="row g-3 mb-4">
                <div class="col-md-4 col-lg-2">
                    <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #f6c23e; border-radius: 15px;">
                        <h6>Alunos</h6>
                        <h2>@TotalAlunos</h2>
                    </div>
                </div>

                <div class="col-md-4 col-lg-2">
                    <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #4e73df; border-radius: 15px;">
                        <h6>Professores</h6>
                        <h2>@TotalProfessores</h2>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm p-3 bg-white border-start border-warning border-4 h-100" style="border-radius: 15px;">
                        <h6 class="text-muted small">Gestão de Turmas</h6>
                        <p class="small text-muted mb-2">Criar turmas e alunos</p>
                        <a href="/admin/GerirTurmas" class="btn btn-outline-warning btn-sm rounded-pill w-100">Ir para Turmas</a>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow-sm p-3 bg-white border-start border-indigo border-4 h-100" style="border-radius: 15px; border-left-color: #6610f2 !important;">
                        <h6 class="text-muted small">Gestão de Disciplinas</h6>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="badge bg-light text-dark shadow-sm">@TotalDisciplinas</span>
                            <a href="/admin/GerirDisciplinas" class="btn btn-outline-dark btn-sm rounded-pill" style="border-color: #6610f2; color: #6610f2;">Ver Todas</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-2">
                    <div class="card border-0 shadow-sm p-3 bg-white border-start border-primary border-4 h-100" style="border-radius: 15px;">
                        <h6 class="text-muted small">Atribuição</h6>
                        <a href="/admin/AtribuirTurma" class="btn btn-outline-primary btn-sm rounded-pill mt-2">Configurar</a>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- TABELA CENTRAL -->
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                        <h5 class="fw-bold mb-3">Professores e Módulos Ativos</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Professor</th>
                                        <th>Turma</th>
                                        <th>Disciplina</th>
                                        <th class="text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ListaAtribuicoes != null && ListaAtribuicoes.Any())
                                    {
                                        @foreach (var item in ListaAtribuicoes)
                                        {
                                            <tr>
                                                <td>@item.ProfessorNome</td>
                                                <td>@item.TurmaNome</td>
                                                <td>@item.ModuloNome</td>
                                                <td class="text-center">
                                                    <a href="/admin/GerirTurmas" class="btn btn-sm btn-light border">Editar</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="4" class="text-center text-muted p-4">Nenhuma atribuição encontrada.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- AÇÕES RÁPIDAS (APENAS AS PEDIDAS) -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                        <h5 class="fw-bold mb-4">Ações Rápidas</h5>
                        <div class="d-grid gap-3">

                            <a href="/admin/CriarDisciplina" class="btn p-3 text-start shadow-sm d-flex align-items-center text-white" style="border-radius: 12px; background-color: #6610f2;">
                                <i class="bi bi-journal-plus me-3 fs-4"></i>
                                <div class="fw-bold">Criar Disciplina</div>
                            </a>

                            <a href="/admin/GerirModulos" class="btn btn-success p-3 text-start shadow-sm d-flex align-items-center" style="border-radius: 12px;">
                                <i class="bi bi-journal-text me-3 fs-4"></i>
                                <div class="fw-bold">Gerir Módulos</div>
                            </a>

                            <a href="/admin/CriarModulo" class="btn btn-success p-3 text-start shadow-sm d-flex align-items-center" style="border-radius: 12px; opacity: 0.9;">
                                <i class="bi bi-plus-circle me-3 fs-4"></i>
                                <div class="fw-bold">Criar Módulo</div>
                            </a>

                            <a href="/admin/RegisterAdmin" class="btn btn-primary p-3 text-start shadow-sm d-flex align-items-center" style="border-radius: 12px;">
                                <i class="bi bi-person-plus me-3 fs-4"></i>
                                <div class="fw-bold">Registar Utilizador</div>
                            </a>

                            <a href="/admin/GerirUtilizadores" class="btn btn-primary p-3 text-start shadow-sm d-flex align-items-center" style="border-radius: 12px; opacity: 0.85;">
                                <i class="bi bi-people me-3 fs-4"></i>
                                <div class="fw-bold">Gerir Utilizadores</div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private string successMessage = "";
    private int TotalAlunos;
    private int TotalProfessores;
    private int TotalDisciplinas;
    private List<ResumoAtribuicao> ListaAtribuicoes = new(); // <-- aqui


    protected override async Task OnInitializedAsync()
    {
        TotalAlunos = await AdminService.GetTotalAlunosAsync();
        TotalProfessores = await AdminService.GetTotalProfessoresAsync();

        var listaD = await DisciplinaService.GetDisciplinasAsync();
        TotalDisciplinas = listaD?.Count ?? 0;

        ListaAtribuicoes = await AdminService.GetAtribuicoesAtivasAsync();
    }
}
