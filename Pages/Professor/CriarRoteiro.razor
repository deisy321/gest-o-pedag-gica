@page "/professor/CriarRoteiro/{TurmaIdStr}"
@namespace gestaopedagogica.Pages.Professor
@layout MainLayout

@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject TrabalhoService TrabalhoService
@inject TurmaService TurmaService
@inject ModuloService ModuloService
@inject DisciplinaService DisciplinaService
@inject ProfessorService ProfessorService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="page-teacher animate-fade-in">
    @if (IsLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">A preparar o ambiente...</p>
        </div>
    }
    else if (TurmaSelecionada == null)
    {
        <div class="alert-custom alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <span>Turma não encontrada!</span>
        </div>
    }
    else
    {
        <div class="admin-header-row">
            <div>
                <h1 class="page-title">Novo Trabalho</h1>
                <p class="page-subtitle">Turma: <span class="text-gradient">@TurmaSelecionada.Nome</span></p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn-custom btn-custom-outline" @onclick='() => Nav.NavigateTo("/professor/DashboardProfessor")'>
                    <i class="fas fa-arrow-left"></i> Voltar
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="custom-card mb-4 elevation-2 border-start-primary">
                    <div class="card-header-custom">
                        <h5><i class="fas fa-pen-nib me-2"></i>Informações Gerais</h5>
                    </div>
                    <div class="card-body-custom">
                        <div class="form-group">
                            <label class="form-label">Título do Trabalho</label>
                            <input class="form-control @(string.IsNullOrEmpty(ErroTitulo) ? "" : "is-invalid")"
                                   @bind="Titulo" placeholder="Ex: Relatório de Atividades Práticas" />
                            <small class="text-danger">@ErroTitulo</small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Descrição / Instruções</label>
                            <textarea class="form-control @(string.IsNullOrEmpty(ErroDescricao) ? "" : "is-invalid")"
                                      @bind="Descricao" rows="4" placeholder="Descreva os objetivos e o que é esperado do aluno..."></textarea>
                            <small class="text-danger">@ErroDescricao</small>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6 form-group">
                                <label class="form-label">Disciplina</label>
                                <select class="form-select @(string.IsNullOrEmpty(ErroDisciplina) ? "" : "is-invalid")" @onchange="OnDisciplinaChanged">
                                    <option value="0">-- Selecione a Disciplina --</option>
                                    @foreach (var disc in ListaDisciplinas)
                                    {
                                        <option value="@disc.Id">@disc.Nome</option>
                                    }
                                </select>
                                <small class="text-danger">@ErroDisciplina</small>
                            </div>

                            <div class="col-md-6 form-group">
                                <label class="form-label">Módulo</label>
                                <select class="form-select @(string.IsNullOrEmpty(ErroModulo) ? "" : "is-invalid")" @bind="ModuloSelecionadoId" disabled="@(DisciplinaSelecionadaId == 0)">
                                    <option value="0">-- Selecione o Módulo --</option>
                                    @foreach (var mod in ModulosFiltrados)
                                    {
                                        <option value="@mod.Id">@mod.Nome (@mod.TotalHoras h)</option>
                                    }
                                </select>
                                <small class="text-danger">@ErroModulo</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="custom-card mb-4 elevation-2">
                    <div class="card-header-custom">
                        <h5><i class="fas fa-list-check me-2"></i>Vertentes e Critérios</h5>
                    </div>
                    <div class="card-body-custom">
                        <div class="row">
                            @foreach (var vert in Vertentes)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="p-3 border rounded-lg bg-light">
                                        <label class="form-label d-block text-center border-bottom pb-2">@vert.Tipo</label>
                                        <textarea class="form-control mt-2" @bind="vert.ConteudoTexto"
                                                  rows="2" placeholder="Notas sobre @vert.Tipo.ToLower()..."></textarea>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="custom-card elevation-2 mb-4">
                    <div class="card-header-custom">
                        <h5><i class="fas fa-cog me-2"></i>Configurações</h5>
                    </div>
                    <div class="card-body-custom">
                        <div class="form-group">
                            <label class="form-label">Carga Horária (h)</label>
                            <input type="number" class="form-control @(string.IsNullOrEmpty(ErroHoras) ? "" : "is-invalid")"
                                   @bind="HorasAtribuidas" min="1" />
                            <small class="text-muted">Quanto tempo este trabalho ocupa no módulo.</small>
                            <br /><small class="text-danger">@ErroHoras</small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Prazo de Entrega</label>
                            <input type="date" class="form-control" @bind="PrazoEntrega" />
                            <small class="text-danger">@ErroPrazo</small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Destinatário</label>
                            <select class="form-select" @bind="TipoAtribuicao">
                                <option value="turma">Toda a Turma (@(TurmaSelecionada?.Alunos?.Count ?? 0) alunos)</option>
                                <option value="aluno">Aluno Específico</option>
                            </select>
                        </div>

                        @if (TipoAtribuicao == "aluno")
                        {
                            <div class="form-group animate-slide-up">
                                <label class="form-label">Selecionar Aluno</label>
                                <select class="form-select @(string.IsNullOrEmpty(ErroAluno) ? "" : "is-invalid")" @bind="AlunoSelecionadoId">
                                    <option value="0">-- Escolha o aluno --</option>
                                    @foreach (var aluno in TurmaSelecionada!.Alunos.Where(a => !string.IsNullOrEmpty(a.UserId)))
                                    {
                                        <option value="@aluno.Id">@aluno.Nome</option>
                                    }
                                </select>
                                <small class="text-danger">@ErroAluno</small>
                            </div>
                        }

                        <hr />

                        <button type="button" class="btn-custom btn-custom-success w-100 justify-content-center py-3 mt-2"
                                @onclick="SalvarRoteiro" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>A gravar...</span>
                            }
                            else
                            {
                                <i class="fas fa-save me-2"></i>
                                <span>Criar Trabalho</span>
                            }
                        </button>

                        @if (!string.IsNullOrEmpty(StatusMessage))
                        {
                            <div class="alert-custom @(StatusMessage.Contains("✅") ? "alert-success" : "alert-danger") mt-3 animate-fade-in">
                                <span>@StatusMessage</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? TurmaIdStr { get; set; }

    private int TurmaId = 0;
    private Turma? TurmaSelecionada;
    private List<Disciplina> ListaDisciplinas = new();
    private List<Modulo> ModulosFiltrados = new();

    private string Titulo = "";
    private string Descricao = "";
    private int ModuloSelecionadoId = 0;
    private int DisciplinaSelecionadaId = 0;
    private int AlunoSelecionadoId = 0;
    private int HorasAtribuidas = 1;
    private string TipoAtribuicao = "turma";
    private DateTime? PrazoEntrega = DateTime.Today.AddDays(7);
    private string StatusMessage = "";
    private bool IsSaving = false;
    private bool IsLoading = true;
    private string? ProfessorUserId;

    private string ErroTitulo = "";
    private string ErroDescricao = "";
    private string ErroModulo = "";
    private string ErroDisciplina = "";
    private string ErroAluno = "";
    private string ErroPrazo = "";
    private string ErroHoras = "";

    private List<VertenteEditModel> Vertentes = new()
    {
        new VertenteEditModel { Tipo = "Competência" },
        new VertenteEditModel { Tipo = "Aptidão" },
        new VertenteEditModel { Tipo = "Conhecimento" }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            ProfessorUserId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(ProfessorUserId) || !int.TryParse(TurmaIdStr, out TurmaId))
            {
                StatusMessage = "❌ Acesso inválido.";
                return;
            }

            await CarregarDados();
        }
        catch (Exception ex)
        {
            StatusMessage = $"❌ Erro ao carregar: {ex.Message}";
        }
        finally { IsLoading = false; }
    }

    private async Task CarregarDados()
    {
        TurmaSelecionada = await TurmaService.GetTurmaByIdAsync(TurmaId);

        // BUSCA APENAS AS DISCIPLINAS QUE ESTE PROFESSOR LECIONA NESTA TURMA ESPECÍFICA
        ListaDisciplinas = await DisciplinaService.GetDisciplinasPorProfessorETurmaAsync(ProfessorUserId!, TurmaId);
    }

    private void OnDisciplinaChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            DisciplinaSelecionadaId = id;
            ModuloSelecionadoId = 0;

            if (id > 0)
            {
                var disc = ListaDisciplinas.FirstOrDefault(d => d.Id == id);
                ModulosFiltrados = disc?.Modulos?.OrderBy(m => m.Nome).ToList() ?? new();
            }
            else
            {
                ModulosFiltrados = new();
            }
        }
    }

    private bool ValidarFormulario()
    {
        ErroTitulo = string.IsNullOrWhiteSpace(Titulo) ? "O título é obrigatório" : "";
        ErroDescricao = string.IsNullOrWhiteSpace(Descricao) ? "A descrição é exigida" : "";
        ErroModulo = (ModuloSelecionadoId <= 0) ? "Selecione um módulo" : "";
        ErroDisciplina = (DisciplinaSelecionadaId <= 0) ? "Selecione uma disciplina" : "";
        ErroPrazo = !PrazoEntrega.HasValue ? "Escolha um prazo" : "";
        ErroAluno = (TipoAtribuicao == "aluno" && AlunoSelecionadoId <= 0) ? "Selecione um aluno" : "";
        ErroHoras = (HorasAtribuidas <= 0) ? "A carga horária deve ser superior a 0" : "";

        return string.IsNullOrEmpty(ErroTitulo) &&
               string.IsNullOrEmpty(ErroDescricao) &&
               string.IsNullOrEmpty(ErroModulo) &&
               string.IsNullOrEmpty(ErroDisciplina) &&
               string.IsNullOrEmpty(ErroPrazo) &&
               string.IsNullOrEmpty(ErroHoras) &&
               string.IsNullOrEmpty(ErroAluno);
    }

    private async Task SalvarRoteiro()
    {
        if (IsSaving) return;
        IsSaving = true;
        StatusMessage = "A validar...";
        StateHasChanged();

        try
        {
            if (!ValidarFormulario())
            {
                StatusMessage = "❌ Corrija os erros antes de salvar.";
                IsSaving = false;
                return;
            }

            var modulo = ModulosFiltrados.FirstOrDefault(m => m.Id == ModuloSelecionadoId);
            if (modulo != null)
            {
                var alunosParaAtribuir = TipoAtribuicao == "aluno"
                    ? TurmaSelecionada!.Alunos.Where(a => a.Id == AlunoSelecionadoId && !string.IsNullOrEmpty(a.UserId)).ToList()
                    : TurmaSelecionada!.Alunos.Where(a => !string.IsNullOrEmpty(a.UserId)).ToList();

                var alunoRef = alunosParaAtribuir.FirstOrDefault();
                if (alunoRef != null)
                {
                    int horasConsumidas = await TrabalhoService.GetHorasConsumidasNoModuloAsync(
                        ModuloSelecionadoId,
                        TurmaSelecionada!.Id,
                        alunoRef.UserId!);

                    if (horasConsumidas + HorasAtribuidas > modulo.TotalHoras)
                    {
                        StatusMessage = $"❌ Limite excedido! O módulo tem {modulo.TotalHoras}h. Já usou {horasConsumidas}h. Restam {modulo.TotalHoras - horasConsumidas}h.";
                        IsSaving = false;
                        return;
                    }
                }
            }

            var professor = await ProfessorService.GetProfessorByUserIdAsync(ProfessorUserId!);
            var alunosGravar = TipoAtribuicao == "aluno"
                ? TurmaSelecionada!.Alunos.Where(a => a.Id == AlunoSelecionadoId && !string.IsNullOrEmpty(a.UserId)).ToList()
                : TurmaSelecionada!.Alunos.Where(a => !string.IsNullOrEmpty(a.UserId)).ToList();

            int sucessos = 0;
            foreach (var aluno in alunosGravar)
            {
                await CriarTrabalhoCompleto(professor!.UserId, aluno.UserId!);
                sucessos++;
            }

            if (sucessos > 0)
            {
                StatusMessage = $"✅ {sucessos} trabalho(s) criado(s)!";
                await Task.Delay(1500);
                Nav.NavigateTo("/professor/DashboardProfessor");
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"❌ Erro: {ex.Message}";
        }
        finally { IsSaving = false; }
    }

    private async Task CriarTrabalhoCompleto(string professorId, string alunoId)
    {
        var trabalho = new Trabalho
        {
            Titulo = Titulo.Trim(),
            Descricao = Descricao.Trim(),
            ProfessorId = professorId,
            AlunoId = alunoId,
            TurmaId = TurmaSelecionada!.Id,
            ModuloId = ModuloSelecionadoId,
            DisciplinaId = DisciplinaSelecionadaId,
            HorasAtribuidas = HorasAtribuidas,
            DataCriacao = DateTime.UtcNow,
            PrazoEntrega = PrazoEntrega ?? DateTime.UtcNow.AddDays(7)
        };

        int trabalhoId = await TrabalhoService.AddTrabalhoAsync(trabalho);

        foreach (var vertente in Vertentes)
        {
            await TrabalhoService.AddVertenteAsync(new TrabalhoVertente
            {
                TrabalhoId = trabalhoId,
                Tipo = vertente.Tipo,
                ConteudoTexto = vertente.ConteudoTexto ?? ""
            });
        }
    }

    public class VertenteEditModel
    {
        public string Tipo { get; set; } = "";
        public string? ConteudoTexto { get; set; }
    }
}