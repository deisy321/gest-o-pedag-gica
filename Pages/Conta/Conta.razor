@page "/Conta"
@attribute [Authorize]

@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization

<h3>Minha Conta</h3>

<div class="card p-4" style="max-width:500px">

    <div class="mb-3">
        <button class="btn btn-primary w-100"
                @onclick='() => Nav.NavigateTo("/Conta/MudarSenha")'>
            Alterar Senha
        </button>
    </div>

</div>