@page "/admin/GerirCursos"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject CursoService CursoService
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-book me-2"></i>Gerir Cursos</h3>
        <button class="btn btn-secondary rounded-pill" @onclick='() => Nav.NavigateTo("/admin/GerirTurmas")'>
            Voltar às Turmas
        </button>
    </div>

    @* Formulário Simples para Adicionar Curso *@
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light">
            <h5 class="card-title">Novo Curso</h5>
            <div class="d-flex gap-2">
                <input class="form-control" placeholder="Nome do Curso (ex: Informática)" @bind="NovoCurso.Nome" />
                <button class="btn btn-success px-4" @onclick="SalvarCurso">Adicionar</button>
            </div>
        </div>
    </div>

    @* Tabela de Cursos Existentes *@
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>Nome do Curso</th>
                        <th class="text-center" style="width: 150px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Cursos != null && Cursos.Any())
                    {
                        @foreach (var c in Cursos)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@c.Nome</td>
                                <td class="text-center">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => Eliminar(c)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="2" class="text-center p-4 text-muted">Nenhum curso registado.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    List<Curso> Cursos = new();
    Curso NovoCurso = new();

    protected override async Task OnInitializedAsync() => await CarregarCursos();

    async Task CarregarCursos()
    {
        Cursos = await CursoService.GetCursosAsync() ?? new();
        StateHasChanged();
    }

    async Task SalvarCurso()
    {
        if (string.IsNullOrWhiteSpace(NovoCurso.Nome)) return;
        await CursoService.AddCursoAsync(NovoCurso);
        NovoCurso = new Curso(); // Limpa o campo
        await CarregarCursos();
    }

    async Task Eliminar(Curso c)
    {
        await CursoService.RemoveCursoAsync(c);
        await CarregarCursos();
    }
}
