@page "/aluno/EnviarTrabalho/{Id:int}"
@namespace gestaopedagogica.Pages.Aluno
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Forms

@inject TrabalhoService TrabalhoService
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-primary text-white p-3" style="border-radius: 15px 15px 0 0;">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-file-earmark me-2"></i>
                    @(Trabalho?.Titulo ?? "Carregando...")
                </h4>

                <button class="btn btn-light btn-sm rounded-pill"
                        @onclick='() => Nav.NavigateTo("/aluno/DashboardAluno")'>
                    <i class="bi bi-arrow-left me-1"></i>Voltar
                </button>
            </div>
        </div>

        <div class="card-body p-4">

            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="alert alert-danger">
                    @StatusMessage
                </div>
            }

            @if (Trabalho == null)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Carregando trabalho...</p>
                </div>
            }
            else
            {

                <EditForm Model="Vertentes">

                    @foreach (var vert in Vertentes ?? new())
                    {
                        <div class="card mb-4 shadow-sm">

                            <div class="card-header bg-light">
                                <h5 class="mb-0">@vert.Tipo</h5>
                            </div>

                            <div class="card-body">

                                <label class="form-label fw-bold">Sua Resposta:</label>

                                <textarea class="form-control"
                                          rows="5"
                                          @bind="vert.ConteudoTextoAluno">
                                                </textarea>

                                <div class="mt-3">
                                    <label class="form-label fw-bold">Enviar Ficheiro:</label>

                                    <InputFile OnChange="async e => await UploadArquivo(e, vert)"
                                               class="form-control" />

                                    @if (!string.IsNullOrEmpty(vert.ArquivoNome))
                                    {
                                        <div class="alert alert-success mt-2">
                                            <strong>Ficheiro:</strong> @vert.ArquivoNome
                                        </div>
                                    }
                                </div>

                                <div class="form-check mt-3">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="feedbackCheckbox_@vert.Id"
                                           @bind="vert.SolicitarFeedback" />
                                    <label class="form-check-label" for="feedbackCheckbox_@vert.Id">
                                        Quero receber feedback automático antes de enviar
                                    </label>
                                </div>

                            </div>
                        </div>
                    }

                </EditForm>

                <div class="d-flex gap-2 justify-content-end mt-4">

                    <button class="btn btn-outline-secondary"
                            @onclick='() => Nav.NavigateTo("/aluno/DashboardAluno")'>
                        Cancelar
                    </button>

                    <!-- Novo botão para gerar feedback antes de enviar -->
                    <button class="btn btn-warning"
                            @onclick="GerarFeedbackSelecionadoAsync"
                            disabled="@IsSaving">
                        @(IsSaving ? "Gerando..." : "Gerar Feedback")
                    </button>

                    <button class="btn btn-primary"
                            @onclick="EnviarVertentesAsync"
                            disabled="@IsSaving">
                        Enviar Trabalho
                    </button>

                </div>

            }

        </div>
    </div>
</div>

<!-- Modal de Feedback -->
@if (MostrarModalFeedback)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Feedback Automático</h5>
                    <button type="button" class="btn-close" @onclick="FecharModalFeedback"></button>
                </div>
                <div class="modal-body">
                    @foreach (var fb in FeedbacksGerados)
                    {
                        <div class="mb-3">
                            <h6>@fb.Tipo</h6>
                            <div class="alert alert-info">@fb.Texto</div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FecharModalFeedback">Ignorar Feedback</button>
                    <button class="btn btn-primary" @onclick="AceitarFeedback">Aceitar Feedback e Enviar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private Trabalho? Trabalho;
    private List<AlunoVertenteModel>? Vertentes;

    private string StatusMessage = "";
    private bool IsSaving = false;

    // Modal feedback
    private bool MostrarModalFeedback = false;
    private List<FeedbackModel> FeedbacksGerados = new();

    protected override async Task OnInitializedAsync()
    {
        Trabalho = await TrabalhoService.GetTrabalhoPorIdAsync(Id);

        if (Trabalho != null)
        {
            var vertentesDb =
                await TrabalhoService.GetVertentesDoTrabalhoAsync(Trabalho.Id);

            Vertentes = vertentesDb.Select(v => new AlunoVertenteModel
            {
                Id = v.Id,
                Tipo = v.Tipo,
                ConteudoTextoProfessor = v.ConteudoTexto,
                ConteudoTextoAluno = v.ConteudoTextoAluno ?? "",
                ArquivoNome = v.FicheiroNome,
                ArquivoBytes = v.FicheiroBytes,
                ArquivoContentType = v.FicheiroContentType,
                Feedback = v.Feedback,
                Nota = v.Nota,
                SolicitarFeedback = false
            }).ToList();
        }
    }

    private async Task GerarFeedbackSelecionadoAsync()
    {
        if (Vertentes == null) return;

        IsSaving = true;
        FeedbacksGerados.Clear();

        try
        {
            foreach (var vert in Vertentes.Where(v => v.SolicitarFeedback))
            {
                var texto = vert.ConteudoTextoAluno;

                var feedback = await TrabalhoService.GerarFeedbackIAAsync(
                    texto,
                    vert.ArquivoBytes,
                    Trabalho!.Id
                );

                FeedbacksGerados.Add(new FeedbackModel
                {
                    Tipo = vert.Tipo,
                    Texto = feedback
                });
            }

            if (FeedbacksGerados.Any())
            {
                MostrarModalFeedback = true;
            }
            else
            {
                StatusMessage = "Nenhuma vertente selecionada para feedback.";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }
    private async Task EnviarVertentesAsync()
    {
        if (Vertentes == null) return;

        IsSaving = true;
        StatusMessage = "";

        try
        {
            foreach (var vert in Vertentes)
            {
                var vertDb = await TrabalhoService.GetVertentePorIdAsync(vert.Id);
                if (vertDb == null) continue;

                vertDb.ConteudoTextoAluno = vert.ConteudoTextoAluno;

                if (vert.ArquivoBytes != null)
                {
                    vertDb.FicheiroBytes = vert.ArquivoBytes;
                    vertDb.FicheiroNome = vert.ArquivoNome;
                    vertDb.FicheiroContentType = vert.ArquivoContentType;
                }

                // REMOVIDO: não salvar feedback da IA no banco
                // if (vert.AceitouFeedback && !string.IsNullOrWhiteSpace(vert.Feedback))
                //     vertDb.Feedback += "\n[Feedback Automático]: " + vert.Feedback;

                await TrabalhoService.AtualizarVertenteAsync(vertDb);
            }

            Nav.NavigateTo("/aluno/DashboardAluno");
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void FecharModalFeedback()
    {
        MostrarModalFeedback = false;
    }

    private async Task AceitarFeedback()
    {
        foreach (var vert in Vertentes!)
        {
            if (vert.SolicitarFeedback)
                vert.AceitouFeedback = true;
        }

        MostrarModalFeedback = false;
        await EnviarVertentesAsync();
    }

    private async Task UploadArquivo(InputFileChangeEventArgs e, AlunoVertenteModel vert)
    {
        try
        {
            var file = e.File;

            vert.ArquivoNome = file.Name;
            vert.ArquivoContentType = file.ContentType;

            using var ms = new MemoryStream();
            await file.OpenReadStream(10_000_000).CopyToAsync(ms);
            vert.ArquivoBytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Erro ao enviar ficheiro: {ex.Message}";
        }
    }

    public class AlunoVertenteModel
    {
        public int Id { get; set; }
        public string Tipo { get; set; } = "";
        public string ConteudoTextoProfessor { get; set; } = "";
        public string ConteudoTextoAluno { get; set; } = "";
        public string? ArquivoNome { get; set; }
        public byte[]? ArquivoBytes { get; set; }
        public string? ArquivoContentType { get; set; }
        public string? Feedback { get; set; }
        public decimal? Nota { get; set; }

        public bool SolicitarFeedback { get; set; } = false;
        public bool AceitouFeedback { get; set; } = false;
    }

    public class FeedbackModel
    {
        public string Tipo { get; set; } = "";
        public string Texto { get; set; } = "";
    }
}