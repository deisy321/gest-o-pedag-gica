@page "/professor/DashboardProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject AlunoService AlunoService
@inject TurmaService TurmaService
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@layout MainLayout

<div class="page-teacher">
    @if (IsLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Carregando dados...</p>
        </div>
    }
    else
    {
        <div class="admin-header-row">
            <div>
                <h1 class="page-title">Dashboard de Professor</h1>
                <p class="page-subtitle">Acompanhe seus alunos, turmas e trabalhos</p>
            </div>
            <div class="d-flex gap-2" style="flex-wrap: wrap;">
                <button class="btn btn-custom btn-custom-secondary" @onclick="IrParaRelatorios">
                    <i class="bi bi-file-text"></i> Relatórios
                </button>
                <button class="btn btn-custom btn-custom-outline" @onclick='() => Nav.NavigateTo("/professor/GerirTrabalhos")'>
                    <i class="bi bi-gear"></i> Gerir Trabalhos
                </button>
                <button class="btn btn-custom btn-custom-primary" @onclick="CriarTrabalho">
                    <i class="bi bi-plus-lg"></i> Criar Trabalho
                </button>
            </div>
        </div>

        <div class="row g-3" style="margin-bottom: 2rem;">
            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-blue">
                    <i class="bi bi-people stat-card-icon"></i>
                    <div class="stat-card-content">
                        <h3>Total de Alunos</h3>
                        <p>@Alunos.Count</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-green">
                    <i class="bi bi-people-fill stat-card-icon"></i>
                    <div class="stat-card-content">
                        <h3>Total de Turmas</h3>
                        <p>@Turmas.Count</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-yellow">
                    <i class="bi bi-file-earmark stat-card-icon"></i>
                    <div class="stat-card-content">
                        <h3>Trabalhos Pendentes</h3>
                        <p>@TodosTrabalhosPendentes.Count</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="stat-card card-red">
                    <i class="bi bi-exclamation-triangle stat-card-icon"></i>
                    <div class="stat-card-content">
                        <h3>Média Baixa</h3>
                        <p>@AlunosMediaBaixa.Count</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="custom-card elevation-2">
            <div class="card-header-custom">
                <h5>Alunos das Suas Turmas</h5>
            </div>
            <div class="card-body-custom">
                <div class="row g-2 mb-4">
                    <div class="col-md-4">
                        <label class="form-label"><i class="bi bi-funnel"></i> Filtrar por Turma</label>
                        <select class="form-select" @onchange="FiltrarTurma">
                            <option value="">Todas as Turmas</option>
                            @foreach (var turma in Turmas)
                            {
                                <option value="@turma.Id">@turma.Nome</option>
                            }
                        </select>
                    </div>
                </div>

                @if (!AlunosFiltrados.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="mt-3 text-muted">Nenhum aluno encontrado</p>
                    </div>
                }
                else
                {
                    <div style="overflow-x: auto;">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th style="width: 40%;">Nome / Email</th>
                                    <th style="width: 30%;">Turma</th>
                                    <th style="width: 30%;" class="text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var aluno in AlunosFiltrados)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-circle me-2" style="width: 32px; height: 32px; font-size: 0.9rem;">
                                                    @aluno.Nome?.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <strong>@aluno.Nome</strong><br />
                                                    <small class="text-muted">@aluno.Email</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @* CORREÇÃO AQUI: Forçando cores de visibilidade para a turma *@
                                            <span class="badge bg-primary text-white" style="display: inline-block; padding: 0.35em 0.65em; color: #fff !important; background-color: #0d6efd !important;">
                                                @(aluno.Turma?.Nome ?? "Sem Turma")
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-custom btn-custom-primary" style="padding: 6px 12px;"
                                                    @onclick='() => Nav.NavigateTo("/professor/FichaAluno/" + aluno.Id)'>
                                                <i class="bi bi-eye"></i> Ver Ficha
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Aluno> Alunos = new();
    private List<Aluno> AlunosFiltrados = new();
    private List<Turma> Turmas = new();
    private bool IsLoading = true;
    private int TurmaSelecionadaId = 0;
    private List<Trabalho> TodosTrabalhosPendentes = new();
    private List<Aluno> AlunosMediaBaixa = new();

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = auth.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId)) return;

            var professor = await ProfessorService.GetProfessorByUserIdAsync(userId);
            if (professor == null) return;

            Turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);
            var turmaIds = Turmas.Select(t => t.Id).ToList();

            var todosAlunos = await AlunoService.GetAlunosAsync();
            Alunos = todosAlunos.Where(a => a.TurmaId != null && turmaIds.Contains(a.TurmaId.Value)).ToList();
            AlunosFiltrados = new List<Aluno>(Alunos);

            var trabalhos = await TrabalhoService.GetTrabalhosDoProfessorAsync(professor.UserId);

            TodosTrabalhosPendentes = trabalhos
                .Where(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.Any(v => !v.Nota.HasValue))
                .ToList();

            foreach (var aluno in Alunos)
            {
                var trabalhosAluno = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(aluno.UserId);
                var notas = trabalhosAluno
                    .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                    .Where(v => v.Nota.HasValue)
                    .Select(v => (double)v.Nota!.Value)
                    .ToList();

                if (notas.Any() && notas.Average() < 6)
                    AlunosMediaBaixa.Add(aluno);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erro: " + ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void FiltrarTurma(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();

        if (string.IsNullOrEmpty(val))
        {
            AlunosFiltrados = new List<Aluno>(Alunos);
            TurmaSelecionadaId = 0;
        }
        else if (int.TryParse(val, out int id))
        {
            TurmaSelecionadaId = id;
            AlunosFiltrados = Alunos.Where(a => a.TurmaId == id).ToList();
        }
    }

    private async Task CriarTrabalho()
    {
        if (TurmaSelecionadaId > 0)
            Nav.NavigateTo("/professor/CriarRoteiro/" + TurmaSelecionadaId);
        else
            await JS.InvokeVoidAsync("alert", "Selecione uma turma primeiro");
    }

    private void IrParaRelatorios()
    {
        Nav.NavigateTo("/professor/RelatoriosProfessor");
    }
}
