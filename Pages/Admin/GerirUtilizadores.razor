@page "/admin/GerirUtilizadores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using gestaopedagogica.Data
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Administrador")]

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IJSRuntime JS

@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

<h3>Gerir Utilizadores</h3>



<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Email</th>
            <th>Perfil</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Usuarios)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", UserRoles[user.Id])</td>
                <td>
                    <button class="btn btn-warning btn-sm me-1" @onclick="() => ResetarSenha(user)">Resetar Senha</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => Remover(user)">Remover</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (MostrarModalCriar)
{
    <div class="modal-bg">
        <div class="modal-card">

            <h4>Novo Utilizador</h4>

            <input class="form-control mb-2"
                   placeholder="Username"
                   @bind="NovoUser.UserName" />

            <input class="form-control mb-2"
                   placeholder="Email"
                   @bind="NovoUser.Email" />

            <select class="form-control mb-2" @bind="NovoRole">
                @foreach (var r in Roles)
                {
                    <option value="@r">@r</option>
                }
            </select>

            <button class="btn btn-success me-2" @onclick="SalvarNovo">Guardar</button>
            <button class="btn btn-secondary" @onclick="() => MostrarModalCriar = false">Cancelar</button>

        </div>
    </div>
}

@code {

    private List<ApplicationUser> Usuarios = new();
    private Dictionary<string, List<string>> UserRoles = new();
    private List<string> Roles = new();

    private ApplicationUser NovoUser = new();
    private string NovoRole = "Professor";

    private bool MostrarModalCriar = false;


    protected override async Task OnInitializedAsync()
    {
        await CarregarUsuarios();
    }


    private async Task CarregarUsuarios()
    {
        Usuarios = await UserManager.Users.ToListAsync();
        Roles = await RoleManager.Roles.Select(r => r.Name!).ToListAsync();

        UserRoles.Clear();

        foreach (var u in Usuarios)
        {
            var rolesForUser = await UserManager.GetRolesAsync(u);
            UserRoles[u.Id] = rolesForUser.ToList();
        }
    }


    private void MostrarCriar()
    {
        NovoUser = new ApplicationUser();
        NovoRole = "Professor";
        MostrarModalCriar = true;
    }


    private async Task SalvarNovo()
    {
        if (string.IsNullOrWhiteSpace(NovoUser.UserName) ||
            string.IsNullOrWhiteSpace(NovoUser.Email))
        {
            await JS.InvokeVoidAsync("alert", "Preencha username e email.");
            return;
        }

        var result = await UserManager.CreateAsync(
            new ApplicationUser
            {
                UserName = NovoUser.UserName,
                Email = NovoUser.Email
            },
            "Temp123!" // senha inicial
        );

        if (result.Succeeded)
        {
            var created = await UserManager.FindByNameAsync(NovoUser.UserName);

            if (created != null)
            {
                await UserManager.AddToRoleAsync(created, NovoRole);
            }

            await JS.InvokeVoidAsync("alert", "Utilizador criado com senha Temp123!");
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Erro ao criar utilizador.");
        }

        MostrarModalCriar = false;

        await CarregarUsuarios();
    }


    private async Task ResetarSenha(ApplicationUser user)
    {
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);

        var result = await UserManager.ResetPasswordAsync(user, token, "Temp123!");

        if (result.Succeeded)
        {
            await JS.InvokeVoidAsync("alert", $"Senha do utilizador {user.UserName} foi resetada para Temp123!");
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Erro ao resetar senha.");
        }
    }


    private async Task Remover(ApplicationUser user)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Excluir utilizador {user.UserName}?");

        if (!confirmado)
            return;

        await UserManager.DeleteAsync(user);

        await CarregarUsuarios();
    }

}