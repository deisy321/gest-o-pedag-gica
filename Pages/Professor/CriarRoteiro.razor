@page "/professor/CriarRoteiro/{TurmaIdStr}"
@namespace gestaopedagogica.Pages.Professor
@layout MainLayout

@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject TrabalhoService TrabalhoService
@inject TurmaService TurmaService
@inject ModuloService ModuloService
@inject DisciplinaService DisciplinaService
@inject ProfessorService ProfessorService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    @if (IsLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary"></div>
            <p>Carregando dados...</p>
        </div>
    }
    else if (TurmaSelecionada == null)
    {
        <div class="alert alert-danger">Turma não encontrada!</div>
    }
    else
    {
        <h3>Criar Trabalho para @TurmaSelecionada.Nome</h3>

        <div class="mb-3">
            <label><strong>Título</strong></label>
            <input class="form-control" @bind="Titulo" placeholder="Ex: Relatório de Estágio" />
            @if (!string.IsNullOrEmpty(ErroTitulo))
            {
                <small class="text-danger">@ErroTitulo</small>
            }
        </div>

        @* NOVO CAMPO: Descrição (Obrigatório pelo seu Banco de Dados) *@
        <div class="mb-3">
            <label><strong>Descrição do Trabalho</strong></label>
            <textarea class="form-control" @bind="Descricao" rows="3" placeholder="Descreva brevemente o que deve ser feito"></textarea>
            @if (!string.IsNullOrEmpty(ErroDescricao))
            {
                <small class="text-danger">@ErroDescricao</small>
            }
        </div>

        <div class="row">
            @if (ListaModulos.Count > 0)
            {
                <div class="col-md-6 mb-3">
                    <label>Módulo</label>
                    <select class="form-control" @bind="ModuloSelecionadoId">
                        <option value="0">-- Selecione um módulo --</option>
                        @foreach (var mod in ListaModulos)
                        {
                            <option value="@mod.Id">@mod.Nome</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(ErroModulo))
                    {
                        <small class="text-danger">@ErroModulo</small>
                    }
                </div>
            }

            @if (ListaDisciplinas.Count > 0)
            {
                <div class="col-md-6 mb-3">
                    <label>Disciplina</label>
                    <select class="form-control" @bind="DisciplinaSelecionadaId">
                        <option value="0">-- Selecione uma disciplina --</option>
                        @foreach (var disc in ListaDisciplinas)
                        {
                            <option value="@disc.Id">@disc.Nome</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(ErroDisciplina))
                    {
                        <small class="text-danger">@ErroDisciplina</small>
                    }
                </div>
            }
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Prazo de Entrega</label>
                <input type="date" class="form-control" @bind="PrazoEntrega" />
                @if (!string.IsNullOrEmpty(ErroPrazo))
                {
                    <small class="text-danger">@ErroPrazo</small>
                }
            </div>

            <div class="col-md-6 mb-3">
                <label>Tipo de Atribuição</label>
                <select class="form-control" @bind="TipoAtribuicao">
                    <option value="turma">Para toda a turma</option>
                    <option value="aluno">Para aluno específico</option>
                </select>
            </div>
        </div>

        @if (TipoAtribuicao == "aluno")
        {
            <div class="mb-3">
                <label>Aluno</label>
                <select class="form-control" @bind="AlunoSelecionadoId">
                    <option value="0">-- Selecione um aluno --</option>
                    @foreach (var aluno in TurmaSelecionada.Alunos.Where(a => !string.IsNullOrEmpty(a.UserId)))
                    {
                        <option value="@aluno.Id">@aluno.Nome</option>
                    }
                </select>
                @if (!string.IsNullOrEmpty(ErroAluno))
                {
                    <small class="text-danger">@ErroAluno</small>
                }
            </div>
        }

        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <h5>Vertentes</h5>
                @foreach (var vert in Vertentes)
                {
                    <div class="mb-2">
                        <label>@vert.Tipo</label>
                        <input class="form-control" @bind="vert.ConteudoTexto" placeholder="Conteúdo inicial (opcional)" />
                    </div>
                }
            </div>
        </div>

        <button type="button" class="btn btn-success btn-lg w-100" @onclick="SalvarRoteiro" disabled="@IsSaving">
            @if (IsSaving)
            {
                <span class="spinner-border spinner-border-sm"></span>
                <span> Gravando no Banco...</span>
            }
            else
            {
                <span>Criar Trabalho</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="alert @(StatusMessage.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                @StatusMessage
            </div>
        }
    }
</div>

@code {
    [Parameter] public string? TurmaIdStr { get; set; }

    private int TurmaId = 0;
    private Turma? TurmaSelecionada;
    private List<Modulo> ListaModulos = new();
    private List<Disciplina> ListaDisciplinas = new();

    private string Titulo = "";
    private string Descricao = ""; // Nova variável
    private int ModuloSelecionadoId = 0;
    private int DisciplinaSelecionadaId = 0;
    private int AlunoSelecionadoId = 0;
    private string TipoAtribuicao = "turma";
    private DateTime? PrazoEntrega = DateTime.Today.AddDays(7);
    private string StatusMessage = "";
    private bool IsSaving = false;
    private bool IsLoading = true;
    private string? ProfessorUserId;

    private string ErroTitulo = "";
    private string ErroDescricao = ""; // Novo erro
    private string ErroModulo = "";
    private string ErroDisciplina = "";
    private string ErroAluno = "";
    private string ErroPrazo = "";

    private List<VertenteEditModel> Vertentes = new()
    {
        new VertenteEditModel { Tipo = "Competência" },
        new VertenteEditModel { Tipo = "Aptidão" },
        new VertenteEditModel { Tipo = "Conhecimento" }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            ProfessorUserId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!int.TryParse(TurmaIdStr, out TurmaId))
            {
                StatusMessage = "❌ ID da turma inválido.";
                return;
            }

            await CarregarDados();
        }
        catch (Exception ex)
        {
            StatusMessage = $"❌ Erro ao carregar: {ex.Message}";
        }
        finally { IsLoading = false; }
    }

    private async Task CarregarDados()
    {
        TurmaSelecionada = await TurmaService.GetTurmaByIdAsync(TurmaId);
        ListaModulos = await ModuloService.GetModulosAsync() ?? new();
        ListaDisciplinas = await DisciplinaService.GetDisciplinasAsync() ?? new();
    }

    private bool ValidarFormulario()
    {
        ErroTitulo = string.IsNullOrWhiteSpace(Titulo) ? "O título é obrigatório" : "";
        ErroDescricao = string.IsNullOrWhiteSpace(Descricao) ? "A descrição é exigida pelo banco de dados" : "";
        ErroModulo = (ModuloSelecionadoId <= 0) ? "Selecione um módulo" : "";
        ErroDisciplina = (DisciplinaSelecionadaId <= 0) ? "Selecione uma disciplina" : "";
        ErroPrazo = !PrazoEntrega.HasValue ? "Escolha um prazo" : "";
        ErroAluno = (TipoAtribuicao == "aluno" && AlunoSelecionadoId <= 0) ? "Selecione um aluno" : "";

        return string.IsNullOrEmpty(ErroTitulo) &&
               string.IsNullOrEmpty(ErroDescricao) &&
               string.IsNullOrEmpty(ErroModulo) &&
               string.IsNullOrEmpty(ErroDisciplina) &&
               string.IsNullOrEmpty(ErroPrazo) &&
               string.IsNullOrEmpty(ErroAluno);
    }

    private async Task SalvarRoteiro()
    {
        if (IsSaving) return;
        IsSaving = true;
        StatusMessage = "Processando...";
        StateHasChanged();

        try
        {
            if (!ValidarFormulario())
            {
                StatusMessage = "❌ Corrija os erros antes de salvar.";
                IsSaving = false;
                return;
            }

            var professor = await ProfessorService.GetProfessorByUserIdAsync(ProfessorUserId!);
            if (professor == null)
            {
                StatusMessage = "❌ Professor não localizado.";
                IsSaving = false;
                return;
            }

            var alunosParaAtribuir = TipoAtribuicao == "aluno"
                ? TurmaSelecionada!.Alunos.Where(a => a.Id == AlunoSelecionadoId && !string.IsNullOrEmpty(a.UserId)).ToList()
                : TurmaSelecionada!.Alunos.Where(a => !string.IsNullOrEmpty(a.UserId)).ToList();

            int sucessos = 0;
            string detalheErro = "";

            foreach (var aluno in alunosParaAtribuir)
            {
                try
                {
                    await CriarTrabalhoAluno(professor.UserId, aluno.UserId!);
                    sucessos++;
                }
                catch (Exception ex)
                {
                    detalheErro = ex.InnerException?.Message ?? ex.Message;
                }
            }

            if (sucessos > 0)
            {
                StatusMessage = $"✅ {sucessos} trabalho(s) criado(s) com sucesso!";
                StateHasChanged();
                await Task.Delay(1500);
                Nav.NavigateTo("/professor/DashboardProfessor");
            }
            else
            {
                StatusMessage = $"❌ Falha ao gravar no Banco: {detalheErro}";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"❌ Erro Crítico: {ex.Message}";
        }
        finally { IsSaving = false; }
    }

    private async Task CriarTrabalhoAluno(string professorId, string alunoId)
    {
        var trabalho = new Trabalho
        {
            Titulo = Titulo.Trim(),
            Descricao = Descricao.Trim(), // Enviando o campo que estava faltando
            ProfessorId = professorId,
            AlunoId = alunoId,
            TurmaId = TurmaSelecionada!.Id,
            ModuloId = ModuloSelecionadoId,
            DisciplinaId = DisciplinaSelecionadaId,
            DataCriacao = DateTime.UtcNow,
            PrazoEntrega = PrazoEntrega ?? DateTime.UtcNow.AddDays(7)
        };

        int trabalhoId = await TrabalhoService.AddTrabalhoAsync(trabalho);

        if (trabalhoId <= 0) throw new Exception("ID retornado pelo banco foi zero.");

        foreach (var vertente in Vertentes)
        {
            var vertDb = new TrabalhoVertente
            {
                TrabalhoId = trabalhoId,
                Tipo = vertente.Tipo,
                ConteudoTexto = vertente.ConteudoTexto ?? ""
            };
            await TrabalhoService.AddVertenteAsync(vertDb);
        }
    }

    public class VertenteEditModel
    {
        public string Tipo { get; set; } = "";
        public string? ConteudoTexto { get; set; }
    }
}