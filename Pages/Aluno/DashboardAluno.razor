@page "/aluno/DashboardAluno"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject TurmaService TurmaService
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject DisciplinaService DisciplinaService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white p-3" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard do Aluno
            </h4>
        </div>

        <div class="card-body p-4 bg-light">

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }

            @if (IsLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">A carregar...</p>
                </div>
            }
            else
            {
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card text-white border-0" style="background:#f1b40e; border-radius:15px;">
                            <div class="card-body">
                                <small>Trabalhos Pendentes</small>
                                <h2>@TrabalhosPendentes.Count</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card text-white border-0" style="background:#0d6efd; border-radius:15px;">
                            <div class="card-body">
                                <small>Disciplinas</small>
                                <h2>@DisciplinasUnicas.Count</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card text-white border-0" style="background:#198754; border-radius:15px;">
                            <div class="card-body">
                                <small>Média</small>
                                <h2>@MediaGeral.ToString("F1")</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card bg-white border-0" style="border-radius:15px;">
                            <div class="card-body text-center">
                                <span class="badge bg-info text-dark">
                                    @TurmaAtual?.Nome ?? "N/D"
                                </span><br />
                                <small>@TurmaAtual?.Curso?.Nome ?? "N/D"</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4" style="border-radius:15px;">
                    <div class="card-body">
                        <div class="row">

                            <div class="col-md-6">
                                <label>Disciplina</label>
                                <select class="form-control" @onchange="OnDisciplinaChanged">
                                    <option value="">Todas</option>
                                    @foreach (var d in DisciplinasUnicas)
                                    {
                                        <option value="@d">@d</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label>Módulo</label>
                                <select class="form-control" @bind="ModuloSelecionado" @bind:after="FiltrarTrabalhos">
                                    <option value="">Todos</option>
                                    @foreach (var m in ModulosDisponiveis)
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="card" style="border-radius:15px;">
                    <div class="card-body p-0">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Título</th>
                                    <th>Professor</th>
                                    <th>Módulo</th>
                                    <th>Prazo</th>
                                    <th>Progresso</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var t in TrabalhosFiltrados)
                                {
                                    var perc = CalcularPercentualConclusao(t.TrabalhoVertentes);

                                    <tr>
                                        <td>
                                            <b>@t.Titulo</b><br />
                                            <small>@t.Disciplina?.Nome</small>
                                        </td>

                                        <td>@t.Professor?.UserName</td>

                                        <td>@t.Modulo?.Nome</td>

                                        <td>
                                            <span class="@(t.PrazoEntrega < DateTime.UtcNow ? "text-danger" : "")">
                                                @t.PrazoEntrega.ToString("dd/MM/yyyy")
                                            </span>
                                        </td>

                                        <td>
                                            <div class="progress" style="height:6px;">
                                                <div class="progress-bar" style="width:@perc%"></div>
                                            </div>
                                            <small>@perc.ToString("F0")%</small>
                                        </td>

                                        <td>
                                            <button class="btn btn-sm btn-primary"
                                                    @onclick="() => ResolverTrabalho(t.Id)">
                                                Abrir
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end">
                    <button class="btn btn-outline-primary me-2"
                            @onclick="IrParaMinhasNotas">
                        Minhas Notas
                    </button>

                    <button class="btn btn-outline-secondary"
                            @onclick="IrParaHistorico">
                        Histórico
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Aluno? AlunoAtual;
    private Turma? TurmaAtual;

    private List<Trabalho> TodosTrabalhos = new();
    private List<Trabalho> TrabalhosPendentes = new();
    private List<Trabalho> TrabalhosFiltrados = new();

    private List<string> DisciplinasUnicas = new();
    private List<string> ModulosDisponiveis = new();

    private string DisciplinaSelecionada = "";
    private string ModuloSelecionado = "";

    private double MediaGeral = 0;

    private string? ErrorMessage;
    private bool IsLoading = true;
    private string? AlunoUserId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        AlunoUserId = auth.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await CarregarDados();
        IsLoading = false;
    }

    private async Task CarregarDados()
    {
        AlunoAtual = (await AlunoService.GetAlunosAsync())
            .FirstOrDefault(a => a.UserId == AlunoUserId);

        if (AlunoAtual?.TurmaId != null)
            TurmaAtual = await TurmaService.GetTurmaByIdAsync(AlunoAtual.TurmaId.Value);

        TodosTrabalhos = await TrabalhoService.GetTrabalhosDisponiveisParaAlunoAsync(AlunoUserId);

        TrabalhosPendentes = TodosTrabalhos
            .Where(t => t.TrabalhoVertentes == null || t.TrabalhoVertentes.Any(v => !v.Nota.HasValue))
            .ToList();

        TrabalhosFiltrados = TodosTrabalhos;

        DisciplinasUnicas = TodosTrabalhos
            .Select(t => t.Disciplina?.Nome)
            .Where(n => n != null)
            .Distinct()
            .ToList()!;

        ModulosDisponiveis = TodosTrabalhos
            .Select(t => t.Modulo?.Nome)
            .Where(n => n != null)
            .Distinct()
            .ToList()!;

        var notas = TodosTrabalhos
            .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>()) // ✔ FIX
            .Where(v => v.Nota.HasValue)
            .Select(v => (double)v.Nota!.Value);

        MediaGeral = notas.Any() ? notas.Average() : 0;
    }

    private void OnDisciplinaChanged(ChangeEventArgs e)
    {
        DisciplinaSelecionada = e.Value?.ToString() ?? "";
        FiltrarTrabalhos();
    }

    private void FiltrarTrabalhos()
    {
        TrabalhosFiltrados = TodosTrabalhos
            .Where(t =>
                (string.IsNullOrEmpty(DisciplinaSelecionada) || t.Disciplina?.Nome == DisciplinaSelecionada) &&
                (string.IsNullOrEmpty(ModuloSelecionado) || t.Modulo?.Nome == ModuloSelecionado))
            .ToList();
    }

    private double CalcularPercentualConclusao(ICollection<TrabalhoVertente>? v)
    {
        if (v == null || !v.Any()) return 0;
        var done = v.Count(x => !string.IsNullOrEmpty(x.ConteudoTextoAluno) || x.FicheiroBytes != null);
        return (double)done / v.Count * 100;
    }

    private void ResolverTrabalho(int id) => Nav.NavigateTo($"/aluno/EnviarTrabalho/{id}");
    private void IrParaMinhasNotas() => Nav.NavigateTo("/aluno/MinhasNotas");
    private void IrParaHistorico() => Nav.NavigateTo("/aluno/Historico");
}