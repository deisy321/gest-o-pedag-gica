@page "/admin/GerirTurmas"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@attribute [Authorize(Roles = "Admin")]

@inject TurmaService TurmaService
@inject ProfessorService ProfessorService
@inject AlunoService AlunoService
@inject DisciplinaService DisciplinaService
@inject CursoService CursoService
@inject NavigationManager Nav

<div class="page-admin animate-fade-in">
    @* Cabeçalho *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-gradient fw-bold mb-0">Gerir Turmas</h2>
            <p class="text-muted small">Administração de turmas, alunos e corpo docente</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary rounded-pill px-4" @onclick='() => Nav.NavigateTo("/admin/GerirCursos")'>
                <i class="bi bi-book me-2"></i>Cursos
            </button>
            @* Botão Corrigido para Verde *@
            <button class="btn btn-success rounded-pill px-4 shadow-sm" @onclick="MostrarCriarTurma">
                <i class="bi bi-plus-lg me-2"></i>Nova Turma
            </button>
        </div>
    </div>

    @* Alertas *@
    @if (!string.IsNullOrEmpty(ErroMensagem))
    {
        <div class="alert alert-danger border-0 shadow-sm mb-3">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @ErroMensagem
        </div>
    }
    @if (!string.IsNullOrEmpty(SucessoMensagem))
    {
        <div class="alert alert-success border-0 shadow-sm mb-3">
            <i class="bi bi-check-circle-fill me-2"></i> @SucessoMensagem
        </div>
    }

    @* Tabela *@
    <div class="custom-card shadow-sm border-0">
        @if (CarregandoDados)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">A atualizar dados...</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Identificação</th>
                            <th>Curso</th>
                            <th>Ano Letivo</th>
                            <th class="text-center">Alunos</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Turmas != null && Turmas.Any())
                        {
                            @foreach (var t in Turmas)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@t.Nome</div>
                                        <small class="text-muted">ID: #@t.Id</small>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-light text-primary border px-3">
                                            @(t.Curso?.Nome ?? "Sem Curso")
                                        </span>
                                    </td>
                                    <td><span class="text-secondary">@t.Ano</span></td>
                                    <td class="text-center">
                                        <span class="badge bg-info bg-opacity-10 text-info border-info border-opacity-25 px-3">
                                            @((t.Alunos?.Count ?? 0)) Inscritos
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" @onclick="() => Remover(t)">
                                            <i class="bi bi-trash3 fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">Nenhuma turma encontrada.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Modal *@
@if (MostrarModalCriar)
{
    <div class="modal-bg animate-fade-in" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1050; display: flex; align-items: center; justify-content: center;">
        <div class="modal-card bg-white p-4 shadow-lg animate-slide-up" style="border-radius: 20px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0 text-primary">Configurar Turma</h4>
                <button class="btn-close" @onclick="() => MostrarModalCriar = false"></button>
            </div>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-bold small text-secondary">CURSO BASE</label>
                    <select class="form-select rounded-pill" @bind="NovaTurma.CursoId">
                        <option value="0">Selecione o Curso...</option>
                        @foreach (var c in TodosCursos)
                        {
                            <option value="@c.Id">@c.Nome</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold small text-secondary">NOME DA TURMA</label>
                    <input class="form-control rounded-pill" @bind="NovaTurma.Nome" placeholder="Ex: 10º A" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-secondary">ANO LETIVO</label>
                    <input class="form-control rounded-pill" @bind="NovaTurma.Ano" placeholder="Ex: 2023/24" />
                </div>

                @* Professores *@
                <div class="col-12 mt-3">
                    <label class="form-label fw-bold">Corpo Docente</label>
                    <div class="input-group">
                        <select class="form-select rounded-start-pill" @bind="ProfessorSelecionado">
                            <option value="0">Professor...</option>
                            @foreach (var p in TodosProfessores)
                            {
                                <option value="@p.Id">@p.Nome</option>
                            }
                        </select>
                        <select class="form-select" @bind="DisciplinaSelecionada">
                            <option value="0">Disciplina...</option>
                            @foreach (var d in TodosDisciplinas)
                            {
                                <option value="@d.Id">@d.Nome</option>
                            }
                        </select>
                        <button class="btn btn-primary rounded-end-pill" @onclick="AdicionarProfessor"><i class="bi bi-plus"></i></button>
                    </div>
                    <div class="mt-2">
                        @foreach (var tp in NovaTurma.Professores)
                        {
                            <span class="badge bg-white text-dark border m-1 p-2 rounded-pill shadow-sm">
                                @tp.Professor?.Nome (@tp.Disciplina?.Nome)
                                <i class="bi bi-x-circle ms-2 text-danger" style="cursor:pointer" @onclick="() => NovaTurma.Professores.Remove(tp)"></i>
                            </span>
                        }
                    </div>
                </div>

                @* Alunos *@
                <div class="col-12 mt-2">
                    <label class="form-label fw-bold">Adicionar Alunos</label>
                    <select class="form-select rounded-pill" @onchange="AdicionarAluno">
                        <option value="0">Selecionar aluno...</option>
                        @foreach (var a in TodosAlunos)
                        {
                            <option value="@a.Id">@a.Nome</option>
                        }
                    </select>
                    <div class="scroll-list mt-2 rounded-3" style="max-height: 150px; overflow-y: auto; border: 1px solid #eee; padding: 10px;">
                        @foreach (var a in NovaTurma.Alunos)
                        {
                            <div class="d-flex justify-content-between border-bottom py-1">
                                <span class="small">@a.Nome</span>
                                <i class="bi bi-trash text-danger" style="cursor:pointer" @onclick="() => NovaTurma.Alunos.Remove(a)"></i>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex gap-2">
                <button class="btn btn-light rounded-pill flex-grow-1" @onclick="() => MostrarModalCriar = false">Cancelar</button>
                @* Botão Corrigido para Azul *@
                <button class="btn btn-primary rounded-pill flex-grow-1 shadow-sm" style="font-weight: bold;" @onclick="SalvarNovaTurma">
                    Gravar Turma
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<Turma> Turmas = new();
    List<Professor> TodosProfessores = new();
    List<Aluno> TodosAlunos = new();
    List<Curso> TodosCursos = new();
    List<Disciplina> TodosDisciplinas = new();

    bool MostrarModalCriar = false;
    bool CarregandoDados = true;
    Turma NovaTurma = new();
    int ProfessorSelecionado = 0;
    int DisciplinaSelecionada = 0;
    string? ErroMensagem;
    string? SucessoMensagem;

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        try
        {
            CarregandoDados = true;
            TodosProfessores = await ProfessorService.GetProfessoresAsync() ?? new();
            TodosAlunos = await AlunoService.GetAlunosAsync() ?? new();
            TodosCursos = await CursoService.GetCursosAsync() ?? new();
            TodosDisciplinas = await DisciplinaService.GetDisciplinasAsync() ?? new();
            Turmas = await TurmaService.GetTurmasComCursoAsync() ?? new();
        }
        catch (Exception ex) { ErroMensagem = $"Erro ao carregar: {ex.Message}"; }
        finally { CarregandoDados = false; }
    }

    void MostrarCriarTurma()
    {
        NovaTurma = new Turma { Professores = new(), Alunos = new() };
        MostrarModalCriar = true;
        ErroMensagem = null;
    }

    void AdicionarProfessor()
    {
        if (ProfessorSelecionado == 0 || DisciplinaSelecionada == 0) return;
        var p = TodosProfessores.FirstOrDefault(x => x.Id == ProfessorSelecionado);
        var d = TodosDisciplinas.FirstOrDefault(x => x.Id == DisciplinaSelecionada);
        if (p != null && d != null)
        {
            // Evitar duplicados na mesma turma
            if (!NovaTurma.Professores.Any(x => x.ProfessorId == p.Id && x.DisciplinaId == d.Id))
            {
                NovaTurma.Professores.Add(new TurmaProfessor { ProfessorId = p.Id, Professor = p, DisciplinaId = d.Id, Disciplina = d });
            }
            ProfessorSelecionado = 0; DisciplinaSelecionada = 0;
        }
    }

    void AdicionarAluno(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id != 0)
        {
            var a = TodosAlunos.FirstOrDefault(x => x.Id == id);
            if (a != null && !NovaTurma.Alunos.Any(x => x.Id == id)) NovaTurma.Alunos.Add(a);
        }
    }

    async Task SalvarNovaTurma()
    {
        try
        {
            ErroMensagem = null;

            // Validação de segurança
            if (string.IsNullOrWhiteSpace(NovaTurma.Nome) || NovaTurma.CursoId == 0)
            {
                ErroMensagem = "Por favor, preencha o nome e selecione um curso.";
                return;
            }

            // LIMPEZA PARA O BANCO DE DADOS (RENDER)
            // Removemos as instâncias dos objetos para o EF focar apenas nos IDs
            // e não tentar criar novos professores/disciplinas/cursos
            foreach (var tp in NovaTurma.Professores)
            {
                tp.Professor = null;
                tp.Disciplina = null;
            }

            // Limpamos a lista de alunos para enviar apenas as referências por ID
            var alunosIds = NovaTurma.Alunos.Select(a => a.Id).ToList();
            NovaTurma.Alunos = TodosAlunos.Where(a => alunosIds.Contains(a.Id)).ToList();

            // O Curso também deve ser limpo para não duplicar
            NovaTurma.Curso = null;

            await TurmaService.AddTurmaAsync(NovaTurma);

            SucessoMensagem = "Turma registada com sucesso!";
            MostrarModalCriar = false;
            await CarregarDados();
            _ = AutoFecharMensagem();
        }
        catch (Exception ex)
        {
            // Captura o erro detalhado do banco de dados
            ErroMensagem = $"Erro ao gravar: {ex.InnerException?.Message ?? ex.Message}";
        }
    }

    async Task Remover(Turma t)
    {
        try
        {
            await TurmaService.RemoveTurmaAsync(t);
            SucessoMensagem = "Turma removida!";
            await CarregarDados();
            _ = AutoFecharMensagem();
        }
        catch (Exception ex) { ErroMensagem = "Erro ao remover: " + ex.Message; }
    }

    private async Task AutoFecharMensagem()
    {
        await Task.Delay(4000);
        SucessoMensagem = null;
        ErroMensagem = null;
        StateHasChanged();
    }
}