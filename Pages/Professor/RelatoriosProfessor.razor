@page "/professor/RelatoriosProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.Security.Claims
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject IAService IAService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark">Painel de Avaliação Docente</h3>
        <span class="badge bg-primary">Sessão: @DateTime.Now.Year/@(DateTime.Now.Year + 1)</span>
    </div>

    <div class="row mb-4">
        @* Gráfico de Desempenho *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-4 text-muted">Média por Turma</h5>
                @if (Labels == null || !Labels.Any())
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                <div style="position: relative; height:350px; width:100%">
                    <canvas id="chartTurmas"></canvas>
                </div>
            </div>
        </div>

        @* Coluna Lateral com Resumo e IA *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 bg-light h-100 d-flex flex-column">
                <h5 class="fw-bold mb-3">Resumo de Atividades</h5>
                <div class="list-group list-group-flush bg-transparent">
                    @foreach (var label in Labels.Select((name, index) => new { name, index }))
                    {
                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-0 px-0">
                            <span>@label.name</span>
                            <span class="fw-bold">@Medias[label.index].ToString("F1")</span>
                        </div>
                    }
                </div>

                @* Bloco de Análise da IA *@
                <div class="mt-4 pt-3 border-top">
                    @if (isGerandoAnalise)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <p class="small text-muted mt-2">A IA está a analisar os resultados...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(analiseIA))
                    {
                        <div class="p-3 rounded-3" style="background: #ffffff; border-left: 4px solid #4e73df;">
                            <h6 class="small fw-bold text-primary mb-2">
                                <i class="bi bi-robot me-2"></i>Insight Pedagógico (IA)
                            </h6>
                            <p class="small mb-0 text-dark" style="line-height: 1.4; white-space: pre-line;">
                                @analiseIA
                            </p>
                        </div>
                    }
                </div>

                <div class="mt-auto pt-3">
                    <p class="small text-muted mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Análise gerada com base nos dados da Tríade.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<string> Labels = new();
    private List<double> Medias = new();
    private string analiseIA = "";
    private bool isGerandoAnalise = false;
    private bool initialized = false;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        var professor = await ProfessorService.GetProfessorByUserIdAsync(userId);
        if (professor == null) return;

        var turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);
        var trabalhos = await TrabalhoService.GetTodosTrabalhosComNotasAsync();

        var dados = turmas.Select(turma =>
        {
            var notas = trabalhos.Where(t => t.TurmaId == turma.Id && t.ProfessorId == userId)
                .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                .Where(v => v.Nota.HasValue)
                .Select(v => (double)v.Nota!.Value).ToList();

            return new { Nome = turma.Nome, Media = notas.Any() ? Math.Round(notas.Average(), 1) : 0 };
        }).OrderByDescending(x => x.Media).ToList();

        Labels = dados.Select(d => d.Nome).ToList();
        Medias = dados.Select(d => d.Media).ToList();
        initialized = true;

        // Inicia a geração da análise da IA se houver dados
        if (Medias.Any(m => m > 0))
        {
            _ = GerarAnaliseIA(userId); // Executa em background para não travar a UI
        }
    }

    private async Task GerarAnaliseIA(string professorId)
    {
        try
        {
            isGerandoAnalise = true;
            StateHasChanged();

            var resumoDados = string.Join("; ", Labels.Select((name, index) =>
                $"Turma {name} tem média {Medias[index]}"));

            analiseIA = await IAService.ObterSugestoes(
                promptSistemaOriginal: "És um Mentor Pedagógico especializado em análise de dados escolares. O teu objetivo é ajudar o professor a interpretar as médias das suas turmas.",
                instrucaoPrincipal: "Dá um conselho pedagógico curto (máx 3 frases) baseado nestas médias. Identifica quem precisa de apoio ou parabéns.",
                conteudoParaAnalisar: resumoDados,
                alunoId: professorId,
                trabalhoId: "REPORT_PROF",
                vertenteId: "0",
                arquivoBytes: null
            );
        }
        catch (Exception ex)
        {
            analiseIA = "Padrões de desempenho estáveis. Continue a monitorizar.";
            Console.WriteLine($"Erro IA Relatório: {ex.Message}");
        }
        finally
        {
            isGerandoAnalise = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (initialized && Labels.Any())
        {
            await JS.InvokeVoidAsync("site.renderBarChart",
                "chartTurmas",
                Labels.ToArray(),
                Medias.ToArray(),
                Labels.Select(_ => "#4e73df").ToArray());

            initialized = false;
        }
    }
}