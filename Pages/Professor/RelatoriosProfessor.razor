@page "/professor/RelatoriosProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<h3>Relatórios do Professor</h3>

<div class="row">
    <div class="col-md-12">
        <div class="card p-3">
            <h5>Comparação de Desempenho por Turma</h5>
            <canvas id="chartTurmas"></canvas>
        </div>
    </div>
</div>

@code {
    private List<string> Labels = new();
    private List<double> Medias = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var professor = await ProfessorService.GetProfessorByUserIdAsync(userId!);

        if (professor == null) return;

        var turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);

        var trabalhos = await TrabalhoService.GetTodosTrabalhosComNotasAsync();

        var dados = turmas.Select(turma =>
        {
            var notas = trabalhos
                .Where(t => t.TurmaId == turma.Id)
                .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                .Where(v => v.Nota.HasValue)
                .Select(v => (double)v.Nota!.Value)
                .ToList();

            return new
            {
                Nome = turma.Nome,
                Media = notas.Any() ? notas.Average() : 0
            };
        })
        .OrderByDescending(x => x.Media) // ✔ ordena melhor → pior
        .ToList();

        Labels = dados.Select(d => d.Nome).ToList();
        Medias = dados.Select(d => d.Media).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Labels.Any())
        {
            var colors = Labels.Select(_ => "#4e73df").ToArray();

            await JS.InvokeVoidAsync(
                "site.renderBarChart",
                "chartTurmas",
                Labels.ToArray(),
                Medias.ToArray(),
                colors
            );
        }
    }
}
