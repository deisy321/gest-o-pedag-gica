@page "/professor/AvaliarAlunos/{AlunoId:int}"
@using gestaopedagogica.Services
@using gestaopedagogica.Models

@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject NavigationManager Nav

<h3 class="fw-bold mb-4">Avaliar Aluno</h3>

@if (IsLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else if (AlunoAtual == null)
{
    <div class="alert alert-danger">Aluno não encontrado</div>
}
else if (!Trabalhos.Any())
{
    <div class="alert alert-warning">Aluno ainda não tem trabalhos</div>
}
else
{
    <!-- INFO DO ALUNO -->
    <div class="card mb-4 p-3 shadow-sm" style="border-radius: 12px;">
        <strong>@AlunoAtual.Email</strong><br />
        Turma: @(AlunoAtual.Turma?.Nome ?? "Sem turma")
    </div>

    <!-- TRABALHOS -->
    @foreach (var trabalho in Trabalhos)
    {
        <div class="card mb-4 shadow-sm border-0" style="border-radius: 15px;">

            <!-- HEADER -->
            <div class="card-header bg-light fw-bold d-flex justify-content-between">
                <span>@trabalho.Titulo</span>
            </div>

            <div class="card-body">

                @if (!trabalho.TrabalhoVertentes.Any())
                {
                    <div class="alert alert-warning mb-0">
                        Este trabalho ainda não tem vertentes.
                    </div>
                }
                else if (trabalho.TrabalhoVertentes.All(v =>
                string.IsNullOrEmpty(v.ConteudoTextoAluno) && v.FicheiroBytes == null))
                {
                    <div class="alert alert-secondary mb-3">
                        O aluno ainda não enviou nenhuma resposta para este trabalho.
                    </div>
                }

                <!-- VERTENTES EM CARDS -->
                <div class="row g-3">
                    @foreach (var vertente in trabalho.TrabalhoVertentes)
                    {
                        var enviado = !string.IsNullOrEmpty(vertente.ConteudoTextoAluno) || vertente.FicheiroBytes != null;

                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px;">

                                <div class="card-body d-flex flex-column">

                                    <!-- TIPO -->
                                    <h6 class="fw-bold">@vertente.Tipo</h6>

                                    <!-- STATUS -->
                                    @if (!enviado)
                                    {
                                        <span class="badge bg-secondary mb-2">Não enviado</span>
                                    }
                                    else if (vertente.Nota.HasValue)
                                    {
                                        <span class="badge bg-success mb-2">Corrigido</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark mb-2">Enviado</span>
                                    }

                                    <!-- TEXTO -->
                                    @if (!string.IsNullOrEmpty(vertente.ConteudoTextoAluno))
                                    {
                                        <p class="text-muted small">
                                            @vertente.ConteudoTextoAluno
                                        </p>
                                    }

                                    <!-- NOTA -->
                                    @if (vertente.Nota.HasValue)
                                    {
                                        <div class="mt-auto">
                                            <strong>Nota:</strong> @vertente.Nota<br />
                                            <small class="text-muted">@vertente.Feedback</small>
                                        </div>
                                    }

                                    <!-- BOTÃO -->
                                    <button class="btn btn-sm btn-success rounded-pill mt-3"
                                            @onclick='() => IrAvaliar(trabalho.Id, vertente.Tipo)'>
                                        Avaliar
                                    </button>

                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
}

@code {
    [Parameter] public int AlunoId { get; set; }

    private Aluno? AlunoAtual;
    private List<Trabalho> Trabalhos = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        AlunoAtual = await AlunoService.GetAlunoByIdAsync(AlunoId);

        if (AlunoAtual != null && !string.IsNullOrEmpty(AlunoAtual.UserId))
        {
            Trabalhos = await TrabalhoService
                .GetTrabalhosDoAlunoComVertentesAsync(AlunoAtual.UserId);
        }

        IsLoading = false;
    }

    private void IrAvaliar(int trabalhoId, string tipo)
    {
        Nav.NavigateTo($"/professor/AvaliarVertente/{trabalhoId}/{tipo}");
    }
}