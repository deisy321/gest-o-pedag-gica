@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject ProfessorService ProfessorService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <h2 class="fw-bold mb-4">Ficha do Aluno</h2>

    @if (IsLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">A analisar dados do aluno...</p>
        </div>
    }
    else if (AlunoSelecionado == null)
    {
        <div class="alert alert-warning">Aluno não encontrado.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 p-3 d-flex align-items-center justify-content-center"
                     style="border-radius: 15px; cursor:pointer; text-align:center;"
                     @onclick="ToggleDetalhes">

                    <div class="bg-primary text-white d-flex align-items-center justify-content-center mb-2"
                         style="width:50px; height:50px; border-radius:50%; font-size:20px;">
                        @(string.IsNullOrEmpty(AlunoSelecionado.Nome) ? "?" : AlunoSelecionado.Nome.Substring(0, 1).ToUpper())
                    </div>

                    <div class="fw-bold">@AlunoSelecionado.Nome</div>

                    @if (MostrarDetalhes)
                    {
                        <div class="mt-2 border-top pt-2 text-start w-100">
                            <small class="d-block"><strong>Email:</strong> @AlunoSelecionado.Email</small>
                            <small class="d-block"><strong>Turma:</strong> @(AlunoSelecionado.Turma?.Nome ?? "Sem turma")</small>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-9">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 15px; background:#f0f8ff;">
                            <h6 class="text-muted">Entregues</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Enviado))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 15px; background:#fff3cd;">
                            <h6 class="text-muted">Pendentes</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.All(v => !v.Enviado))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 15px; background:#d4edda;">
                            <h6 class="text-muted">Corrigidos</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 15px; background:#e2e3e5;">
                            <h6 class="text-muted">Média Geral</h6>
                            <h4 class="fw-bold mb-0">@CalcularMediaGeral().ToString("F1")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px; border-left: 5px solid #dc3545;">
            <h5 class="fw-bold text-danger mb-3"><i class="bi bi-exclamation-octagon"></i> Análise de Recuperação</h5>

            @if (VertentesAbaixoDaMedia != null && VertentesAbaixoDaMedia.Any())
            {
                <p class="text-muted small">As seguintes categorias apresentam média insuficiente (≤ 9.0):</p>
                <div class="row g-2">
                    @foreach (var v in VertentesAbaixoDaMedia)
                    {
                        <div class="col-md-6">
                            <div class="alert alert-light border d-flex justify-content-between align-items-center p-2 mb-0 shadow-sm">
                                <div>
                                    <strong class="text-uppercase">@v.Tipo</strong>
                                    <span class="badge bg-danger ms-2">@v.Media.ToString("F1")</span>
                                </div>
                                <button class="btn btn-danger btn-sm rounded-pill" @onclick="() => IniciarPlano(v)">
                                    Criar Plano
                                </button>
                            </div>
                        </div>
                    }
                </div>

                @if (VertenteEmFoco != null)
                {
                    <div class="mt-4 p-3 bg-light rounded border-start border-danger border-4">
                        <h6 class="fw-bold text-danger">Instruções para Recuperação: @VertenteEmFoco.Tipo</h6>
                        <textarea class="form-control mb-3" rows="4" @bind="DescricaoNovoPlano"
                                  placeholder="Escreva aqui as orientações detalhadas para o aluno..."></textarea>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger btn-sm px-4" @onclick="SubmeterPlanoRecuperacao"
                                    disabled="@(string.IsNullOrEmpty(DescricaoNovoPlano) || IsSaving)">
                                @(IsSaving ? "A enviar..." : "Enviar Plano ao Aluno")
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => VertenteEmFoco = null">Cancelar</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted mb-0 small">O aluno não possui vertentes críticas (média ≤ 9) no momento.</p>
            }
        </div>

        <div class="d-flex justify-content-end mb-4 gap-2">
            <button class="btn btn-success rounded-pill px-4"
                    @onclick='() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}")'>
                Avaliar Aluno
            </button>
            <button class="btn btn-secondary rounded-pill px-4"
                    @onclick="VoltarParaDashboard">
                <i class="bi bi-arrow-left me-2"></i> Voltar
            </button>
        </div>

        <div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
            <h5 class="fw-bold mb-4">Progresso do Aluno</h5>
            <div class="progress mb-2" style="height:25px; border-radius:12px;">
                @{
                    var countCorrigidos = TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue));
                    var percentagem = TrabalhosAluno.Count > 0 ? (countCorrigidos * 100 / TrabalhosAluno.Count) : 0;
                }
                <div class="progress-bar bg-success" role="progressbar"
                     style="width: @(percentagem)%"
                     aria-valuenow="@percentagem"
                     aria-valuemin="0" aria-valuemax="100">
                    @percentagem%
                </div>
            </div>
            <small class="text-muted">Percentual de trabalhos corrigidos</small>
        </div>
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }

    private Aluno? AlunoSelecionado;
    private List<TrabalhoAlunoCustom> TrabalhosAluno = new();
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool MostrarDetalhes = false;

    private List<VertenteAnalise> VertentesAbaixoDaMedia = new();
    private VertenteAnalise? VertenteEmFoco;
    private string DescricaoNovoPlano = "";

    private void ToggleDetalhes() => MostrarDetalhes = !MostrarDetalhes;

    protected override async Task OnInitializedAsync()
    {
        await CarregarFichaCompleta();
    }

    private double CalcularMediaGeral()
    {
        var notas = TrabalhosAluno.SelectMany(t => t.Vertentes)
                                  .Where(v => v.Nota.HasValue)
                                  .Select(v => (double)v.Nota!.Value)
                                  .ToList();
        return notas.Any() ? notas.Average() : 0;
    }

    private async Task CarregarFichaCompleta()
    {
        IsLoading = true;
        TrabalhosAluno.Clear();

        try
        {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);

            if (AlunoSelecionado != null && !string.IsNullOrEmpty(AlunoSelecionado.UserId))
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);

                if (trabalhos != null)
                {
                    TrabalhosAluno = trabalhos.Select(t => new TrabalhoAlunoCustom
                    {
                        TrabalhoId = t.Id,
                        Titulo = t.Titulo ?? "Sem Título",
                        DisciplinaId = t.DisciplinaId,
                        IsPlanoRecuperacao = t.IsPlanoRecuperacao,
                        Vertentes = t.TrabalhoVertentes?.Select(v => new VertenteStatusCustom
                        {
                            Tipo = v.Tipo ?? "Geral",
                            Enviado = !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null,
                            Nota = v.Nota
                        }).ToList() ?? new List<VertenteStatusCustom>()
                    }).ToList();

                    AnalisarVertentesCriticas();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void AnalisarVertentesCriticas()
    {
        if (TrabalhosAluno == null || !TrabalhosAluno.Any()) return;

        VertentesAbaixoDaMedia = TrabalhosAluno
            .Where(t => !t.IsPlanoRecuperacao)
            .SelectMany(t => t.Vertentes)
            .GroupBy(v => (v.Tipo ?? "Geral").Trim().ToUpper())
            .Select(g =>
            {
                var notasValidas = g.Where(v => v.Nota.HasValue).Select(v => (double)v.Nota!.Value).ToList();
                return new VertenteAnalise
                {
                    Tipo = g.First().Tipo ?? "Geral",
                    Media = notasValidas.Any() ? notasValidas.Average() : 0,
                    TemNotas = notasValidas.Any()
                };
            })
            .Where(v => v.TemNotas && v.Media <= 9.0)
            .OrderBy(v => v.Media)
            .ToList();
    }

    private void IniciarPlano(VertenteAnalise v)
    {
        VertenteEmFoco = v;
        DescricaoNovoPlano = "";
    }

    private async Task SubmeterPlanoRecuperacao()
    {
        if (VertenteEmFoco == null || AlunoSelecionado == null || IsSaving) return;

        IsSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var professorUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            var plano = new Trabalho
            {
                Titulo = $"RECUPERAÇÃO: {VertenteEmFoco.Tipo}",
                ConteudoTexto = DescricaoNovoPlano,
                AlunoId = AlunoSelecionado.UserId,
                ProfessorId = professorUserId,
                IsPlanoRecuperacao = true,
                DataCriacao = DateTime.UtcNow,
                PrazoEntrega = DateTime.UtcNow.AddDays(7),
                DisciplinaId = TrabalhosAluno.FirstOrDefault(t => !t.IsPlanoRecuperacao)?.DisciplinaId,
                TurmaId = AlunoSelecionado.TurmaId
            };

            var trabalhoId = await TrabalhoService.AddTrabalhoAsync(plano);

            var vertenteInicial = new TrabalhoVertente
            {
                TrabalhoId = trabalhoId,
                Tipo = VertenteEmFoco.Tipo,
                // CORREÇÃO: Passamos o texto que o prof escreveu para a vertente,
                // que é o que o aluno visualiza na página de detalhes.
                ConteudoTexto = DescricaoNovoPlano,
                ConteudoTextoAluno = "Iniciado por Recuperação"
            };

            await TrabalhoService.AddVertenteAsync(vertenteInicial);
            await JS.InvokeVoidAsync("alert", "Plano enviado com sucesso! O aluno já pode ver as suas instruções.");

            VertenteEmFoco = null;
            await CarregarFichaCompleta();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro: " + ex.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");

    public class TrabalhoAlunoCustom
    {
        public int TrabalhoId { get; set; }
        public string Titulo { get; set; } = "";
        public int? DisciplinaId { get; set; }
        public bool IsPlanoRecuperacao { get; set; }
        public List<VertenteStatusCustom> Vertentes { get; set; } = new();
    }

    public class VertenteStatusCustom
    {
        public string Tipo { get; set; } = "";
        public bool Enviado { get; set; }
        public decimal? Nota { get; set; }
    }

    public class VertenteAnalise
    {
        public string Tipo { get; set; } = "";
        public double Media { get; set; }
        public bool TemNotas { get; set; }
    }
}