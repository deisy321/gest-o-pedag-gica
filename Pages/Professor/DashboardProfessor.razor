@page "/professor/DashboardProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject AlunoService AlunoService
@inject TurmaService TurmaService
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS


@if (IsLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary"></div>
        <p>Carregando dados...</p>
    </div>
}
else
{
    <!-- CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-lg-2">
            <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #4e73df; border-radius: 15px;">
                <h6>Total de Alunos</h6>
                <h2>@Alunos.Count</h2>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="card border-0 shadow-sm p-3 text-white h-100" style="background-color: #1cc88a; border-radius: 15px;">
                <h6>Total de Turmas</h6>
                <h2>@Turmas.Count</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- ALUNOS -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                <h5 class="fw-bold mb-3">Alunos</h5>

                <div class="mb-3 d-flex align-items-center gap-3">
                    <select class="form-select shadow-sm" style="border-radius: 12px; width: 200px;" @onchange="FiltrarTurma">
                        <option value="">Todas as Turmas</option>
                        @foreach (var turma in Turmas)
                        {
                            <option value="@turma.Id">@turma.Nome</option>
                        }
                    </select>
                </div>

                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Turma</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var aluno in AlunosFiltrados)
                        {
                            <tr>
                                <td>@aluno.Email</td>
                                <td>@aluno.Turma?.Nome</td>
                                <td>
                                    <!-- BOTÃO CORRIGIDO -->
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm"
                                            style="font-weight:500;"
                                            @onclick='() => Nav.NavigateTo("/professor/FichaAluno/" + aluno.Id)'>
                                        Ver Ficha
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- AÇÕES -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">

                <!-- BOTÃO CRIAR TRABALHO MELHORADO -->
                <button class="btn btn-primary w-100 mb-3 rounded-pill shadow-sm"
                        style="font-weight:600;"
                        @onclick="CriarTrabalho">
                    Criar Trabalho
                </button>

                <!-- BOTÃO RELATÓRIOS -->
                <button class="btn btn-outline-dark w-100 rounded-pill shadow-sm"
                        style="font-weight:500;"
                        @onclick="IrParaRelatorios">
                    Ver Relatórios
                </button>

            </div>
        </div>
    </div>
}

@code {
    private List<Aluno> Alunos = new();
    private List<Aluno> AlunosFiltrados = new();
    private List<Turma> Turmas = new();
    private bool IsLoading = true;
    private int TurmaSelecionadaId = 0;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var professor = await ProfessorService.GetProfessorByUserIdAsync(userId!);

        if (professor != null)
        {
            Turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);

            var turmaIds = Turmas.Select(t => t.Id).ToList();

            Alunos = (await AlunoService.GetAlunosAsync())
                .Where(a => a.TurmaId != null && turmaIds.Contains(a.TurmaId.Value))
                .ToList();

            AlunosFiltrados = Alunos;
        }

        IsLoading = false;
    }

    private void FiltrarTurma(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();

        if (string.IsNullOrEmpty(val))
        {
            AlunosFiltrados = Alunos;
            TurmaSelecionadaId = 0;
        }
        else if (int.TryParse(val, out int id))
        {
            TurmaSelecionadaId = id;
            AlunosFiltrados = Alunos.Where(a => a.TurmaId == id).ToList();
        }
    }

    private async Task CriarTrabalho()
    {
        if (TurmaSelecionadaId > 0)
            Nav.NavigateTo("/professor/CriarRoteiro/" + TurmaSelecionadaId);
        else
            await JS.InvokeVoidAsync("alert", "Selecione uma turma primeiro");
    }

    private void IrParaRelatorios()
    {
        Nav.NavigateTo("/professor/RelatoriosProfessor");
    }
}