@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Ficha Técnica do Aluno</h2>
        <button class="btn btn-outline-secondary rounded-pill" @onclick="VoltarParaDashboard">
            <i class="bi bi-arrow-left me-2"></i> Voltar
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">A analisar desempenho por módulos...</p>
        </div>
    }
    else if (AlunoSelecionado == null)
    {
        <div class="alert alert-warning">Aluno não encontrado.</div>
    }
    else
    {
        @* Stats Rápidas *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-3 border-bottom border-primary border-4" style="border-radius: 15px;">
                    <h6 class="text-muted small text-uppercase">Média Global</h6>
                    <h4 class="fw-bold mb-0">@CalcularMediaGeral().ToString("F1")</h4>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-3 h-100" style="border-radius: 15px;">
                    <div class="fw-bold">@AlunoSelecionado.Nome</div>
                    <div class="text-muted small">@AlunoSelecionado.Turma?.Nome</div>
                </div>
            </div>
        </div>

        @* TABELA DE MÓDULOS COM LÓGICA DE BLOQUEIO *@
        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px;">
            <h5 class="fw-bold mb-3 text-muted small text-uppercase">Estado de Conclusão e Bloqueios</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Módulo</th>
                            <th>Progresso Horas</th>
                            <th class="text-center">Vertentes (Status)</th>
                            <th class="text-center">Nota Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in PanoramaModulos)
                        {
                            // Verifica se este módulo específico tem alguma vertente crítica
                            var criticas = VertentesAbaixoDaMedia.Where(v => v.ModuloId == m.ModuloId).ToList();
                            bool estaBloqueado = criticas.Any();

                            <tr>
                                <td>
                                    <div class="fw-bold">@m.ModuloNome</div>
                                    <span class="badge bg-light text-dark border">@m.DisciplinaNome</span>
                                </td>
                                <td style="min-width: 150px;">
                                    <div class="d-flex align-items-center">
                                        <span class="me-2 small fw-bold">@m.HorasConsumidas/@m.HorasTotais h</span>
                                        <div class="progress flex-grow-1" style="height: 8px; background-color: #eee;">
                                            <div class="progress-bar @(m.ModuloConcluido ? "bg-success" : "bg-primary")"
                                                 style="width: @(Math.Min(100, m.HorasConsumidas * 100 / m.HorasTotais))%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (estaBloqueado)
                                    {
                                        @foreach (var v in criticas)
                                        {
                                            <button class="btn btn-sm btn-danger mb-1 w-100 py-0"
                                                    style="font-size: 10px;"
                                                    @onclick="() => IniciarPlano(v)">
                                                <i class="bi bi-exclamation-triangle"></i> @v.Tipo (@v.Media.ToString("F1"))
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-success small"><i class="bi bi-check-circle-fill"></i> Conformidade Técnica</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (estaBloqueado)
                                    {
                                        <div class="text-danger" title="Nota Bloqueada: Requer Recuperação">
                                            <i class="bi bi-lock-fill fs-4"></i>
                                            <div class="fw-bold" style="font-size: 9px;">BLOQUEADO</div>
                                        </div>
                                    }
                                    else if (m.ModuloConcluido)
                                    {
                                        <span class="badge bg-success fs-6 shadow-sm">
                                            @m.Media.ToString("F1")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border">@m.Media.ToString("F1") (Em curso)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoSelecionado;
    private List<ModuloAnalise> PanoramaModulos = new();
    private List<VertenteAnalise> VertentesAbaixoDaMedia = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync() => await CarregarFichaCompleta();

    private async Task CarregarFichaCompleta()
    {
        IsLoading = true;
        try
        {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado != null)
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                if (trabalhos != null)
                {
                    ProcessarLogicaTecnica(trabalhos);
                }
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ProcessarLogicaTecnica(List<Trabalho> trabalhos)
    {
        // 1. Agrupamento por ID do Módulo para o Panorama
        PanoramaModulos = trabalhos
            .GroupBy(t => new { t.ModuloId, t.Modulo?.Nome, t.Disciplina?.Nome, t.Modulo?.TotalHoras })
            .Select(g => new ModuloAnalise
            {
                ModuloId = g.Key.ModuloId ?? 0,
                ModuloNome = g.Key.Nome ?? "Módulo Geral",
                DisciplinaNome = g.Key.Nome ?? "N/A",
                HorasTotais = g.Key.TotalHoras ?? 25,
                HorasConsumidas = g.Sum(x => x.HorasAtribuidas), // Soma as horas reais de cada trabalho
                Media = g.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                         .Where(v => v.Nota.HasValue)
                         .Select(v => (double)v.Nota!)
                         .DefaultIfEmpty(0).Average()
            }).ToList();

        // 2. Identificação de Vertentes Críticas (Média < 9.5) agrupadas por Módulo
        VertentesAbaixoDaMedia = trabalhos
            .SelectMany(t => (t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                .Select(v => new { v, t.ModuloId, t.Disciplina?.Nome }))
            .GroupBy(x => new { x.v.Tipo, x.ModuloId, x.Nome })
            .Select(g => new VertenteAnalise
            {
                Tipo = g.Key.Tipo ?? "Geral",
                ModuloId = g.Key.ModuloId ?? 0,
                DisciplinaNome = g.Key.Nome ?? "N/A",
                Media = g.Where(x => x.v.Nota.HasValue)
                         .Select(x => (double)x.v.Nota!)
                         .DefaultIfEmpty(0).Average(),
                TemNotas = g.Any(x => x.v.Nota.HasValue)
            })
            .Where(v => v.TemNotas && v.Media < 9.5)
            .ToList();
    }

    private double CalcularMediaGeral()
    {
        return PanoramaModulos.Any() ? PanoramaModulos.Average(m => m.Media) : 0;
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");

    private void IniciarPlano(VertenteAnalise v)
    {
        // Navega para a página de criação já com o Aluno e Módulo pré-selecionados
        // Ou abre o seu Modal de recuperação aqui
    }

    public class ModuloAnalise
    {
        public int ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public double Media { get; set; }
        public bool ModuloConcluido => HorasConsumidas >= HorasTotais;
    }

    public class VertenteAnalise
    {
        public string Tipo { get; set; } = "";
        public int ModuloId { get; set; }
        public string DisciplinaNome { get; set; } = "";
        public double Media { get; set; }
        public bool TemNotas { get; set; }
    }
}