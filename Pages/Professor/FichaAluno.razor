@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    @* Animação para o botão de recuperação crítica *@
    @@keyframes pulse-red {
        0%

    {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
    }

    70% {
        transform: scale(1);
        box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
    }

    100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }

    }

    .btn-recuperar-urgente {
        animation: pulse-red 2s infinite;
    }

    .modal-backdrop {
        opacity: 0.5;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0">Ficha Técnica: @(AlunoSelecionado?.Nome ?? "Carregando...")</h2>
            <p class="text-muted small">Gestão de Progressão e Planos de Recuperação</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success rounded-pill px-4" @onclick="IrParaAvaliacao">Avaliar Aluno</button>
            <button class="btn btn-secondary rounded-pill" @onclick="VoltarParaDashboard">Voltar</button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        @* SEÇÃO DE ALERTAS CRÍTICOS *@
        @if (VertentesCriticas.Any())
        {
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-body">
                    <h5 class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Atenção: Vertentes Críticas</h5>
                    <div class="row g-3">
                        @foreach (var crit in VertentesCriticas)
                        {
                            <div class="col-md-4">
                                <div class="p-3 border rounded bg-white shadow-sm">
                                    <div class="small text-muted text-uppercase fw-bold">@crit.ModuloNome</div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="badge bg-danger">@crit.TipoVertente: @crit.Nota.ToString("F1")</span>
                                        <button class="btn btn-sm btn-danger btn-recuperar-urgente" @onclick="() => AbrirPainelRecuperacao(crit)">Recuperar</button>
                                    </div>
                                    <div class="mt-1 text-muted" style="font-size: 10px;">Origem: @crit.TrabalhoTitulo</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* TABELA DE PROGRESSO POR MÓDULO *@
        <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Módulo / Disciplina</th>
                        <th>Carga Horária (Progresso)</th>
                        <th>Total de Vertentes</th>
                        <th class="text-center">Estado / Média Global</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in PanoramaModulos)
                    {
                        bool trancado = VertentesCriticas.Any(vc => vc.ModuloId == m.ModuloId);
                        <tr>
                            <td>
                                <div class="fw-bold">@m.ModuloNome</div>
                                <div class="text-muted small">@m.DisciplinaNome</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="me-2 small fw-bold">@m.HorasConsumidas / @m.HorasTotais h</span>
                                    <div class="progress flex-grow-1" style="height: 8px;">
                                        <div class="progress-bar @(m.HorasConsumidas >= m.HorasTotais ? "bg-success" : "bg-primary")"
                                             style="width: @(m.CalcularPercentualHoras())%"></div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@m.TotalVertentesAvaleadas Vertentes</span></td>
                            <td class="text-center">
                                @if (trancado)
                                {
                                    <div class="text-danger">
                                        <i class="bi bi-lock-fill fs-4"></i>
                                        <div class="fw-bold small">TRANCADO</div>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge @(m.MediaModulo >= 9.5m ? "bg-success" : "bg-warning text-dark") fs-6">
                                        @m.MediaModulo.ToString("F1")
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* MODAL DE CRIAÇÃO DO PLANO DE RECUPERAÇÃO *@
@if (MostrarModalRecuperacao)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Criar Plano de Recuperação</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => MostrarModalRecuperacao = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small">
                        Este plano será atribuído ao aluno para recuperar a vertente <strong>@CriticaParaRecuperar?.TipoVertente</strong> do módulo <strong>@CriticaParaRecuperar?.ModuloNome</strong>.
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Título do Trabalho</label>
                        <input type="text" class="form-control" @bind="TituloRecuperacao" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Instruções de Recuperação</label>
                        <textarea class="form-control" rows="4" @bind="DescricaoRecuperacao" placeholder="Descreva o que o aluno deve realizar para obter aproveitamento..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" @onclick="() => MostrarModalRecuperacao = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarCriacaoRecuperacao" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Atribuir Recuperação
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoSelecionado;
    private List<ModuloAnalise> PanoramaModulos = new();
    private List<CriticaModel> VertentesCriticas = new();
    private bool IsLoading = true;
    private bool IsSaving = false;

    private bool MostrarModalRecuperacao = false;
    private CriticaModel? CriticaParaRecuperar;
    private string TituloRecuperacao = "";
    private string DescricaoRecuperacao = "";

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        try
        {
            IsLoading = true;
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado?.UserId != null)
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                ProcessarDados(trabalhos ?? new List<Trabalho>());
            }
        }
        catch (Exception ex) { Console.WriteLine($"Erro ao carregar dados: {ex.Message}"); }
        finally { IsLoading = false; }
    }

    private void ProcessarDados(List<Trabalho> trabalhos)
    {
        VertentesCriticas.Clear();
        PanoramaModulos.Clear();

        foreach (var t in trabalhos)
        {
            if (t.TrabalhoVertentes == null) continue;
            foreach (var v in t.TrabalhoVertentes.Where(x => x.Nota.HasValue && x.Nota < 9.5m))
            {
                VertentesCriticas.Add(new CriticaModel
                {
                    ModuloId = t.ModuloId ?? 0,
                    ModuloNome = t.Modulo?.Nome ?? "N/A",
                    TrabalhoTitulo = t.Titulo ?? "Sem Título",
                    TipoVertente = v.Tipo ?? "Geral",
                    Nota = v.Nota.Value,
                    TrabalhoOriginalId = t.Id,
                    DisciplinaId = t.DisciplinaId ?? 0
                });
            }
        }

        PanoramaModulos = trabalhos
            .GroupBy(t => new { ModId = t.ModuloId ?? 0, Nome = t.Modulo?.Nome ?? "Módulo" })
            .Select(g =>
            {
                var notas = g.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                             .Where(v => v.Nota.HasValue)
                             .Select(v => v.Nota!.Value).ToList();
                return new ModuloAnalise
                {
                    ModuloId = g.Key.ModId,
                    ModuloNome = g.Key.Nome,
                    DisciplinaNome = g.FirstOrDefault()?.Disciplina?.Nome ?? "N/A",
                    HorasTotais = g.FirstOrDefault()?.Modulo?.TotalHoras ?? 0,
                    HorasConsumidas = g.Sum(x => x.HorasAtribuidas),
                    TotalVertentesAvaleadas = notas.Count,
                    MediaModulo = notas.Any() ? notas.Average() : 0m
                };
            }).ToList();
    }

    private void AbrirPainelRecuperacao(CriticaModel crit)
    {
        CriticaParaRecuperar = crit;
        TituloRecuperacao = $"PLANO DE RECUPERAÇÃO: {crit.ModuloNome}";
        DescricaoRecuperacao = "";
        MostrarModalRecuperacao = true;
    }

    private async Task ConfirmarCriacaoRecuperacao()
    {
        if (CriticaParaRecuperar == null || string.IsNullOrWhiteSpace(DescricaoRecuperacao)) return;

        try
        {
            IsSaving = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var professorId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            var novoTrabalho = new Trabalho
            {
                Titulo = TituloRecuperacao,
                ConteudoTexto = DescricaoRecuperacao,
                AlunoId = AlunoSelecionado!.UserId,
                ProfessorId = professorId,
                ModuloId = CriticaParaRecuperar.ModuloId,
                DisciplinaId = CriticaParaRecuperar.DisciplinaId,
                DataCriacao = DateTime.UtcNow,
                PrazoEntrega = DateTime.UtcNow.AddDays(7),
                IsPlanoRecuperacao = true,
                HorasAtribuidas = 0,
                Status = "Pendente",
                Ativo = true
            };

            int novoId = await TrabalhoService.AddTrabalhoAsync(novoTrabalho);

            await TrabalhoService.AddVertenteAsync(new TrabalhoVertente
            {
                TrabalhoId = novoId,
                Tipo = CriticaParaRecuperar.TipoVertente,
                ConteudoTexto = "Avaliação resultante do plano de recuperação."
            });

            // Feedback e Atualização da UI
            await JS.InvokeVoidAsync("alert", "Plano de recuperação atribuído com sucesso!");

            MostrarModalRecuperacao = false;
            TituloRecuperacao = "";
            DescricaoRecuperacao = "";

            // Recarrega os dados da ficha para refletir as mudanças imediatamente
            await CarregarDados();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao salvar: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Erro ao processar a solicitação.");
        }
        finally { IsSaving = false; }
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");
    private void IrParaAvaliacao() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}");

    public class ModuloAnalise
    {
        public int ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public int TotalVertentesAvaleadas { get; set; }
        public decimal MediaModulo { get; set; }
        public double CalcularPercentualHoras() => HorasTotais > 0 ? Math.Min(100.0, (double)(HorasConsumidas * 100) / HorasTotais) : 0;
    }

    public class CriticaModel
    {
        public int ModuloId { get; set; }
        public int DisciplinaId { get; set; }
        public int TrabalhoOriginalId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string TrabalhoTitulo { get; set; } = "";
        public string TipoVertente { get; set; } = "";
        public decimal Nota { get; set; }
    }
}