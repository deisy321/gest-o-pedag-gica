@page "/professor/AvaliarAlunos/{AlunoId:int}"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService

<h3>Avaliar Aluno</h3>

@if (IsLoading)
{
    <div class="spinner-border text-primary"></div>
}
else if (AlunoAtual == null)
{
    <div class="alert alert-danger">Aluno não encontrado</div>
}
else if (!Trabalhos.Any())
{
    <div class="alert alert-warning">Aluno ainda não enviou trabalhos</div>
}
else
{
    <div class="card mb-3 p-3">
        <strong>@AlunoAtual.Email</strong><br />
        Turma: @(AlunoAtual.Turma?.Nome ?? "Sem turma")
    </div>

    @foreach (var trabalho in Trabalhos)
    {
        <div class="card mb-3 p-2">
            <strong>@trabalho.Titulo</strong>
            @foreach (var vertente in trabalho.TrabalhoVertentes)
            {
                <div class="border p-2 mt-2">
                    <strong>Vertente:</strong> @vertente.Tipo
                    <p>@vertente.ConteudoTextoAluno</p>

                    @if (vertente.FicheiroBytes != null)
                    {
                        <p>
                            Ficheiro:
                            <button class="btn btn-link p-0"
                                    @onclick="() => AbrirModal(vertente.Id, vertente.FicheiroNome, vertente.FicheiroContentType)">
                                @vertente.FicheiroNome
                            </button>
                            <a class="ms-2 btn btn-sm btn-outline-secondary"
                               href="@($"/ficheiro/vertente/{vertente.Id}")"
                               target="_blank">
                                Download
                            </a>
                        </p>
                    }

                    <table class="table">
                        <tr>
                            <td>Nota</td>
                            <td>
                                <input type="number" class="form-control"
                                       @bind-value="vertente.Nota"
                                       @bind-value:event="oninput"
                                       min="0" max="20" />
                            </td>
                        </tr>
                        <tr>
                            <td>Feedback</td>
                            <td>
                                <textarea class="form-control"
                                          @bind-value="vertente.Feedback"
                                          @bind-value:event="oninput"></textarea>
                            </td>
                        </tr>
                    </table>

                    <button class="btn btn-success mb-2"
                            @onclick="() => SalvarVertente(vertente)">
                        Salvar Avaliação
                    </button>

                    @if (FoiSalvo(vertente.Id))
                    {
                        <span class="text-success ms-2">Avaliação salva!</span>
                    }
                </div>
            }
        </div>
    }
}

@if (ModalAberto)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@FicheiroNomeModal</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body text-center">
                    @if (!string.IsNullOrEmpty(ModalContentTypeModal) && ModalContentTypeModal.StartsWith("image/"))
                    {
                        <img src="@ModalUrl" class="img-fluid" />
                    }
                    else if (ModalContentTypeModal == "application/pdf")
                    {
                        <iframe src="@ModalUrl" style="width:100%; height:600px;" frameborder="0"></iframe>
                    }
                    else
                    {
                        <p>Não é possível visualizar este ficheiro aqui. Use o botão de download.</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }

    private Aluno? AlunoAtual;
    private List<Trabalho> Trabalhos = new();
    private bool IsLoading = true;

    private bool ModalAberto = false;
    private string ModalUrl = "";
    private string ModalContentTypeModal = "";
    private string FicheiroNomeModal = "";

    // Dicionário para rastrear vertentes salvas
    private Dictionary<int, bool> VertentesSalvas = new();

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        AlunoAtual = await AlunoService.GetAlunoByIdAsync(AlunoId);

        if (AlunoAtual != null && !string.IsNullOrEmpty(AlunoAtual.UserId))
        {
            Trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoAtual.UserId);
        }

        IsLoading = false;
    }

    private async Task SalvarVertente(TrabalhoVertente vertente)
    {
        if (vertente == null) return;

        await TrabalhoService.AtualizarVertenteAsync(vertente);

        // marca como salva no dicionário
        VertentesSalvas[vertente.Id] = true;

        StateHasChanged();
    }

    private bool FoiSalvo(int vertenteId)
    {
        return VertentesSalvas.ContainsKey(vertenteId) && VertentesSalvas[vertenteId];
    }

    private void AbrirModal(int vertenteId, string nome, string contentType)
    {
        ModalAberto = true;
        FicheiroNomeModal = nome;
        ModalContentTypeModal = contentType ?? "application/octet-stream";
        ModalUrl = $"/ficheiro/vertente/{vertenteId}";
    }

    private void FecharModal()
    {
        ModalAberto = false;
        ModalUrl = "";
        ModalContentTypeModal = "";
        FicheiroNomeModal = "";
    }
}