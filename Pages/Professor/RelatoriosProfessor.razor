@page "/professor/RelatoriosProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.Security.Claims
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<h3>Relatórios do Professor</h3>

<div class="row">
    <div class="col-md-12">
        <div class="card p-3 shadow-sm">
            <h5 class="mb-4">Comparação de Desempenho por Turma</h5>

            @if (Labels == null || !Labels.Any())
            {
                <div class="alert alert-info">A carregar dados ou sem avaliações disponíveis...</div>
            }

            <div style="position: relative; height:400px; width:100%">
                <canvas id="chartTurmas"></canvas>
            </div>
        </div>
    </div>
</div>

@code {
    private List<string> Labels = new();
    private List<double> Medias = new();
    private bool initialized = false;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(userId)) return;

        var professor = await ProfessorService.GetProfessorByUserIdAsync(userId);
        if (professor == null) return;

        var turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);
        var trabalhos = await TrabalhoService.GetTodosTrabalhosComNotasAsync();

        var dados = turmas.Select(turma =>
        {
            var notas = trabalhos
                .Where(t => t.TurmaId == turma.Id)
                .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                .Where(v => v.Nota.HasValue)
                .Select(v => (double)v.Nota!.Value)
                .ToList();

            return new
            {
                Nome = turma.Nome,
                Media = notas.Any() ? Math.Round(notas.Average(), 2) : 0
            };
        })
        .OrderByDescending(x => x.Media)
        .ToList();

        Labels = dados.Select(d => d.Nome).ToList();
        Medias = dados.Select(d => d.Media).ToList();
        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Só renderiza o gráfico se já tivermos dados e o componente estiver pronto
        if (initialized && Labels.Any())
        {
            var colors = Labels.Select(_ => "#4e73df").ToArray();

            await JS.InvokeVoidAsync(
                "site.renderBarChart",
                "chartTurmas",
                Labels.ToArray(),
                Medias.ToArray(),
                colors
            );

            // Marcamos como falso para não renderizar em loop a cada atualização de UI
            initialized = false;
        }
    }
}