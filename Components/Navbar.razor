@namespace gestaopedagogica.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Antiforgery
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark custom-navbar fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <img src="/images/logo_triadelearn.png" alt="Logo" />
            <span>TriadeLearn</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="navbar-nav">
                <AuthorizeView>
                    <Authorized>
                        <a href="/Conta" class="user-profile-btn">
                            <div class="avatar-circle">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="d-flex flex-column" style="line-height: 1.1;">
                                <span style="font-size: 0.7rem; opacity: 0.85;">Conta</span>
                                <span style="font-size: 0.8rem; font-weight: 700;">@context.User.Identity?.Name?.Split('@')[0]</span>
                            </div>
                        </a>

                        <form method="post" action="Identity/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button type="submit" class="btn-logout-custom">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Sair</span>
                            </button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>