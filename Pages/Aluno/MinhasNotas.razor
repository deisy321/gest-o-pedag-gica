@page "/aluno/MinhasNotas"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject TrabalhoService TrabalhoService

<div class="container mt-4">
    <h3 class="fw-bold mb-4">O Meu Desempenho</h3>

    @if (DisciplinasAgrupadas != null && DisciplinasAgrupadas.Any())
    {
        @foreach (var disciplina in DisciplinasAgrupadas)
        {
            <div class="mb-5">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary rounded-circle me-2" style="width: 12px; height: 12px;"></div>
                    <h4 class="fw-bold m-0 text-dark">@disciplina.Key</h4>
                    <span class="badge bg-dark ms-3 shadow-sm">Média Global: @disciplina.MediaFinalDisciplina.ToString("F1")</span>
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </div>

                <div class="row">
                    @foreach (var modulo in disciplina.Modulos)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card shadow-sm border-0 @(modulo.EstaBloqueado ? "border-start border-danger border-5" : (modulo.Concluido ? "border-start border-success border-5" : "border-start border-primary border-5"))" style="border-radius: 12px;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-start mb-2">
                                        <div>
                                            <h5 class="fw-bold mb-0">@modulo.ModuloNome</h5>
                                            <small class="text-muted">@modulo.HorasTotais h totais</small>
                                        </div>
                                        <div class="text-end">
                                            @if (modulo.EstaBloqueado)
                                            {
                                                <div class="text-danger">
                                                    <i class="bi bi-lock-fill fs-5"></i>
                                                    <span class="d-block fw-bold" style="font-size: 0.7rem;">RETIDO</span>
                                                </div>
                                            }
                                            else if (modulo.Concluido)
                                            {
                                                <span class="badge bg-success fs-6 shadow-sm">Nota Final: @modulo.Media.ToString("F1")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Em Curso / Pendente</span>
                                            }
                                        </div>
                                    </div>

                                    @if (modulo.VertentesCriticas.Any())
                                    {
                                        <div class="alert alert-danger py-1 px-2 mb-2" style="font-size: 0.8rem;">
                                            <i class="bi bi-exclamation-circle me-1"></i>
                                            Recuperação necessária: <strong>@string.Join(", ", modulo.VertentesCriticas)</strong>
                                        </div>
                                    }

                                    <div class="mt-3">
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>Progresso: @modulo.HorasAtuais / @modulo.HorasTotais h</span>
                                            <span>@(modulo.HorasTotais > 0 ? (modulo.HorasAtuais * 100 / modulo.HorasTotais) : 0)%</span>
                                        </div>
                                        <div class="progress" style="height: 8px; border-radius: 4px; background-color: #e9ecef;">
                                            <div class="progress-bar @(modulo.EstaBloqueado ? "bg-warning" : (modulo.Concluido ? "bg-success" : "bg-primary"))"
                                                 role="progressbar"
                                                 style="width: @(modulo.HorasTotais > 0 ? Math.Min(100, (modulo.HorasAtuais * 100 / modulo.HorasTotais)) : 0)%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center p-5 text-muted">
            <i class="bi bi-folder-x fs-1"></i>
            <p>Nenhum registo encontrado.</p>
        </div>
    }
</div>

@code {
    private List<Trabalho> trabalhos = new();
    private List<DisciplinaAgrupada> DisciplinasAgrupadas = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(userId);
            ProcessarResumoPorDisciplina();
        }
    }

    private void ProcessarResumoPorDisciplina()
    {
        if (trabalhos == null || !trabalhos.Any()) return;

        DisciplinasAgrupadas = trabalhos
            .GroupBy(t => t.Disciplina?.Nome ?? "Outros")
            .Select(gd =>
            {
                var modulos = gd.GroupBy(m => new { m.ModuloId, Nome = m.Modulo?.Nome ?? "Geral", Horas = m.Modulo?.TotalHoras ?? 25 })
                .Select(g =>
                {
                    var listaTrabalhosModulo = g.ToList();

                    // LÓGICA IDÊNTICA À DA FICHA TÉCNICA
                    double ObterNotaFinalVertente(string termo)
                    {
                        termo = termo.ToLower();

                        // 1. Prioridade para Recuperação
                        var notaRec = listaTrabalhosModulo
                            .Where(t => t.Titulo != null && t.Titulo.ToLower().Contains("recuper"))
                            .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                            .Where(v => v.Tipo != null && v.Tipo.ToLower().Contains(termo.Substring(0, 4)) && v.Nota.HasValue)
                            .OrderByDescending(v => v.Id)
                            .Select(v => (double?)v.Nota)
                            .FirstOrDefault();

                        if (notaRec.HasValue) return notaRec.Value;

                        // 2. Média dos trabalhos normais
                        var notasNormais = listaTrabalhosModulo
                            .Where(t => t.Titulo == null || !t.Titulo.ToLower().Contains("recuper"))
                            .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                            .Where(v => v.Tipo != null && v.Tipo.ToLower().Contains(termo.Substring(0, 4)) && v.Nota.HasValue)
                            .Select(v => (double)v.Nota!)
                            .ToList();

                        return notasNormais.Any() ? notasNormais.Average() : 0;
                    }

                    double mComp = ObterNotaFinalVertente("comp");
                    double mConh = ObterNotaFinalVertente("conh");
                    double mApt = ObterNotaFinalVertente("apti");

                    var criticas = new List<string>();
                    if (mComp > 0 && mComp < 9.5) criticas.Add("Competência");
                    if (mConh > 0 && mConh < 9.5) criticas.Add("Conhecimento");
                    if (mApt > 0 && mApt < 9.5) criticas.Add("Aptidão");

                    return new ModuloResumo
                    {
                        ModuloNome = g.Key.Nome,
                        HorasTotais = g.Key.Horas,
                        HorasAtuais = g.Sum(t => t.HorasAtribuidas),
                        Media = (mComp + mConh + mApt) / 3,
                        VertentesCriticas = criticas
                    };
                }).ToList();

                return new DisciplinaAgrupada
                {
                    Key = gd.Key,
                    Modulos = modulos
                };
            })
            .OrderBy(d => d.Key)
            .ToList();
    }

    public class DisciplinaAgrupada
    {
        public string Key { get; set; } = "";
        public List<ModuloResumo> Modulos { get; set; } = new();
        public double MediaFinalDisciplina => Modulos.Any(m => m.Media > 0) ? Modulos.Where(m => m.Media > 0).Average(m => m.Media) : 0;
    }

    public class ModuloResumo
    {
        public string ModuloNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasAtuais { get; set; }
        public double Media { get; set; }
        public List<string> VertentesCriticas { get; set; } = new();
        public bool EstaBloqueado => VertentesCriticas.Any();
        public bool Concluido => HorasAtuais >= HorasTotais && !EstaBloqueado && Media >= 9.5;
    }
}