@page "/admin/CriarDisciplina"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject DisciplinaService DisciplinaService
@inject NavigationManager Nav
@layout MainLayout

<div class="page-admin">
    <!-- Cabeçalho -->
    <div class="admin-header-row">
        <div>
            <h1 class="page-title">Nova Disciplina</h1>
 <p class="page-subtitle">Preencha os dados para registar uma nova disciplina</p>
    </div>
        <a href="/admin/GerirDisciplinas" class="btn btn-custom btn-custom-outline">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- Card Formulário -->
    <div class="custom-card elevation-2" style="max-width: 600px; margin: 0 auto;">
     <div class="card-body-custom">
            <EditForm Model="novaDisciplina" OnValidSubmit="SalvarDisciplina">
   <DataAnnotationsValidator />

           <!-- Nome da Disciplina -->
     <div class="form-group">
   <label class="form-label">
       <i class="bi bi-journal-text"></i> Nome da Disciplina
         </label>
     <InputText @bind-Value="novaDisciplina.Nome" 
   class="form-control" 
  placeholder="Ex: Programação de Sistemas" />
     <ValidationMessage For="@(() => novaDisciplina.Nome)" class="text-danger small mt-1" />
        </div>

     <!-- Seleção de Curso -->
       <div class="form-group">
   <label class="form-label">
          <i class="bi bi-book"></i> Curso Associado
           </label>
           <InputSelect @bind-Value="novaDisciplina.CursoId" class="form-select">
 <option value="0">Escolha o curso...</option>
               @if (ListaCursos != null)
    {
          @foreach (var curso in ListaCursos)
  {
   <option value="@curso.Id">@curso.Nome</option>
   }
     }
    </InputSelect>
         </div>

     <!-- Mensagem de Erro -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
      {
     <div class="alert-custom alert-danger">
    <i class="bi bi-exclamation-triangle-fill"></i>
     <div>@ErrorMessage</div>
  </div>
     }

   <!-- Botões Ação -->
         <div class="d-flex gap-2" style="margin-top: 2rem; flex-wrap: wrap;">
        <a href="/admin/GerirDisciplinas" class="btn btn-custom btn-custom-outline" style="flex: 1;">
         <i class="bi bi-x"></i> Cancelar
      </a>
        <button type="submit" class="btn btn-custom btn-custom-success" style="flex: 1;">
        <i class="bi bi-check2"></i> Criar Disciplina
           </button>
               </div>
            </EditForm>
        </div>
</div>
</div>

@code {
    private Disciplina novaDisciplina = new Disciplina();
    private List<Curso> ListaCursos = new();
    private string ErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
    {
      ListaCursos = await DisciplinaService.GetCursosAsync();
        }
     catch (Exception ex)
        {
      ErrorMessage = "Erro ao carregar cursos: " + ex.Message;
        }
    }

    private async Task SalvarDisciplina()
    {
        ErrorMessage = "";

        if (novaDisciplina.CursoId == 0)
      {
            ErrorMessage = "Por favor, selecione um curso para continuar.";
        return;
        }

        if (string.IsNullOrWhiteSpace(novaDisciplina.Nome))
        {
   ErrorMessage = "O nome da disciplina é obrigatório.";
            return;
        }

  try
        {
          await DisciplinaService.AddDisciplinaAsync(novaDisciplina);
            Nav.NavigateTo("/admin/GerirDisciplinas");
        }
  catch (Exception ex)
        {
  ErrorMessage = "Erro ao salvar: " + ex.Message;
        }
    }
}
