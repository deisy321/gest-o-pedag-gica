@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject NavigationManager Nav

<h2 class="fw-bold mb-4">Ficha do Aluno</h2>

@if (IsLoading)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else if (AlunoSelecionado == null)
{
    <div class="alert alert-warning">Aluno não encontrado.</div>
}
else
{
    <!-- INFO BÁSICA -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white p-3" style="border-radius: 15px;">
                <h6>Nome</h6>
                <h5 class="fw-bold">@AlunoSelecionado.Nome</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-info text-white p-3" style="border-radius: 15px;">
                <h6>Email</h6>
                <h5 class="fw-bold">@AlunoSelecionado.Email</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white p-3" style="border-radius: 15px;">
                <h6>Turma</h6>
                <h5 class="fw-bold">@AlunoSelecionado.Turma?.Nome ?? "Sem turma"</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-warning text-dark p-3" style="border-radius: 15px;">
                <h6>Total de Trabalhos</h6>
                <h5 class="fw-bold">@TrabalhosAluno.Count</h5>
            </div>
        </div>
    </div>

    <!-- MÉTRICAS DE DESEMPENHO -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px; background:#f0f8ff;">
                <h6>Trabalhos Entregues</h6>
                <h5 class="fw-bold">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Enviado))</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px; background:#fff3cd;">
                <h6>Trabalhos Pendentes</h6>
                <h5 class="fw-bold">@TrabalhosAluno.Count(t => t.Vertentes.All(v => !v.Enviado))</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px; background:#d4edda;">
                <h6>Trabalhos Corrigidos</h6>
                <h5 class="fw-bold">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue))</h5>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px; background:#e2e3e5;">
                <h6>Média de Notas</h6>
                <h5 class="fw-bold">@((TrabalhosAluno.SelectMany(t => t.Vertentes).Where(v => v.Nota.HasValue).Select(v => v.Nota.Value).DefaultIfEmpty(0).Average()).ToString("0.##"))</h5>
            </div>
        </div>
    </div>

    <!-- BOTÕES DE AÇÃO -->
    <div class="d-flex justify-content-end mb-4 gap-2">
        <button class="btn btn-success rounded-pill px-4"
                @onclick='() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoSelecionado.Id}")'>
            Avaliar Aluno
        </button>
        <button class="btn btn-secondary rounded-pill px-4"
                @onclick="VoltarParaDashboard">
            <i class="bi bi-arrow-left me-2"></i> Voltar
        </button>
    </div>

    <!-- RESUMO DE DESEMPENHO GRÁFICO (OPCIONAL) -->
    <div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
        <h5 class="fw-bold mb-4">Progresso do Aluno</h5>
        <div class="progress mb-2" style="height:25px; border-radius:12px;">
            <div class="progress-bar bg-success" role="progressbar"
                 style="width: @(TrabalhosAluno.Count > 0 ? (TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue)) * 100 / TrabalhosAluno.Count) : 0)%"
                 aria-valuenow="@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue))"
                 aria-valuemin="0" aria-valuemax="@TrabalhosAluno.Count">
                @((TrabalhosAluno.Count > 0 ? (TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue)) * 100 / TrabalhosAluno.Count) : 0))%
            </div>
        </div>
        <small class="text-muted">Percentual de trabalhos corrigidos</small>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }

    private Aluno? AlunoSelecionado;
    private List<TrabalhoAluno> TrabalhosAluno = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;

        try
        {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);

            if (AlunoSelecionado != null && !string.IsNullOrEmpty(AlunoSelecionado.UserId))
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);

                TrabalhosAluno = trabalhos?.Select(t => new TrabalhoAluno
                {
                    TrabalhoId = t.Id,
                    Titulo = t.Titulo,
                    AlunoNome = AlunoSelecionado.Nome,
                    AlunoEmail = AlunoSelecionado.Email,
                    ModuloNome = t.Modulo?.Nome ?? "Módulo não definido",
                    DisciplinaNome = t.Disciplina?.Nome ?? "Disciplina não definida",
                    Vertentes = t.TrabalhoVertentes?.Select(v => new VertenteStatus
                    {
                        Tipo = v.Tipo,
                        Conteudo = v.ConteudoTextoAluno ?? "",
                        Enviado = !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null,
                        Nota = v.Nota,
                        Feedback = v.Feedback
                    }).ToList() ?? new List<VertenteStatus>()
                }).ToList() ?? new List<TrabalhoAluno>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar dados: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/dashboard");

    public class TrabalhoAluno
    {
        public int TrabalhoId { get; set; }
        public string Titulo { get; set; } = "";
        public string AlunoNome { get; set; } = "";
        public string AlunoEmail { get; set; } = "";
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public List<VertenteStatus> Vertentes { get; set; } = new();
    }

    public class VertenteStatus
    {
        public string Tipo { get; set; } = "";
        public string Conteudo { get; set; } = "";
        public bool Enviado { get; set; }
        public decimal? Nota { get; set; }
        public string Feedback { get; set; } = "";
    }
}