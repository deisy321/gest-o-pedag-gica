@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<style>
    /* Correção do erro de keyframes: usamos @@ para o Razor ignorar */
    @@keyframes pulse-red {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }

    .btn-recuperar-urgente {
        animation: pulse-red 2s infinite;
    }
    
    .text-gradient {
        background: linear-gradient(45deg, #1a73e8, #0d47a1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0">Ficha Técnica do Aluno</h2>
            <p class="text-muted small">Análise de conformidade e desempenho por módulos</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success rounded-pill px-4 shadow-sm" @onclick="IrParaAvaliacao">
                <i class="bi bi-pencil-square me-2"></i>Avaliar Aluno
            </button>

            <button class="btn btn-secondary rounded-pill shadow-sm" @onclick="VoltarParaDashboard">
                <i class="bi bi-arrow-left me-2"></i> Voltar
            </button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">A analisar desempenho por módulos...</p>
        </div>
    }
    else if (AlunoSelecionado == null)
    {
        <div class="alert alert-warning">Aluno não encontrado.</div>
    }
    else
    {
        <!-- CARDS DE IDENTIFICAÇÃO -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-3 border-bottom border-primary border-4 h-100" style="border-radius: 15px;">
                    <h6 class="text-muted small text-uppercase fw-bold">Média Global do Aluno</h6>
                    <h4 class="fw-bold mb-0">@CalcularMediaGeral().ToString("F1")</h4>
                    <small class="text-muted">Apenas módulos concluídos</small>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-3 h-100 d-flex flex-row align-items-center" style="border-radius: 15px;">
                    <div class="bg-light rounded-circle p-3 me-3">
                        <i class="bi bi-person-badge fs-3 text-primary"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-5 text-gradient">@AlunoSelecionado.Nome</div>
                        <div class="text-muted small">
                            <i class="bi bi-mortarboard me-1"></i> @(AlunoSelecionado.Turma?.Nome ?? "Sem Turma")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ANÁLISE DE RECUPERAÇÃO (A que aparece na tua imagem) -->
        @if (VertentesAbaixoDaMedia.Any())
        {
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-body p-4">
                    <h5 class="text-danger fw-bold"><i class="bi bi-exclamation-octagon me-2"></i>Análise de Recuperação</h5>
                    <p class="text-muted small">As seguintes vertentes possuem média inferior ou igual a 9.0:</p>
                    
                    <div class="row g-2">
                        @foreach (var v in VertentesAbaixoDaMedia)
                        {
                            <div class="col-md-6">
                                <div class="border rounded p-2 d-flex justify-content-between align-items-center bg-white">
                                    <div class="d-flex align-items-center">
                                        <span class="fw-bold text-uppercase me-2" style="font-size: 0.9rem;">@v.Tipo</span>
                                        <span class="badge bg-danger">@v.Media.ToString("F1")</span>
                                    </div>
                                    <button class="btn btn-danger btn-sm rounded-pill px-3" @onclick="() => AbrirModalRecuperacao(v)">
                                        Criar Plano
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- TABELA DE PROGRESSO DOS MÓDULOS -->
        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px;">
            <h5 class="fw-bold mb-3 text-muted small text-uppercase">Estado de Conclusão e Bloqueios</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Módulo</th>
                            <th>Progresso Horas</th>
                            <th class="text-center">Vertentes Críticas</th>
                            <th class="text-center">Média do Módulo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in PanoramaModulos)
                        {
                            var criticas = VertentesAbaixoDaMedia.Where(v => v.ModuloId == m.ModuloId).ToList();
                            bool estaBloqueado = criticas.Any();

                            <tr>
                                <td>
                                    <div class="fw-bold">@m.ModuloNome</div>
                                    <span class="badge bg-light text-dark border">@m.DisciplinaNome</span>
                                </td>
                                <td style="min-width: 200px;">
                                    <div class="d-flex align-items-center">
                                        <span class="me-2 small fw-bold">@m.HorasConsumidas/@m.HorasTotais h</span>
                                        <div class="progress flex-grow-1" style="height: 10px; border-radius: 10px;">
                                            <div class="progress-bar @(m.ModuloConcluido ? "bg-success" : "bg-primary")"
                                                 style="width: @(m.HorasTotais > 0 ? Math.Min(100, m.HorasConsumidas * 100 / m.HorasTotais) : 0)%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (estaBloqueado)
                                    {
                                        <span class="badge bg-soft-danger text-danger border border-danger">
                                            @criticas.Count Vertente(s) < 9.5
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success small"><i class="bi bi-check-circle-fill"></i> Conforme</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (estaBloqueado)
                                    {
                                        <div class="text-danger" title="Média Bloqueada por Vertente Negativa">
                                            <i class="bi bi-lock-fill fs-5"></i>
                                            <div class="fw-bold" style="font-size: 10px;">BLOQUEADO</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge @(m.ModuloConcluido ? "bg-success" : "bg-light text-muted border") fs-6">
                                            @m.Media.ToString("F1")
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (MostrarModal)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.6); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header bg-danger text-white" style="border-radius: 20px 20px 0 0;">
                    <h5 class="modal-title fw-bold">Novo Plano de Recuperação</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => MostrarModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-3">A criar atividade para recuperar a vertente <strong>@VertenteParaRecuperar?.Tipo</strong> do módulo <strong>@PanoramaModulos.FirstOrDefault(x => x.ModuloId == VertenteParaRecuperar?.ModuloId)?.ModuloNome</strong>.</p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Instruções para o Aluno</label>
                        <textarea class="form-control" rows="3" @bind="InstrucoesRecuperacao" placeholder="O que o aluno deve fazer?"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Data de Entrega</label>
                        <input type="date" class="form-control" @bind="DataLimiteRecuperacao" />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-light rounded-pill px-4" @onclick="() => MostrarModal = false">Cancelar</button>
                    <button class="btn btn-danger rounded-pill px-4" @onclick="GravarPlanoRecuperacao">Confirmar e Criar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoSelecionado;
    private List<ModuloAnalise> PanoramaModulos = new();
    private List<VertenteAnalise> VertentesAbaixoDaMedia = new();
    private bool IsLoading = true;
    private bool MostrarModal = false;
    private VertenteAnalise? VertenteParaRecuperar;
    private string InstrucoesRecuperacao = "";
    private DateTime DataLimiteRecuperacao = DateTime.Now.AddDays(7);

    protected override async Task OnInitializedAsync() => await CarregarFichaCompleta();

    private async Task CarregarFichaCompleta()
    {
        IsLoading = true;
        try {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado?.UserId != null) {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                if (trabalhos != null) ProcessarLogicaTecnica(trabalhos);
            }
        } finally { IsLoading = false; }
    }

    private void ProcessarLogicaTecnica(List<Trabalho> trabalhos)
    {
        // 1. Agrupar por Módulo para ver o panorama geral
        PanoramaModulos = trabalhos
            .GroupBy(t => new { 
                t.ModuloId, 
                NomeModulo = t.Modulo?.Nome ?? "Módulo Indefinido", 
                NomeDisc = t.Disciplina?.Nome ?? "N/A", 
                Horas = t.Modulo?.TotalHoras ?? 25 
            })
            .Select(g => {
                // Calcula a média das vertentes ÚNICAS do módulo (pega a maior nota de cada tipo)
                var vertentesDoModulo = g.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                                         .Where(v => v.Nota.HasValue)
                                         .GroupBy(v => v.Tipo)
                                         .Select(gv => (double)gv.Max(v => v.Nota!.Value))
                                         .ToList();

                return new ModuloAnalise {
                    ModuloId = g.Key.ModuloId ?? 0,
                    ModuloNome = g.Key.NomeModulo,
                    DisciplinaNome = g.Key.NomeDisc,
                    HorasTotais = g.Key.Horas,
                    HorasConsumidas = g.Sum(x => x.HorasAtribuidas),
                    Media = vertentesDoModulo.Any() ? vertentesDoModulo.Average() : 0
                };
            }).ToList();

        // 2. Identificar vertentes críticas (Abaixo de 9.5) para o painel de recuperação
        VertentesAbaixoDaMedia = trabalhos
            .SelectMany(t => (t.TrabalhoVertentes ?? new List<TrabalhoVertente>()).Select(v => new { v, t.ModuloId }))
            .Where(x => x.v.Nota.HasValue)
            .GroupBy(x => new { x.ModuloId, x.v.Tipo })
            .Select(g => new VertenteAnalise {
                ModuloId = g.Key.ModuloId ?? 0,
                Tipo = g.Key.Tipo ?? "Geral",
                Media = (double)g.Max(x => x.v.Nota!.Value)
            })
            .Where(v => v.Media < 9.5)
            .ToList();
    }

    private double CalcularMediaGeral() {
        var concluidos = PanoramaModulos.Where(m => m.ModuloConcluido).ToList();
        return concluidos.Any() ? concluidos.Average(m => m.Media) : 0;
    }

    private void AbrirModalRecuperacao(VertenteAnalise v) {
        VertenteParaRecuperar = v;
        InstrucoesRecuperacao = "";
        MostrarModal = true;
    }

    private async Task GravarPlanoRecuperacao() {
        if (VertenteParaRecuperar == null || AlunoSelecionado == null) return;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var profId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var novoT = new Trabalho {
            Titulo = $"[RECUPERAÇÃO] {VertenteParaRecuperar.Tipo}",
            Descricao = InstrucoesRecuperacao,
            ModuloId = VertenteParaRecuperar.ModuloId,
            AlunoId = AlunoSelecionado.UserId,
            ProfessorId = profId,
            IsPlanoRecuperacao = true,
            Status = "Pendente",
            DataCriacao = DateTime.Now,
            PrazoEntrega = DataLimiteRecuperacao,
            TrabalhoVertentes = new List<TrabalhoVertente> { 
                new TrabalhoVertente { Tipo = VertenteParaRecuperar.Tipo, ConteudoTexto = "Atividade de recuperação" } 
            }
        };

        await TrabalhoService.AddTrabalhoAsync(novoT);
        MostrarModal = false;
        await CarregarFichaCompleta();
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");
    private void IrParaAvaliacao() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}");

    public class ModuloAnalise {
        public int ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public double Media { get; set; }
        public bool ModuloConcluido => HorasConsumidas >= HorasTotais && HorasTotais > 0;
    }

    public class VertenteAnalise {
        public string Tipo { get; set; } = "";
        public int ModuloId { get; set; }
        public double Media { get; set; }
    }
}