@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject ProfessorService ProfessorService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject PushService PushService

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Ficha do Aluno</h2>
        <button class="btn btn-outline-secondary rounded-pill" @onclick="VoltarParaDashboard">
            <i class="bi bi-arrow-left me-2"></i> Voltar ao Painel
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">A analisar dados do aluno...</p>
        </div>
    }
    else if (AlunoSelecionado == null)
    {
        <div class="alert alert-warning shadow-sm">
            <i class="bi bi-exclamation-triangle me-2"></i> Aluno não encontrado ou sem permissões de acesso.
        </div>
    }
    else
    {
        @* Cabeçalho e Stats *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 p-3 d-flex align-items-center justify-content-center h-100"
                     style="border-radius: 15px; cursor:pointer; transition: 0.3s;"
                     @onclick="ToggleDetalhes">
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center mb-2 shadow-sm"
                         style="width:60px; height:60px; border-radius:50%; font-size:24px; font-weight: bold;">
                        @(string.IsNullOrEmpty(AlunoSelecionado.Nome) ? "?" : AlunoSelecionado.Nome.Substring(0, 1).ToUpper())
                    </div>
                    <div class="fw-bold text-center">@AlunoSelecionado.Nome</div>
                    <small class="text-muted">Clique para mais info</small>

                    @if (MostrarDetalhes)
                    {
                        <div class="mt-3 border-top pt-2 text-start w-100 animate__animated animate__fadeIn">
                            <small class="d-block text-truncate"><strong>Email:</strong> @AlunoSelecionado.Email</small>
                            <small class="d-block"><strong>Turma:</strong> @(AlunoSelecionado.Turma?.Nome ?? "Sem turma")</small>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-9">
                <div class="row g-3 h-100">
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100 border-bottom border-primary border-4" style="border-radius: 15px; background:#f0f8ff;">
                            <h6 class="text-muted small text-uppercase">Entregues</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Enviado))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100 border-bottom border-warning border-4" style="border-radius: 15px; background:#fff3cd;">
                            <h6 class="text-muted small text-uppercase">Pendentes</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.All(v => !v.Enviado))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100 border-bottom border-success border-4" style="border-radius: 15px; background:#d4edda;">
                            <h6 class="text-muted small text-uppercase">Corrigidos</h6>
                            <h4 class="fw-bold mb-0">@TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue))</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm border-0 p-3 h-100 border-bottom border-secondary border-4" style="border-radius: 15px; background:#e2e3e5;">
                            <h6 class="text-muted small text-uppercase">Média Geral</h6>
                            <h4 class="fw-bold mb-0">@CalcularMediaGeral().ToString("F1")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Secção de Recuperação *@
        <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius: 15px; border-left: 5px solid #dc3545;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-danger m-0"><i class="bi bi-exclamation-octagon me-2"></i> Análise de Recuperação</h5>
                @if (VertentesAbaixoDaMedia.Any())
                {
                    <span class="badge bg-danger">Ação Necessária</span>
                }
            </div>

            @if (VertentesAbaixoDaMedia != null && VertentesAbaixoDaMedia.Any())
            {
                <p class="text-muted small">As categorias abaixo apresentam desempenho insuficiente (média &le; 9.0):</p>
                <div class="row g-2">
                    @foreach (var v in VertentesAbaixoDaMedia)
                    {
                        <div class="col-md-6">
                            <div class="card border d-flex flex-row justify-content-between align-items-center p-3 shadow-sm">
                                <div>
                                    <div class="mb-1">
                                        <span class="badge bg-secondary me-1">@v.DisciplinaNome</span>
                                        <strong class="text-uppercase small">@v.Tipo</strong>
                                    </div>
                                    <span class="badge bg-danger">@v.Media.ToString("F1")</span>
                                </div>
                                <button class="btn btn-danger btn-sm rounded-pill px-3" @onclick="() => IniciarPlano(v)">
                                    Criar Plano
                                </button>
                            </div>
                        </div>
                    }
                </div>

                @if (VertenteEmFoco != null)
                {
                    <div class="mt-4 p-4 bg-light rounded border-start border-danger border-4 shadow-sm animate__animated animate__fadeInUp">
                        <h6 class="fw-bold text-danger mb-3">
                            Instruções para Recuperação: @VertenteEmFoco.DisciplinaNome - @VertenteEmFoco.Tipo
                        </h6>
                        <textarea class="form-control mb-3" rows="4" @bind="DescricaoNovoPlano"
                                  placeholder="Descreva as tarefas ou objetivos para o aluno recuperar esta vertente..."></textarea>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger btn-sm px-4" @onclick="SubmeterPlanoRecuperacao"
                                    disabled="@(string.IsNullOrWhiteSpace(DescricaoNovoPlano) || IsSaving)">
                                @(IsSaving ? "A processar..." : "Enviar Plano ao Aluno")
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => VertenteEmFoco = null">Cancelar</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted mb-0 small"><i class="bi bi-check-circle-fill text-success me-1"></i> O aluno mantém médias positivas em todas as vertentes.</div>
            }
        </div>

        @* Barra de Progresso e Ações *@
        <div class="row g-3">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-4 h-100" style="border-radius: 15px;">
                    <h5 class="fw-bold mb-4 small text-uppercase text-muted">Progresso de Avaliação</h5>
                    @{
                        var countCorrigidos = TrabalhosAluno.Count(t => t.Vertentes.Any(v => v.Nota.HasValue));
                        var total = TrabalhosAluno.Count;
                        var percentagem = total > 0 ? (countCorrigidos * 100 / total) : 0;
                    }
                    <div class="progress mb-2" style="height:30px; border-radius:15px; background-color: #e9ecef;">
                        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar"
                             style="width: @(percentagem)%"
                             aria-valuenow="@percentagem"
                             aria-valuemin="0" aria-valuemax="100">
                            @percentagem%
                        </div>
                    </div>
                    <small class="text-muted">@countCorrigidos de @total trabalhos avaliados até ao momento.</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4 h-100 d-flex flex-column justify-content-center" style="border-radius: 15px;">
                    <button class="btn btn-success btn-lg rounded-pill mb-3 shadow-sm"
                            @onclick='() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}")'>
                        <i class="bi bi-pencil-square me-2"></i> Avaliar Agora
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }

    private Aluno? AlunoSelecionado;
    private List<TrabalhoAlunoCustom> TrabalhosAluno = new();
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool MostrarDetalhes = false;

    private List<VertenteAnalise> VertentesAbaixoDaMedia = new();
    private VertenteAnalise? VertenteEmFoco;
    private string DescricaoNovoPlano = "";

    private void ToggleDetalhes() => MostrarDetalhes = !MostrarDetalhes;

    protected override async Task OnInitializedAsync()
    {
        await CarregarFichaCompleta();
    }

    private double CalcularMediaGeral()
    {
        var notas = TrabalhosAluno.SelectMany(t => t.Vertentes)
                                  .Where(v => v.Nota.HasValue)
                                  .Select(v => (double)v.Nota!.Value)
                                  .ToList();
        return notas.Any() ? notas.Average() : 0;
    }

    private async Task CarregarFichaCompleta()
    {
        IsLoading = true;
        try
        {
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado != null && !string.IsNullOrEmpty(AlunoSelecionado.UserId))
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                if (trabalhos != null)
                {
                    TrabalhosAluno = trabalhos.Select(t => new TrabalhoAlunoCustom
                    {
                        TrabalhoId = t.Id,
                        Titulo = t.Titulo ?? "Sem Título",
                        DisciplinaId = t.DisciplinaId,
                        DisciplinaNome = t.Disciplina?.Nome ?? "Disciplina N/A",
                        IsPlanoRecuperacao = t.IsPlanoRecuperacao,
                        Vertentes = t.TrabalhoVertentes?.Select(v => new VertenteStatusCustom
                        {
                            Tipo = v.Tipo ?? "Geral",
                            Enviado = !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null,
                            Nota = v.Nota
                        }).ToList() ?? new List<VertenteStatusCustom>()
                    }).ToList();

                    AnalisarVertentesCriticas();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar ficha: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void AnalisarVertentesCriticas()
    {
        VertentesAbaixoDaMedia = TrabalhosAluno
            .Where(t => !t.IsPlanoRecuperacao)
            .SelectMany(t => t.Vertentes.Select(v => new { Vertente = v, t.DisciplinaNome, t.DisciplinaId }))
            .GroupBy(x => new { Tipo = (x.Vertente.Tipo ?? "Geral").Trim().ToUpper(), x.DisciplinaNome, x.DisciplinaId })
            .Select(g =>
            {
                var notasValidas = g.Where(x => x.Vertente.Nota.HasValue)
                                    .Select(x => (double)x.Vertente.Nota!.Value).ToList();

                // Nova lógica: verifica se existe algum trabalho enviado que o professor ainda não corrigiu
                bool aguardandoCorrecao = g.Any(x => x.Vertente.Enviado && !x.Vertente.Nota.HasValue);

                return new VertenteAnalise
                {
                    Tipo = g.First().Vertente.Tipo ?? "Geral",
                    DisciplinaNome = g.Key.DisciplinaNome ?? "N/A",
                    DisciplinaId = g.Key.DisciplinaId ?? 0,
                    Media = notasValidas.Any() ? notasValidas.Average() : 0,
                    TemNotas = notasValidas.Any(),
                    AguardandoCorrecao = aguardandoCorrecao
                };
            })
            // O aviso só aparece se a média for inferior a 10 E se não houver trabalhos pendentes de correção
            .Where(v => v.TemNotas && v.Media < 10.0 && !v.AguardandoCorrecao)
            .OrderBy(v => v.Media)
            .ToList();
    }

    private void IniciarPlano(VertenteAnalise v)
    {
        VertenteEmFoco = v;
        DescricaoNovoPlano = "";
    }

    private async Task SubmeterPlanoRecuperacao()
    {
        if (VertenteEmFoco == null || AlunoSelecionado == null || IsSaving) return;

        IsSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var professorUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                                  ?? authState.User.Identity?.Name;

            var plano = new Trabalho
            {
                Titulo = $"RECUPERAÇÃO: {VertenteEmFoco.DisciplinaNome} - {VertenteEmFoco.Tipo}",
                ConteudoTexto = DescricaoNovoPlano,
                AlunoId = AlunoSelecionado.UserId,
                ProfessorId = professorUserId,
                IsPlanoRecuperacao = true,
                DataCriacao = DateTime.UtcNow,
                PrazoEntrega = DateTime.UtcNow.AddDays(7),
                DisciplinaId = VertenteEmFoco.DisciplinaId > 0 ? VertenteEmFoco.DisciplinaId : 1,
                TurmaId = AlunoSelecionado.TurmaId
            };

            var trabalhoId = await TrabalhoService.AddTrabalhoAsync(plano);

            if (trabalhoId > 0)
            {
                var vertenteInicial = new TrabalhoVertente
                {
                    TrabalhoId = trabalhoId,
                    Tipo = VertenteEmFoco.Tipo,
                    ConteudoTexto = DescricaoNovoPlano,
                    ConteudoTextoAluno = ""
                };

                await TrabalhoService.AddVertenteAsync(vertenteInicial);

                try
                {
                    var subs = await TrabalhoService.GetSubscriptionsByUserIdAsync(AlunoSelecionado.UserId);
                    foreach (var sub in subs)
                    {
                        await PushService.EnviarNotificacaoAsync(sub.Payload,
                            $"Novo Plano: {VertenteEmFoco.DisciplinaNome} ({VertenteEmFoco.Tipo})",
                            AlunoSelecionado.UserId);
                    }
                }
                catch { }

                await JS.InvokeVoidAsync("alert", "Plano de recuperação enviado com sucesso!");
                VertenteEmFoco = null;
                await CarregarFichaCompleta();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro ao guardar o plano.");
            Console.WriteLine($"Erro: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");

    public class TrabalhoAlunoCustom
    {
        public int TrabalhoId { get; set; }
        public string Titulo { get; set; } = "";
        public int? DisciplinaId { get; set; }
        public string? DisciplinaNome { get; set; }
        public bool IsPlanoRecuperacao { get; set; }
        public List<VertenteStatusCustom> Vertentes { get; set; } = new();
    }

    public class VertenteStatusCustom
    {
        public string Tipo { get; set; } = "";
        public bool Enviado { get; set; }
        public decimal? Nota { get; set; }
    }

    public class VertenteAnalise
    {
        public string Tipo { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int DisciplinaId { get; set; }
        public double Media { get; set; }
        public bool TemNotas { get; set; }
        public bool AguardandoCorrecao { get; set; } // Propriedade adicionada para controlar o aviso
    }
}