@page "/Conta"
@using Microsoft.AspNetCore.Identity
@using gestaopedagogica.Data
@using gestaopedagogica.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.Net.Http.Json
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject gestaopedagogica.Data.ApplicationDbContext _context

<AuthorizeView>
    <Authorized>
        @* ... O seu HTML permanece o mesmo ... *@
        <div class="page-admin animate-fade-in">
            @* ... (Mantenha o seu código HTML aqui) ... *@

            @* Exemplo do local dos botões para referência *@
            @if (!isSubscribed)
            {
                <button class="btn btn-primary w-100 mb-3" @onclick="AtivarNotificacoes">
                    <i class="bi bi-bell-fill"></i> Ativar Notificações
                </button>
            }
            else
            {
                <button class="btn btn-outline-danger w-100 mb-3" @onclick="DesativarNotificacoes">
                    <i class="bi bi-bell-slash-fill"></i> Desativar Notificações
                </button>
            }
            <p class="text-muted small text-center">@statusMessage</p>
            @* ... *@
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private string UserNome = "Utilizador";
    private string UserEmail = "";
    private string UserRole = "Membro";
    private string statusMessage = "";
    private bool isSubscribed = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaims = authState.User;

        if (userClaims.Identity?.IsAuthenticated == true)
        {
            UserNome = userClaims.Identity.Name ?? "Utilizador";
            UserEmail = userClaims.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? "";

            if (userClaims.IsInRole("Admin")) UserRole = "Administrador";
            else if (userClaims.IsInRole("Professor")) UserRole = "Professor";
            else UserRole = "Aluno";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                isSubscribed = await JSRuntime.InvokeAsync<bool>("blazorPushNotifications.checkSubscription");
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task AtivarNotificacoes()
    {
        try
        {
            statusMessage = "A solicitar permissão...";
            StateHasChanged();

            string publicKey = "BHyk2wAbiSLuakbaHIO-wiiCX4QBB-QGRBjY6C22S7pODIK_yxUB3yxLhKd91Gxsr2mBxeP8DWMO86HygQ7Nh9c";
            var subscriptionJson = await JSRuntime.InvokeAsync<string>("blazorPushNotifications.requestSubscription", publicKey);

            if (!string.IsNullOrEmpty(subscriptionJson))
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    // Remover antigas para não duplicar
                    var antigas = _context.PushSubscriptions.Where(s => s.UserId == userId);
                    _context.PushSubscriptions.RemoveRange(antigas);

                    var novaSub = new NotificationSubscription
                    {
                        UserId = userId,
                        Payload = subscriptionJson
                    };

                    _context.PushSubscriptions.Add(novaSub);
                    await _context.SaveChangesAsync();

                    // CRITICAL: Atualiza o estado e avisa a UI
                    isSubscribed = true;
                    statusMessage = "✅ Notificações ativadas!";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            statusMessage = "❌ Erro ao configurar.";
            StateHasChanged();
        }
    }

    private async Task DesativarNotificacoes()
    {
        try
        {
            statusMessage = "A desativar...";
            StateHasChanged();

            var success = await JSRuntime.InvokeAsync<bool>("blazorPushNotifications.unsubscribe");

            if (success)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    var subs = _context.PushSubscriptions.Where(s => s.UserId == userId);
                    _context.PushSubscriptions.RemoveRange(subs);
                    await _context.SaveChangesAsync();
                }

                // CRITICAL: Atualiza o estado e avisa a UI
                isSubscribed = false;
                statusMessage = "🔔 Desativadas com sucesso.";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            statusMessage = "❌ Erro ao desativar.";
            StateHasChanged();
        }
    }
}