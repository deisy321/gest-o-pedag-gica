<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TriadeLearn</title>

    <link href="~/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/custom.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/images/logo_triadelearn.png" alt="Logo" class="navbar-logo" />
                <span class="brand-text">TriadeLearn</span>
            </a>

            <div class="ms-auto d-flex align-items-center">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="user-profile-link me-3">
                        <div class="user-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="user-info-text">
                            <small>Gerir Conta</small>
                            <strong>@User.Identity.Name</strong>
                        </div>
                    </a>

                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <main class="main-content-full">
        <div class="container-fluid py-4 px-md-5">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-custom">
        <p class="mb-0 small">&copy; 2026 <strong>TriadeLearn</strong> - Gestão Pedagógica.</p>
    </footer>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
