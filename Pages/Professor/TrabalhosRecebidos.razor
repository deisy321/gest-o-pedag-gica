@page "/professor/TrabalhosRecebidos"
@page "/professor/TrabalhosRecebidos/{TurmaId:int}"
@using gestaopedagogica.Services
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider


<h3>Trabalhos </h3>

@if (ListaTrabalhos == null)
{
    <div class="spinner-border text-primary"></div>
}
else if (!ListaTrabalhos.Any())
{
    <div class="alert alert-info">Nenhum trabalho enviado.</div>
}
else
{
    @foreach (var t in ListaTrabalhos)
    {
        <div class="card mb-3">
            <div class="card-body">
                <strong>@t.Titulo</strong> - @t.Aluno?.UserName ?? "Desconhecido"
                <div class="d-flex flex-wrap mt-2 gap-2">
                    @foreach (var v in t.TrabalhoVertentes)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => AbrirVertente(v)">
                            @v.Tipo (@(v.Nota.HasValue? v.Nota.ToString() : "Pendente"))
                        </button>
                    }
                </div>
            </div>
        </div>
    }
}

@if (Selecionado != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5>Avaliar @Selecionado.Tipo</h5>
                    <button class="btn-close btn-close-white" @onclick="CancelarAvaliacao"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Conteúdo do aluno:</strong></p>
                    <div class="border p-2 mb-3">@Selecionado.ConteudoTexto</div>
                    @if (Selecionado.FicheiroBytes != null)
                    {
                        <p>Ficheiro enviado: <a href="@($"data:application/octet-stream;base64,{Convert.ToBase64String(Selecionado.FicheiroBytes)}")" target="_blank">@Selecionado.FicheiroNome</a></p>
                    }

                    <label>Nota (0-20)</label>
                    <input type="number" class="form-control" @bind="Selecionado.Nota" min="0" max="20" />

                    <label>Feedback</label>
                    <textarea class="form-control" @bind="Selecionado.Feedback"></textarea>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarAvaliacao">Cancelar</button>
                    <button class="btn btn-success" @onclick="SalvarAvaliacao">Salvar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? TurmaId { get; set; }

    private List<Trabalho> ListaTrabalhos;
    private TrabalhoVertente? Selecionado;

    protected override async Task OnInitializedAsync()
    {
        await CarregarTrabalhos();
    }

    private async Task CarregarTrabalhos()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        var trabalhos = await TrabalhoService.GetTrabalhosDoProfessorAsync(userId);

        if (TurmaId.HasValue)
            trabalhos = trabalhos.Where(t => t.TurmaId == TurmaId).ToList();

        ListaTrabalhos = trabalhos;
    }

    void AbrirVertente(TrabalhoVertente v) => Selecionado = v;

    void CancelarAvaliacao() => Selecionado = null;

    async Task SalvarAvaliacao()
    {
        if (Selecionado == null) return;
        await TrabalhoService.AtualizarNotaEFeedbackAsync(Selecionado.Id, Selecionado.Nota, Selecionado.Feedback);
        Selecionado = null;
        await CarregarTrabalhos();
    }
}