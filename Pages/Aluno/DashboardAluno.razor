@page "/aluno/DashboardAluno"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject TurmaService TurmaService
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject DisciplinaService DisciplinaService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white p-3" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard do Aluno</h4>
        </div>

        <div class="card-body p-4 bg-light">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i> @ErrorMessage
                    <button type="button" class="btn-close" @onclick='() => ErrorMessage = ""'></button>
                </div>
            }

            @if (IsLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">A carregar os teus dados pedagógicos...</p>
                </div>
            }
            else
            {
                <!-- Cards de Estatísticas -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card text-white shadow-sm border-0" style="background-color: #f1b40e; border-radius: 15px;">
                            <div class="card-body">
                                <h6 class="card-title text-uppercase small">Trabalhos Pendentes</h6>
                                <h2 class="fw-bold">@TrabalhosPendentes.Count</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-white shadow-sm border-0" style="background-color: #0d6efd; border-radius: 15px;">
                            <div class="card-body">
                                <h6 class="card-title text-uppercase small">Minhas Disciplinas</h6>
                                <h2 class="fw-bold">@DisciplinasUnicas.Count</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-white shadow-sm border-0" style="background-color: #198754; border-radius: 15px;">
                            <div class="card-body">
                                <h6 class="card-title text-uppercase small">Média Geral</h6>
                                <h2 class="fw-bold">@MediaGeral.ToString("F1")</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-white shadow-sm border-0" style="border-radius: 15px; height: 100%;">
                            <div class="card-body d-flex align-items-center justify-content-center py-2">
                                <div class="text-center">
                                    <span class="badge bg-info text-dark">@TurmaAtual?.Nome</span><br />
                                    <small class="text-muted" style="font-size: 0.7rem">@TurmaAtual?.Curso?.Nome</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filtros -->
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">DISCIPLINA</label>
                                <select class="form-select border-0 bg-light" @onchange="OnDisciplinaChanged">
                                    <option value="">Todas as Disciplinas</option>
                                    @foreach (var disc in DisciplinasUnicas)
                                    {
                                        <option value="@disc">@disc</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">MÓDULO</label>
                                <select class="form-select border-0 bg-light" @bind="ModuloSelecionado" @bind:after="FiltrarTrabalhos">
                                    <option value="">Todos os Módulos</option>
                                    @foreach (var mod in ModulosDisponiveis)
                                    {
                                        <option value="@mod">@mod</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabela de Conteúdo -->
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-muted small">
                                    <tr>
                                        <th class="ps-4">TRABALHO / DISCIPLINA</th>
                                        <th>PROFESSOR</th>
                                        <th>MÓDULO</th>
                                        <th>PRAZO</th>
                                        <th>ESTADO</th>
                                        <th class="text-center">ACÇĂO</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!TrabalhosFiltrados.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center p-5 text-muted">Nenhum trabalho pendente encontrado.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var trabalho in TrabalhosFiltrados)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <span class="fw-bold d-block">@trabalho.Titulo</span>
                                                    <small class="text-primary">@(trabalho.Disciplina?.Nome ?? "N/A")</small>
                                                </td>
                                                <td><span class="badge bg-light text-dark fw-normal">@(trabalho.Professor?.UserName ?? "N/A")</span></td>
                                                <td>@(trabalho.Modulo?.Nome ?? "N/A")</td>
                                                <td>
                                                    <small class="@(trabalho.PrazoEntrega < DateTime.Now ? "text-danger fw-bold" : "")">
                                                        @trabalho.PrazoEntrega.ToString("dd/MM/yyyy")
                                                    </small>
                                                </td>
                                                <td>
                                                    @{
                                                        var perc = CalcularPercentualConclusao(trabalho.TrabalhoVertentes);
                                                    }
                                                    <div class="progress" style="height: 6px; width: 80px;">
                                                        <div class="progress-bar" style="width: @perc%"></div>
                                                    </div>
                                                    <small style="font-size: 0.7rem">@perc.ToString("F0")%</small>
                                                </td>
                                                <td class="text-center">
                                                    <button class="btn btn-sm btn-primary rounded-pill px-3" @onclick="() => ResolverTrabalho(trabalho.Id)">
                                                        Abrir
                                                    </button>
                                                </td>
                                            </tr>
                                            @if (trabalho.TrabalhoVertentes != null && trabalho.TrabalhoVertentes.Any(v => !string.IsNullOrEmpty(v.Feedback)))
                                            {
                                                <tr class="table-warning border-0">
                                                    <td colspan="6" class="py-1 ps-4">
                                                        <small class="text-dark">
                                                            <i class="bi bi-chat-left-dots me-2"></i>
                                                            <strong>Feedback:</strong> @trabalho.TrabalhoVertentes.First(v => !string.IsNullOrEmpty(v.Feedback)).Feedback
                                                        </small>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Aluno? AlunoAtual;
    private Turma? TurmaAtual;
    private List<Trabalho> TrabalhosPendentes = new();
    private List<Trabalho> TrabalhosAvaliados = new();
    private List<Trabalho> TrabalhosFiltrados = new();

    private List<string> DisciplinasUnicas = new();
    private List<string> ModulosDisponiveis = new();
    private string DisciplinaSelecionada = "";
    private string ModuloSelecionado = "";
    private double MediaGeral = 0;

    private string? ErrorMessage;
    private bool IsLoading = true;
    private string? AlunoUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            AlunoUserId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(AlunoUserId))
            {
                ErrorMessage = "Năo foi possível identificar o aluno logado.";
                return;
            }

            await CarregarDados();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erro ao carregar dados: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CarregarDados()
    {
        var alunos = await AlunoService.GetAlunosAsync();
        AlunoAtual = alunos?.FirstOrDefault(a => a.UserId == AlunoUserId);

        if (AlunoAtual?.TurmaId.HasValue == true)
            TurmaAtual = await TurmaService.GetTurmaByIdAsync(AlunoAtual.TurmaId.Value);

        // Trazer todos os trabalhos para memória
        var todosTrabalhos = (await TrabalhoService.GetTrabalhosDisponiveisParaAlunoAsync(AlunoUserId)).ToList();

        TrabalhosPendentes = todosTrabalhos
            .Where(t => t.TrabalhoVertentes == null || t.TrabalhoVertentes.Any(v => !v.Nota.HasValue))
            .ToList();

        TrabalhosAvaliados = todosTrabalhos
            .Where(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.All(v => v.Nota.HasValue))
            .ToList();

        TrabalhosFiltrados = TrabalhosPendentes;

        DisciplinasUnicas = TrabalhosPendentes
            .Where(t => t.Disciplina != null)
            .Select(t => t.Disciplina!.Nome)
            .Distinct()
            .ToList();

        if (TrabalhosAvaliados.Any())
        {
            var notasValidas = TrabalhosAvaliados
                .SelectMany(t => t.TrabalhoVertentes!)
                .Where(v => v.Nota.HasValue)
                .Select(v => v.Nota!.Value);

            if (notasValidas.Any())
                MediaGeral = (double)notasValidas.Average(); // converte decimal para double
        }
    }

    private void OnDisciplinaChanged(ChangeEventArgs e)
    {
        DisciplinaSelecionada = e.Value?.ToString() ?? "";
        ModuloSelecionado = "";

        ModulosDisponiveis = TrabalhosPendentes
            .Where(t => t.Disciplina != null && t.Disciplina.Nome == DisciplinaSelecionada && t.Modulo != null)
            .Select(t => t.Modulo!.Nome)
            .Distinct()
            .ToList();

        FiltrarTrabalhos();
    }

    private void FiltrarTrabalhos()
    {
        var query = TrabalhosPendentes.AsEnumerable();

        if (!string.IsNullOrEmpty(DisciplinaSelecionada))
            query = query.Where(t => t.Disciplina != null && t.Disciplina.Nome == DisciplinaSelecionada);

        if (!string.IsNullOrEmpty(ModuloSelecionado))
            query = query.Where(t => t.Modulo != null && t.Modulo.Nome == ModuloSelecionado);

        TrabalhosFiltrados = query.ToList();
    }

    private double CalcularPercentualConclusao(ICollection<TrabalhoVertente>? vertentes)
    {
        if (vertentes == null || !vertentes.Any()) return 0;
        var concluidas = vertentes.Count(v => !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null);
        return (double)concluidas / vertentes.Count * 100;
    }

    private void ResolverTrabalho(int id) => Nav.NavigateTo($"/aluno/EnviarTrabalho/{id}");
}