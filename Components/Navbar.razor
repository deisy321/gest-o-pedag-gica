@namespace gestaopedagogica.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark custom-navbar fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="/images/logo_triadelearn.png" alt="Logo"
                 style="height: 40px; width: 40px; border-radius: 50%; margin-right: 12px; background: white; padding: 2px;" />
            <span style="font-weight: 700; letter-spacing: 0.5px;">TriadeLearn</span>
        </a>

        <div class="ms-auto d-flex align-items-center gap-3">
            <AuthorizeView>
                <Authorized>
                    <a href="/Conta" class="user-profile-btn">
                        <div class="avatar-circle">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="d-flex flex-column" style="line-height: 1.1;">
                            <span style="font-size: 0.7rem; opacity: 0.8; font-weight: 400;">Gerir Conta</span>
                            <span style="font-size: 0.9rem; font-weight: 700;">@context.User.Identity?.Name</span>
                        </div>
                    </a>

                    <form method="post" action="/Identity/Account/Logout" class="ms-2">
                        <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</nav>