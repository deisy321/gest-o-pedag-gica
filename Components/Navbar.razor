@namespace gestaopedagogica.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using gestaopedagogica.Services
@inject NavigationManager Nav
@* Injetamos o PushService, mas não o usaremos no OnInitialized *@
@inject PushService PushService 

<nav class="navbar navbar-expand-lg navbar-dark custom-navbar fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <img src="/images/logo_triadelearn.png" alt="Logo" />
            <span>TriadeLearn</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="ms-auto d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <div class="dropdown me-3">
                            <button class="btn btn-link text-white position-relative p-0" id="notificacoesDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell-fill fs-5"></i>
                                
                                @if (notificacoesCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.6rem;">
                                        @notificacoesCount
                                    </span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg p-2" aria-labelledby="notificacoesDropdown" style="min-width: 280px; border-radius: 12px;">
                                <li class="dropdown-header border-bottom mb-2 pb-2">
                                    <h6 class="mb-0 fw-bold">Notificações</h6>
                                </li>
                                <li>
                                    <a class="dropdown-item p-2 rounded" href="/notificacoes">
                                        <div class="d-flex flex-column">
                                            <span class="small fw-bold">Novo Trabalho!</span>
                                            <span class="small text-muted text-wrap">O professor enviou uma nova atividade.</span>
                                        </div>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-center small text-primary fw-bold" href="/notificacoes">Ver todas</a>
                                </li>
                            </ul>
                        </div>

                        <a href="/Conta" class="user-profile-btn me-2">
                            <div class="avatar-circle">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="d-flex flex-column" style="line-height: 1.1;">
                                <span style="font-size: 0.7rem; opacity: 0.85;">Conta</span>
                                <span style="font-size: 0.8rem; font-weight: 700;">@context.User.Identity?.Name?.Split('@')[0]</span>
                            </div>
                        </a>

                        <form method="post" action="Identity/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button type="submit" class="btn-logout-custom">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Sair</span>
                            </button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

@code {
    private int notificacoesCount = 0;

    // O segredo está aqui: NUNCA usar OnInitialized para serviços que tocam no JS ou Push
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Aqui o circuito já está conectado e o login não vai travar
                // notificacoesCount = await PushService.ObterTotalNotificacoes();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // Loga o erro internamente sem quebrar a UI
                Console.WriteLine("Erro ao carregar notificações na Navbar: " + ex.Message);
            }
        }
    }
}