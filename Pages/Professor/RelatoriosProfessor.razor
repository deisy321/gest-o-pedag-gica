@page "/professor/RelatoriosProfessor"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.Security.Claims
@inject ProfessorService ProfessorService
@inject TrabalhoService TrabalhoService
@inject IAService IAService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Painel de Avaliação Docente</h3>
            <p class="text-muted">Análise de desempenho, entregas e planos de recuperação</p>
        </div>
        <span class="badge bg-primary px-3 py-2">Sessão: @DateTime.Now.Year/@(DateTime.Now.Year + 1)</span>
    </div>

    @* Cartões de Resumo Rápido *@
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-primary border-4">
                <small class="text-muted fw-bold">MÉDIA GLOBAL</small>
                <h3 class="fw-bold mb-0">@(Medias.Any() ? Medias.Average().ToString("F1") : "0.0")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-danger border-4">
                <small class="text-muted fw-bold">ALUNOS EM RECUPERAÇÃO</small>
                <h3 class="fw-bold mb-0 text-danger">@TotalEmRecuperacao</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-success border-4">
                <small class="text-muted fw-bold">TAXA DE ENTREGA</small>
                <h3 class="fw-bold mb-0 text-success">@TaxaEntregaGlobal.ToString("F0")%</h3>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        @* Gráfico Principal *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-4 text-muted">Desempenho por Turma</h5>
                @if (Labels == null || !Labels.Any())
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                <div style="position: relative; height:350px; width:100%">
                    <canvas id="chartTurmas"></canvas>
                </div>
            </div>
        </div>

        @* Insights da IA e Detalhes *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 bg-white h-100 d-flex flex-column">
                <h5 class="fw-bold mb-3"><i class="bi bi-robot text-primary me-2"></i>Análise Inteligente</h5>

                @if (isGerandoAnalise)
                {
                    <div class="text-center py-5">
                        <div class="spinner-grow text-primary" role="status"></div>
                        <p class="small text-muted mt-2">Processando dados pedagógicos...</p>
                    </div>
                }
                else
                {
                    <div class="p-3 rounded-3 mb-3" style="background: #f8f9fc; border-left: 4px solid #4e73df;">
                        <p class="small mb-0 text-dark" style="line-height: 1.6; white-space: pre-line;">
                            @analiseIA
                        </p>
                    </div>
                }

                <h6 class="fw-bold mt-3 mb-3 small">Métricas por Turma:</h6>
                <div class="list-group list-group-flush small">
                    @foreach (var item in DadosTurmas)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <span class="fw-bold">@item.Nome</span>
                                <div class="text-muted" style="font-size: 0.75rem;">Recuperações: @item.QtdRecuperacao</div>
                            </div>
                            <span class="badge @(item.Media >= 10 ? "bg-success" : "bg-danger")">@item.Media.ToString("F1")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<string> Labels = new();
    private List<double> Medias = new();
    private List<TurmaDashboardItem> DadosTurmas = new();
    private int TotalEmRecuperacao = 0;
    private double TaxaEntregaGlobal = 0;

    private string analiseIA = "";
    private bool isGerandoAnalise = false;
    private bool initialized = false;

    public class TurmaDashboardItem
    {
        public string Nome { get; set; } = "";
        public double Media { get; set; }
        public int QtdRecuperacao { get; set; }
        public double PercentualEntrega { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        var professor = await ProfessorService.GetProfessorByUserIdAsync(userId);
        if (professor == null) return;

        var turmas = await ProfessorService.GetTurmasDoProfessorAsync(professor.Id);
        var trabalhos = await TrabalhoService.GetTodosTrabalhosComNotasAsync();

        DadosTurmas = turmas.Select(turma =>
        {
            var trabalhosTurma = trabalhos.Where(t => t.TurmaId == turma.Id && t.ProfessorId == userId).ToList();
            var vertentes = trabalhosTurma.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>()).ToList();

            var notas = vertentes.Where(v => v.Nota.HasValue).Select(v => (double)v.Nota!.Value).ToList();

            int totalEsperado = vertentes.Count;
            int totalEntregue = vertentes.Count(v => !string.IsNullOrEmpty(v.ConteudoTextoAluno) || v.FicheiroBytes != null);

            return new TurmaDashboardItem
            {
                Nome = turma.Nome,
                Media = notas.Any() ? Math.Round(notas.Average(), 1) : 0,
                QtdRecuperacao = trabalhosTurma.Count(t => t.IsPlanoRecuperacao),
                PercentualEntrega = totalEsperado > 0 ? ((double)totalEntregue / totalEsperado) * 100 : 0
            };
        }).OrderByDescending(x => x.Media).ToList();

        Labels = DadosTurmas.Select(d => d.Nome).ToList();
        Medias = DadosTurmas.Select(d => d.Media).ToList();
        TotalEmRecuperacao = DadosTurmas.Sum(d => d.QtdRecuperacao);
        TaxaEntregaGlobal = DadosTurmas.Any() ? DadosTurmas.Average(d => d.PercentualEntrega) : 0;

        initialized = true;

        if (DadosTurmas.Any())
        {
            _ = GerarAnaliseIA(userId);
        }
    }

    private async Task GerarAnaliseIA(string professorId)
    {
        try
        {
            isGerandoAnalise = true;
            StateHasChanged();

            var resumoParaIA = string.Join(" | ", DadosTurmas.Select(d =>
                $"{d.Nome}: Média {d.Media}, Entregas {d.PercentualEntrega:F0}%, Planos Recup: {d.QtdRecuperacao}"));

            analiseIA = await IAService.ObterSugestoes(
                promptSistemaOriginal: "És um Coordenador Pedagógico. Analisas médias, taxas de entrega e planos de recuperação.",
                instrucaoPrincipal: "Dá um diagnóstico curto. Prioriza turmas com baixa entrega ou muitas recuperações. Seja motivador mas direto.",
                conteudoParaAnalisar: resumoParaIA,
                alunoId: professorId,
                trabalhoId: "REPORT_PROF_ADVANCED",
                vertenteId: "0",
                arquivoBytes: null
            );
        }
        catch (Exception)
        {
            analiseIA = "Análise indisponível no momento. O desempenho geral parece seguir a média institucional.";
        }
        finally
        {
            isGerandoAnalise = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (initialized && Labels.Any())
        {
            await JS.InvokeVoidAsync("site.renderBarChart",
                "chartTurmas",
                Labels.ToArray(),
                Medias.ToArray(),
                Labels.Select(_ => "#4e73df").ToArray());

            initialized = false;
        }
    }
}