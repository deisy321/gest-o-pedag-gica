@namespace gestaopedagogica.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Antiforgery
@using gestaopedagogica.Services
@using System.Security.Claims
@implements IDisposable
@inject NavigationManager Nav
@inject PushService PushService 

<nav class="navbar navbar-expand-lg navbar-dark custom-navbar fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <img src="/images/logo_triadelearn.png" alt="Logo" />
            <span>TriadeLearn</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="ms-auto d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <div class="dropdown me-3">
                            @* Usamos preventDefault para o clique não bugar com o dropdown do Bootstrap *@
                            <button class="btn btn-link text-white position-relative p-0" 
                                    id="notificacoesDropdown" 
                                    data-bs-toggle="dropdown" 
                                    aria-expanded="false"
                                    @onclick="LimparNotificacoes"
                                    @onclick:preventDefault>
                                <i class="bi bi-bell-fill fs-5"></i>
                                
                                @if (notificacoesCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.6rem;">
                                        @notificacoesCount
                                    </span>
                                }
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow-lg p-2" aria-labelledby="notificacoesDropdown" style="min-width: 280px; border-radius: 12px;">
                                <li class="dropdown-header border-bottom mb-2 pb-2">
                                    <h6 class="mb-0 fw-bold">Notificações</h6>
                                </li>
                                
                                @if (notificacoesCount > 0 || !string.IsNullOrEmpty(ultimaNotificacao))
                                {
                                    <li>
                                        <div class="dropdown-item p-2 rounded">
                                            <div class="d-flex flex-column">
                                                <span class="small fw-bold text-primary">Nova Atualização</span>
                                                <span class="small text-muted text-wrap" style="font-size: 0.75rem;">
                                                    @(string.IsNullOrEmpty(ultimaNotificacao) ? "Tem novas notificações pendentes." : ultimaNotificacao)
                                                </span>
                                            </div>
                                        </div>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <div class="dropdown-item p-2 text-muted small text-center">
                                            Sem notificações novas
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>

                        <a href="/Conta" class="user-profile-btn me-2">
                            <div class="avatar-circle">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="d-flex flex-column" style="line-height: 1.1;">
                                <span style="font-size: 0.7rem; opacity: 0.85;">Conta</span>
                                <span style="font-size: 0.8rem; font-weight: 700;">@context.User.Identity?.Name?.Split('@')[0]</span>
                            </div>
                        </a>

                        <form method="post" action="Identity/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button type="submit" class="btn-logout-custom">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Sair</span>
                            </button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

@code {
    private int notificacoesCount = 0;
    private string? ultimaNotificacao;
    private string? meuId;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        PushService.OnNotificationReceived += TratarNovaNotificacao;

        if (AuthState != null)
        {
            var authState = await AuthState;
            meuId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(meuId))
            {
                notificacoesCount = PushService.GetNotificacoesCount(meuId);
            }
        }
    }

    private async void TratarNovaNotificacao(string targetUserId)
    {
        // O InvokeAsync é essencial aqui porque este evento vem de fora da thread da UI
        await InvokeAsync(() =>
        {
            if (!string.IsNullOrEmpty(meuId) && meuId == targetUserId)
            {
                notificacoesCount = PushService.GetNotificacoesCount(meuId);
                ultimaNotificacao = "Recebeu uma nova atividade.";
                StateHasChanged();
            }
        });
    }

    private void LimparNotificacoes()
    {
        if (!string.IsNullOrEmpty(meuId))
        {
            notificacoesCount = 0;
            ultimaNotificacao = null;
            PushService.LimparNotificacoes(meuId);
            
            // Forçamos o Blazor a redesenhar para o badge sumir
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        PushService.OnNotificationReceived -= TratarNovaNotificacao;
    }
}