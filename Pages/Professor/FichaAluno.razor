@page "/ficha-aluno/{AlunoId}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject TrabalhoService TrabalhoService
@inject NavigationManager Navigation

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Gestão de Plano de Recuperação</h3>
        <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo($"/trabalhos-professor/{ProfessorIdAtual}"))">Voltar</button>
    </div>

    @if (carregando)
    {
        <div class="text-center">
            <div class="spinner-border" role="status"></div>
            <p>A carregar dados...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm p-4">
            <EditForm Model="@novoPlano" OnValidSubmit="GravarPlanoRecuperacao">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Título do Plano</label>
                    <InputText @bind-Value="novoPlano.Titulo" class="form-control" placeholder="Ex: Plano de Recuperação - Módulo 1" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Descrição / Instruções do Professor</label>
                    <InputTextArea @bind-Value="novoPlano.ConteudoTexto" class="form-control" rows="3" placeholder="Descreva o que o aluno deve fazer..." />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Horas Atribuídas</label>
                        <InputNumber @bind-Value="novoPlano.HorasAtribuidas" class="form-control" />
                        <small class="text-muted">Horas que serão contabilizadas no módulo.</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Prazo de Entrega</label>
                        <InputDate @bind-Value="novoPlano.PrazoEntrega" class="form-control" />
                    </div>
                </div>

                <div class="mt-4 border-top pt-3 text-end">
                    <button type="submit" class="btn btn-success btn-lg" disabled="@estaProcessando">
                        @if (estaProcessando)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> A gravar no sistema...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle"></i> <span>Criar e Atribuir Plano</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public string AlunoId { get; set; }

    // NOTA: Estes parâmetros devem ser passados ou carregados. 
    // Se eles vierem zerados, o banco de dados pode rejeitar a gravação.
    [Parameter, SupplyParameterFromQuery] public int ModuloIdAtual { get; set; }
    [Parameter, SupplyParameterFromQuery] public int DisciplinaIdAtual { get; set; }
    [Parameter, SupplyParameterFromQuery] public string ProfessorIdAtual { get; set; }

    private Trabalho novoPlano = new Trabalho();
    private bool carregando = true;
    private bool estaProcessando = false;

    protected override void OnInitialized()
    {
        PrepararNovoPlano();
        carregando = false;
    }

    private void PrepararNovoPlano()
    {
        novoPlano = new Trabalho
        {
            AlunoId = AlunoId,
            ProfessorId = ProfessorIdAtual,
            ModuloId = ModuloIdAtual > 0 ? ModuloIdAtual : null,
            DisciplinaId = DisciplinaIdAtual > 0 ? DisciplinaIdAtual : null,
            PrazoEntrega = DateTime.Now.AddDays(7),
            Titulo = "Plano de Recuperação",
            ConteudoTexto = ""
        };
    }

    private async Task GravarPlanoRecuperacao()
    {
        if (estaProcessando) return;

        // Validação básica de segurança
        if (string.IsNullOrEmpty(novoPlano.Titulo)) return;

        try
        {
            estaProcessando = true;

            // 1. Criar o Trabalho (Gera o ID principal)
            // O seu serviço já trata o DateTime.SpecifyKind
            int novoTrabalhoId = await TrabalhoService.CriarTrabalhoAsync(novoPlano);

            if (novoTrabalhoId > 0)
            {
                // 2. Criar a Vertente (CORRIGIDO: Sem DataCriacao que não existe no seu modelo)
                var vertenteRecuperacao = new TrabalhoVertente
                {
                    TrabalhoId = novoTrabalhoId,
                    Tipo = "Recuperação",
                    ConteudoTexto = !string.IsNullOrEmpty(novoPlano.ConteudoTexto) 
                                    ? novoPlano.ConteudoTexto 
                                    : "Plano de Recuperação atribuído.",
                    Feedback = "",
                    ConteudoTextoAluno = ""
                };

                // 3. Adicionar a vertente
                await TrabalhoService.AddVertenteAsync(vertenteRecuperacao);

                // 4. Sucesso! Redireciona para a lista do professor
                Navigation.NavigateTo($"/trabalhos-professor/{ProfessorIdAtual}");
            }
        }
        catch (Exception ex)
        {
            // Log do erro para depuração
            Console.WriteLine($"ERRO CRÍTICO: {ex.Message}");
        }
        finally
        {
            estaProcessando = false;
        }
    }
}