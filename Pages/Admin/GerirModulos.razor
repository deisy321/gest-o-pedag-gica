@page "/admin/GerirModulos"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject ModuloService ModuloService
@inject ProfessorService ProfessorService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-admin">
    <div class="admin-header-row">
        <div>
            <h1 class="page-title">Gestão de Módulos</h1>
            <p class="page-subtitle">Administração do plano curricular e formadores</p>
        </div>
        <div class="d-flex gap-2" style="flex-wrap: wrap;">
            <a href="/admin/DashboardAdmin" class="btn btn-custom btn-custom-outline">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
            <button class="btn btn-custom btn-custom-success" @onclick='() => Nav.NavigateTo("/admin/CriarModulo")'>
                <i class="bi bi-plus-lg"></i> Novo Módulo
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert-custom @(Message.Contains("Erro") ? "alert-danger" : "alert-info")" style="margin-bottom: 1.5rem;">
            <i class="bi bi-info-circle-fill"></i>
            <div>@Message</div>
            <button type="button" style="background: none; border: none; color: inherit; cursor: pointer; margin-left: auto;" @onclick='() => Message = ""'>×</button>
        </div>
    }

    <div class="custom-card elevation-2">
        @if (Modulos == null || !Modulos.Any())
        {
            <div class="card-body-custom text-center py-5">
                <i class="bi bi-search" style="font-size: 3rem; color: #ccc;"></i>
                <p class="mt-3 text-muted">Nenhum módulo encontrado</p>
            </div>
        }
        else
        {
            <div style="overflow-x: auto;">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th style="width: 15%;">Nº / UFCD</th>
                            <th style="width: 35%;">Nome do Módulo</th>
                            <th style="width: 35%;">Professor</th>
                            <th style="width: 15%;" class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Modulos)
                        {
                            <tr>
                                <td><span class="badge badge-custom badge-primary">@m.Numero</span></td>
                                <td><strong>@m.Nome</strong></td>
                                <td>
                                    @if (m.Professor != null)
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                @m.Professor.Nome.Substring(0, 1).ToUpper()
                                            </div>
                                            <span>@m.Professor.Nome</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Não definido</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <button class="btn btn-custom btn-custom-primary" @onclick="() => Editar(m)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-custom btn-custom-danger" @onclick="() => Remover(m.Id)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (MostrarModal)
{
    <div class="modal-bg animate-fade-in">
        <div class="modal-card animate-slide-up">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-gradient m-0">Editar Módulo</h3>
                <button type="button" class="btn-close-custom" @onclick="Cancelar">×</button>
            </div>

            <EditForm Model="EditarModulo" OnValidSubmit="Salvar">
                <div class="d-flex flex-column gap-3">
                    <div class="form-group">
                        <label class="form-label">Nome do Módulo</label>
                        <InputText @bind-Value="EditarModulo.Nome" class="form-control" placeholder="Nome do módulo" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Número/UFCD</label>
                        <InputText @bind-Value="EditarModulo.Numero" class="form-control" placeholder="Ex: 0778" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Professor Responsável</label>
                        <InputSelect @bind-Value="EditarModulo.ProfessorId" class="form-select">
                            <option value="">-- Selecione um Professor --</option>
                            @foreach (var p in Professores)
                            {
                                <option value="@p.Id">@p.Nome</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-custom btn-custom-outline w-100" @onclick="Cancelar">Cancelar</button>
                    <button type="submit" class="btn btn-custom btn-custom-success w-100">Guardar Alterações</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Modulo> Modulos = new();
    private List<Professor> Professores = new();
    private Modulo EditarModulo = new();
    private bool MostrarModal = false;
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            Professores = await ProfessorService.GetProfessoresAsync() ?? new();
            Modulos = await ModuloService.GetModulosComProfessorAsync() ?? new();
        }
        catch (Exception ex) { Message = "Erro ao carregar dados: " + ex.Message; }
    }

    private void Editar(Modulo m)
    {
        // Criamos uma cópia do objeto para não alterar a linha da tabela em tempo real
        EditarModulo = new Modulo
        {
            Id = m.Id,
            Nome = m.Nome,
            Numero = m.Numero,
            ProfessorId = m.ProfessorId
        };
        MostrarModal = true;
    }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(EditarModulo.Nome)) return;

        try
        {
            await ModuloService.UpdateModuloAsync(EditarModulo);
            Message = "Módulo atualizado com sucesso!";
            MostrarModal = false;
            await CarregarDados(); // Recarrega a lista para mostrar o nome do professor atualizado
        }
        catch (Exception ex)
        {
            Message = "Erro ao salvar: " + ex.Message;
        }
    }

    private async Task Remover(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Deseja remover este módulo?")) return;
        try
        {
            var m = Modulos.FirstOrDefault(x => x.Id == id);
            if (m != null)
            {
                await ModuloService.RemoveModuloAsync(m);
                Message = "Módulo removido!";
                await CarregarDados();
            }
        }
        catch (Exception ex) { Message = "Erro: " + ex.Message; }
    }

    private void Cancelar() => MostrarModal = false;
}