@page "/"
@namespace gestaopedagogica.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestão Pedagógica</title>
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="app.css?v=@(DateTime.Now.Ticks)" rel="stylesheet" />
</head>
<body>
    <app>
        @* Alterado para ServerPrerendered para evitar a tela branca inicial *@
        <component type="typeof(App)" render-mode="ServerPrerendered" />

        <div class="loading-screen" id="blazor-error-ui" style="display:none;">
            <div class="spinner-border text-primary mb-2" role="status"></div>
            <h3>A carregar...</h3>
            <p>Aguarde um momento</p>
        </div>
    </app>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="_framework/blazor.server.js"></script>

    <script src="js/site.js"></script>
    <script src="js/notifications.js"></script>

    <script>
        // Registo do Service Worker melhorado
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('service-worker.js')
                    .then(function (reg) {
                        console.log('ServiceWorker ativo:', reg.scope);
                    })
                    .catch(function (error) {
                        console.error('Erro ao registar SW:', error);
                    });
            });
        }
    </script>
</body>
</html>