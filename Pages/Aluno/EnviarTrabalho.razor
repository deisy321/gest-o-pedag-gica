@page "/aluno/EnviarTrabalho/{Id:int}"
@namespace gestaopedagogica.Pages.Aluno
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.IO

@inject TrabalhoService TrabalhoService
@inject NavigationManager Nav

<div class="page-student animate-fade-in">
    @if (Trabalho == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">A carregar detalhes do trabalho...</p>
        </div>
    }
    else
    {
        <div class="admin-header-row">
            <div>
                <h1 class="page-title">Entrega de Trabalho</h1>
                <p class="page-subtitle">Submissão para: <span class="text-gradient">@Trabalho.Titulo</span></p>
            </div>
            <button class="btn-custom btn-custom-outline" @onclick='() => Nav.NavigateTo("/aluno/DashboardAluno")'>
                <i class="fas fa-arrow-left"></i> Voltar
            </button>
        </div>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="alert-custom alert-danger mb-4 animate-slide-up">
                <i class="fas fa-exclamation-triangle"></i>
                <span>@StatusMessage</span>
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <EditForm Model="Vertentes">
                    @foreach (var vert in Vertentes)
                    {
                        <div class="custom-card mb-4 elevation-2 border-start-primary">
                            <div class="card-header-custom d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-primary">@vert.Tipo</h5>
                                @if (vert.Nota.HasValue)
                                {
                                    <span class="badge-custom badge-success">Nota Atual: @vert.Nota</span>
                                }
                            </div>

                            <div class="card-body-custom">
                                @* SEÇÃO DE ORIENTAÇÃO (APENAS LEITURA) *@
                                @if (!string.IsNullOrWhiteSpace(vert.ConteudoTextoProfessor))
                                {
                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold">ORIENTAÇÕES DO PROFESSOR</label>
                                        <div class="p-3 bg-light rounded-lg border-start border-4 border-info" style="white-space: pre-line;">
                                            <i class="fas fa-chalkboard-teacher text-info me-2"></i>
                                            @vert.ConteudoTextoProfessor
                                        </div>
                                    </div>
                                }

                                @* SEÇÃO DE RESPOSTA (ONDE O ALUNO EDITA) *@
                                <div class="form-group mt-4">
                                    <label class="form-label fw-bold">Sua Resposta / Desenvolvimento</label>
                                    <textarea class="form-control" rows="10" @bind="vert.ConteudoTextoAluno"
                                              placeholder="Escreva seu trabalho aqui baseando-se nas orientações acima..."></textarea>
                                </div>

                                <div class="mt-4 p-3 border rounded-lg bg-light shadow-sm">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-paperclip me-2 text-primary"></i>Anexar Documento (Opcional)
                                    </label>
                                    <InputFile OnChange="async e => await UploadArquivo(e, vert)" class="form-control mt-2" />

                                    @if (!string.IsNullOrEmpty(vert.ArquivoNome))
                                    {
                                        <div class="badge-custom badge-primary mt-2 d-inline-flex align-items-center">
                                            <i class="fas fa-file-alt me-2"></i> @vert.ArquivoNome
                                        </div>
                                    }
                                </div>

                                <div class="mt-4 pt-3 border-top">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="feedback_@vert.Id" @bind="vert.SolicitarFeedback" />
                                        <label class="form-check-label fw-600 ms-2" for="feedback_@vert.Id">
                                            Solicitar revisão da IA antes do envio oficial
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </EditForm>
            </div>

            <div class="col-lg-4">
                <div class="custom-card elevation-3 sticky-top" style="top: 100px;">
                    <div class="card-header-custom bg-white">
                        <h5>Resumo da Entrega</h5>
                    </div>
                    <div class="card-body-custom">
                        <div class="mb-3">
                            <small class="text-muted">Tipo de Trabalho:</small>
                            @if (Trabalho.IsPlanoRecuperacao)
                            {
                                <div class="badge bg-danger text-white d-block p-2 mt-1">
                                    <i class="fas fa-retweet"></i> PLANO DE RECUPERAÇÃO
                                </div>
                                <small class="text-danger mt-1 d-block text-center fw-bold">Este envio visa melhorar sua nota anterior.</small>
                            }
                            else
                            {
                                <div class="fw-bold text-primary">Avaliação Normal</div>
                            }
                        </div>

                        <div class="d-grid gap-3 mt-4">
                            <button class="btn-custom btn-custom-secondary w-100 justify-content-center"
                                    @onclick="GerarFeedbackSelecionadoAsync" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="fas fa-robot me-2"></i> Gerar Feedback IA
                            </button>

                            <button class="btn-custom btn-custom-primary w-100 justify-content-center py-3"
                                    @onclick="EnviarVertentesAsync" disabled="@IsSaving">
                                <i class="fas fa-paper-plane me-2"></i> Submeter Trabalho
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (MostrarModalFeedback)
{
    <div class="modal-bg">
        <div class="modal-card animate-slide-up" style="max-width: 650px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="text-gradient mb-0"><i class="fas fa-magic me-2"></i> Sugestões da IA</h4>
                <button type="button" class="btn-close" @onclick="FecharModalFeedback"></button>
            </div>
            <div style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
                @foreach (var fb in FeedbacksGerados)
                {
                    <div class="custom-card elevation-1 mb-3">
                        <div class="p-3 bg-light border-bottom">
                            <strong class="text-primary">@fb.Tipo</strong>
                        </div>
                        <div class="p-3">
                            <p class="mb-0" style="white-space: pre-line;">@fb.Texto</p>
                        </div>
                    </div>
                }
            </div>
            <div class="d-flex gap-2 mt-4">
                <button class="btn-custom btn-custom-outline flex-fill justify-content-center" @onclick="FecharModalFeedback">Ajustar Trabalho</button>
                <button class="btn-custom btn-custom-primary flex-fill justify-content-center" @onclick="AceitarFeedback">Submeter Como Está</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Trabalho? Trabalho;
    private List<AlunoVertenteModel> Vertentes = new();
    private string StatusMessage = "";
    private bool IsSaving = false;
    private bool MostrarModalFeedback = false;
    private List<FeedbackModel> FeedbacksGerados = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Trabalho = await TrabalhoService.GetTrabalhoPorIdAsync(Id);

            if (Trabalho != null)
            {
                var vertentesDb = await TrabalhoService.GetVertentesDoTrabalhoAsync(Trabalho.Id);

                if (vertentesDb == null || !vertentesDb.Any())
                {
                    // LÓGICA CORRIGIDA: Separa orientação (Trabalho.ConteudoTexto) da resposta (Trabalho.ConteudoTextoAluno)
                    Vertentes.Add(new AlunoVertenteModel
                    {
                        Id = 0,
                        Tipo = Trabalho.IsPlanoRecuperacao ? "Recuperação de Nota" : "Desenvolvimento Geral",
                        ConteudoTextoProfessor = Trabalho.ConteudoTexto ?? Trabalho.Descricao ?? "Siga as orientações do professor.",
                        ConteudoTextoAluno = Trabalho.ConteudoTextoAluno ?? "" // Começa vazio para o aluno escrever
                    });
                }
                else
                {
                    Vertentes = vertentesDb.Select(v => new AlunoVertenteModel
                    {
                        Id = v.Id,
                        Tipo = v.Tipo,
                        ConteudoTextoProfessor = v.ConteudoTexto, // Instrução do professor
                        ConteudoTextoAluno = v.ConteudoTextoAluno ?? "", // Resposta do aluno
                        ArquivoNome = v.FicheiroNome,
                        ArquivoBytes = v.FicheiroBytes,
                        ArquivoContentType = v.FicheiroContentType,
                        Feedback = v.Feedback,
                        Nota = v.Nota
                    }).ToList();
                }
            }
        }
        catch (Exception ex) { StatusMessage = "Erro ao carregar: " + ex.Message; }
    }

    private async Task EnviarVertentesAsync()
    {
        IsSaving = true;
        try
        {
            foreach (var vert in Vertentes)
            {
                // Se for uma vertente vinda do banco
                if (vert.Id > 0)
                {
                    var vertDb = await TrabalhoService.GetVertentePorIdAsync(vert.Id);
                    if (vertDb != null)
                    {
                        vertDb.ConteudoTextoAluno = vert.ConteudoTextoAluno;
                        if (vert.ArquivoBytes != null)
                        {
                            vertDb.FicheiroBytes = vert.ArquivoBytes;
                            vertDb.FicheiroNome = vert.ArquivoNome;
                            vertDb.FicheiroContentType = vert.ArquivoContentType;
                        }
                        await TrabalhoService.AtualizarVertenteAsync(vertDb);
                    }
                }
                else if (Trabalho != null)
                {
                    // Caso seja um trabalho sem vertentes (como Recuperação direta no objeto Trabalho)
                    Trabalho.ConteudoTextoAluno = vert.ConteudoTextoAluno;
                    // Note: Aqui você deve garantir que o seu Service tenha um método para atualizar o Trabalho principal
                    await TrabalhoService.AtualizarTrabalhoAsync(Trabalho);
                }
            }
            Nav.NavigateTo("/aluno/DashboardAluno");
        }
        catch (Exception ex) { StatusMessage = "Erro ao enviar: " + ex.Message; }
        finally { IsSaving = false; }
    }

    private async Task GerarFeedbackSelecionadoAsync()
    {
        if (!Vertentes.Any(v => v.SolicitarFeedback))
        {
            StatusMessage = "Selecione a opção de feedback na vertente desejada.";
            return;
        }

        IsSaving = true;
        FeedbacksGerados.Clear();
        try
        {
            foreach (var vert in Vertentes.Where(v => v.SolicitarFeedback))
            {
                var feedback = await TrabalhoService.GerarFeedbackIAAsync(
                    Trabalho!.AlunoId!, vert.ConteudoTextoAluno, vert.ArquivoBytes, Trabalho.Id, vert.Id.ToString());
                FeedbacksGerados.Add(new FeedbackModel { Tipo = vert.Tipo, Texto = feedback });
            }
            if (FeedbacksGerados.Any()) MostrarModalFeedback = true;
        }
        catch (Exception ex) { StatusMessage = $"Erro IA: {ex.Message}"; }
        finally { IsSaving = false; }
    }

    private void FecharModalFeedback() => MostrarModalFeedback = false;

    private async Task AceitarFeedback()
    {
        MostrarModalFeedback = false;
        await EnviarVertentesAsync();
    }

    private async Task UploadArquivo(InputFileChangeEventArgs e, AlunoVertenteModel vert)
    {
        try
        {
            var file = e.File;
            vert.ArquivoNome = file.Name;
            vert.ArquivoContentType = file.ContentType;
            using var ms = new MemoryStream();
            await file.OpenReadStream(10_000_000).CopyToAsync(ms);
            vert.ArquivoBytes = ms.ToArray();
        }
        catch (Exception ex) { StatusMessage = $"Erro upload: {ex.Message}"; }
    }

    public class AlunoVertenteModel
    {
        public int Id { get; set; }
        public string Tipo { get; set; } = "";
        public string ConteudoTextoProfessor { get; set; } = "";
        public string ConteudoTextoAluno { get; set; } = "";
        public string? ArquivoNome { get; set; }
        public byte[]? ArquivoBytes { get; set; }
        public string? ArquivoContentType { get; set; }
        public string? Feedback { get; set; }
        public decimal? Nota { get; set; }
        public bool SolicitarFeedback { get; set; } = false;
    }

    public class FeedbackModel
    {
        public string Tipo { get; set; } = "";
        public string Texto { get; set; } = "";
    }
}