@page "/identity/account/login"
@model gestaopedagogica.Pages.identity.account.LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - TriadeLearn</title>
    <link href="~/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1e3a8a 0%, #0d9488 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        .login-container {
            max-width: 420px;
            width: 100%;
            padding: 0 15px;
        }

        .card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
        }

        .card-body {
            padding: 40px;
        }

        .logo-wrapper {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-img {
            max-width: 180px;
            height: auto;
            border-radius: 50%;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background-color: #1e3a8a;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #0d9488;
                transform: translateY(-1px);
            }

        .form-control:focus {
            border-color: #0d9488;
            box-shadow: 0 0 0 0.25rem rgba(13, 148, 136, 0.25);
        }

        /* Ajuste visual para a lista de erros */
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="card shadow-lg">
            <div class="card-body">

                <div class="logo-wrapper">
                    <img src="~/images/logo_triadelearn.png" alt="TriadeLearn Logo" class="logo-img" />
                    <h5 class="text-center text-muted mt-3" style="font-weight: 400; letter-spacing: 0.5px;">Gestăo Pedagógica</h5>
                </div>

                <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" for="Input_Username">Email ou Utilizador</label>
                        <input type="text" id="Input_Username" name="Input.Username" class="form-control form-control-lg" placeholder="Ex: admin@local" value="@Model.Input.Username" required autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Input_Password">Senha</label>
                        <input type="password" id="Input_Password" name="Input.Password" class="form-control form-control-lg" placeholder="Sua senha" required />
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" id="Input_RememberMe" name="Input.RememberMe" class="form-check-input" @(Model.Input.RememberMe ? "checked" : "") />
                        <label class="form-check-label" for="Input_RememberMe">Manter sessăo iniciada</label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Entrar no Sistema</button>
                </form>

                <hr />

                <div class="text-center text-muted">
                    <small>Suporte: contacte o administrador do TriadeLearn.</small>
                </div>
            </div>
        </div>

        <div class="mt-4 text-center text-white text-opacity-75">
            <p class="small mb-2"><strong>Credenciais de Teste:</strong></p>
            <p class="small">Admin: admin@local / Admin123!</p>
            <p class="small">Professor: prof@local / Prof123!</p>
            <p class="small">Aluno: aluno@local / Aluno123!</p>
        </div>
    </div>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>