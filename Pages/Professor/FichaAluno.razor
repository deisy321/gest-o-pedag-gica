@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject AlunoService AlunoService
@inject NavigationManager Nav

<div class="page-teacher animate-fade-in">
    @* Cabeçalho com Botões de Ação *@
    <div class="admin-header-row mb-4">
        <div>
            <h1 class="page-title">Ficha Técnica do Aluno</h1>
            <p class="page-subtitle">Análise de conformidade e desempenho por módulos</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn-custom btn-custom-primary" @onclick='() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}")'>
                <i class="fas fa-edit me-2"></i>Avaliar Trabalhos
            </button>
            <button class="btn-custom btn-custom-outline" @onclick='() => Nav.NavigateTo("/professor/Dashboard")'>
                <i class="fas fa-arrow-left me-2"></i>Voltar
            </button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">A carregar ficha técnica...</p>
        </div>
    }
    else if (AlunoAtual == null)
    {
        <div class="alert alert-danger">Aluno não encontrado.</div>
    }
    else
    {
        @* Cartões de Resumo *@
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="custom-card p-4 h-100 border-start-primary">
                    <span class="text-muted small fw-bold text-uppercase">Média Global</span>
                    <h2 class="fw-bold mb-0">@MediaGlobal.ToString("F1")</h2>
                    <p class="text-muted small mb-0">Módulos Concluídos</p>
                </div>
            </div>
            <div class="col-md-8">
                <div class="custom-card p-4 h-100 d-flex align-items-center">
                    <div class="avatar-circle-lg me-4">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-1">@AlunoAtual.Nome</h3>
                        <p class="text-muted mb-0"><i class="fas fa-id-badge me-2"></i>@AlunoAtual.Turma?.Nome</p>
                    </div>
                </div>
            </div>
        </div>

        @* Tabela de Estado de Conclusão *@
        <div class="custom-card overflow-hidden">
            <div class="p-3 bg-light border-bottom">
                <h6 class="mb-0 fw-bold text-muted text-uppercase small">Estado de Conclusão e Bloqueios</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Módulo</th>
                            <th>Progresso Horas</th>
                            <th>Vertentes (Status)</th>
                            <th class="text-center">Nota Final / Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var modulo in AlunoAtual.Turma?.Curso?.Modulos ?? new List<Modulo>())
                        {
                            var nota = GetNotaModulo(modulo.Id);
                            var isBloqueado = nota < 9.5;

                            <tr>
                                <td>
                                    <div class="fw-bold">@modulo.Nome</div>
                                    <span class="badge bg-light text-primary border">@modulo.Disciplina?.Nome</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                            <div class="progress-bar" style="width: 85%"></div>
                                        </div>
                                        <span class="small text-muted">24/25 h</span>
                                    </div>
                                </td>
                                <td>
                                    @* Exemplo de visual de vertentes *@
                                    <div class="d-flex gap-1">
                                        <span class="badge bg-success-soft text-success">P1</span>
                                        <span class="badge bg-success-soft text-success">P2</span>
                                        <span class="badge bg-danger-soft text-danger">Competência (5.0)</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (isBloqueado)
                                    {
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <span class="text-danger fw-bold small"><i class="fas fa-lock me-1"></i>BLOQUEADO</span>
                                            <button class="btn btn-warning btn-sm fw-bold shadow-sm"
                                                    @onclick='() => Nav.NavigateTo($"/professor/CriarPlanoRecuperacao/{AlunoId}/{modulo.Id}")'>
                                                <i class="fas fa-plus-circle me-1"></i> Criar Plano Recuperação
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="h5 fw-bold text-success">@nota.ToString("F1")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .bg-success-soft {
        background-color: #d1e7dd;
    }

    .bg-danger-soft {
        background-color: #f8d7da;
    }

    .border-start-primary {
        border-left: 5px solid var(--primary-color) !important;
    }

    .avatar-circle-lg {
        width: 60px;
        height: 60px;
        background: #f0f2f5;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: var(--primary-color);
    }

    .table th {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        padding: 1rem;
    }

    .table td {
        padding: 1rem;
    }

    /* Destaque para o botão de recuperação */
    .btn-warning {
        background-color: #ffc107;
        border: none;
        color: #000;
        transition: all 0.2s;
    }

        .btn-warning:hover {
            background-color: #e0a800;
            transform: scale(1.05);
        }
</style>

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoAtual;
    private bool IsLoading = true;
    private double MediaGlobal = 0.0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarFicha();
    }

    private async Task CarregarFicha()
    {
        IsLoading = true;
        try
        {
            AlunoAtual = await AlunoService.GetAlunoByIdAsync(AlunoId);
            // Lógica para calcular média global viria aqui
        }
        finally
        {
            IsLoading = false;
        }
    }

    private double GetNotaModulo(int moduloId)
    {
        // Simulação de nota negativa para demonstrar o botão
        return 5.0;
    }
}