@page "/admin/GerirTurmas"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services

@inject TurmaService TurmaService
@inject ProfessorService ProfessorService

<h3>Gerir Turmas</h3>

<button class="btn btn-success mb-3" @onclick="MostrarCriarTurma">
    Criar Turma
</button>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Ano Letivo</th>
            <th>Professores</th>
            <th>Alunos</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Turmas)
        {
            <tr>
                <td>@t.Nome</td>
                <td>@t.Ano</td>
                <td>
                    @if (t.Professores != null && t.Professores.Any())
                    {
                        @string.Join(", ", t.Professores.Where(tp => tp.Professor != null).Select(tp => tp.Professor.Nome))
                    }
                    else
                    {
                        @:Não definido
                    }
                </td>
                <td>@(t.Alunos?.Count ?? 0)</td>
                <td>
                    <button class="btn btn-primary btn-sm" @onclick="() => Editar(t)">Editar</button>
                    <button class="btn btn-info btn-sm" @onclick="() => VerDetalhes(t)">Detalhes</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => Remover(t)">Eliminar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (MostrarModalCriar)
{
    <div class="modal-bg">
        <div class="modal-card">
            <h4>Criar Nova Turma</h4>

            <input class="form-control mb-2" placeholder="Nome da Turma" @bind="NovaTurma.Nome" />
            <input class="form-control mb-2" placeholder="Ano Letivo" @bind="NovaTurma.Ano" />

            <label>Selecionar Professores:</label>
            <select class="form-control mb-2" @onchange="AdicionarProfessor">
                <option value="0">Selecione um professor</option>
                @foreach (var p in Professores)
                {
                    <option value="@p.Id">@p.Nome</option>
                }
            </select>

            <div class="mb-2">
                <b>Professores Selecionados:</b>
                @if (NovaTurma.Professores != null && NovaTurma.Professores.Any())
                {
                    @string.Join(", ", NovaTurma.Professores.Where(tp => tp.Professor != null).Select(tp => tp.Professor.Nome))
                }
                else
                {
                    @:Nenhum
                }
            </div>

            <button class="btn btn-success" @onclick="SalvarNovaTurma">Guardar</button>
            <button class="btn btn-secondary" @onclick="() => MostrarModalCriar = false">Cancelar</button>
        </div>
    </div>
}

@if (MostrarModalEditar)
{
    <div class="modal-bg">
        <div class="modal-card">
            <h4>Editar Turma</h4>

            <input class="form-control mb-2" @bind="EditarTurma.Nome" />
            <input class="form-control mb-2" @bind="EditarTurma.Ano" />

            <label>Selecionar Professores:</label>
            <select class="form-control mb-2" @onchange="AdicionarProfessorEditar">
                <option value="0">Selecione um professor</option>
                @foreach (var p in Professores)
                {
                    <option value="@p.Id">@p.Nome</option>
                }
            </select>

            <div class="mb-2">
                <b>Professores Selecionados:</b>
                @if (EditarTurma.Professores != null && EditarTurma.Professores.Any())
                {
                    @string.Join(", ", EditarTurma.Professores.Where(tp => tp.Professor != null).Select(tp => tp.Professor.Nome))
                }
                else
                {
                    @:Nenhum
                }
            </div>

            <button class="btn btn-primary" @onclick="SalvarEdicao">Guardar</button>
            <button class="btn btn-secondary" @onclick="() => MostrarModalEditar = false">Cancelar</button>
        </div>
    </div>
}

@if (MostrarModalDetalhes)
{
    <div class="modal-bg">
        <div class="modal-card">
            <h4>Detalhes da Turma: @TurmaDetalhes.Nome</h4>
            <p><b>Ano:</b> @TurmaDetalhes.Ano</p>

            <h5>Alunos</h5>
            <ul>
                @foreach (var aluno in TurmaDetalhes.Alunos ?? new List<Aluno>())
                {
                    <li>@aluno.Nome</li>
                }
            </ul>

            <input class="form-control mb-2" placeholder="Nome do Aluno" @bind="AlunoNovo" />
            <button class="btn btn-success" @onclick="AdicionarAluno">Adicionar Aluno</button>

            <button class="btn btn-secondary mt-3" @onclick="() => MostrarModalDetalhes = false">Fechar</button>
        </div>
    </div>
}

@code {
    List<Turma> Turmas = new();
    List<Professor> Professores = new();

    bool MostrarModalCriar = false;
    bool MostrarModalEditar = false;
    bool MostrarModalDetalhes = false;

    Turma NovaTurma = new() { Professores = new() };
    Turma EditarTurma = new() { Professores = new() };
    Turma TurmaDetalhes = new() { Alunos = new(), Professores = new() };
    string AlunoNovo = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Turmas = await TurmaService.GetTurmasAsync() ?? new();
            Professores = await ProfessorService.GetProfessoresAsync() ?? new();
        }
        catch
        {
            Turmas = new();
            Professores = new();
        }
    }

    void MostrarCriarTurma()
    {
        NovaTurma = new Turma { Professores = new(), Alunos = new() };
        MostrarModalCriar = true;
    }

    async Task SalvarNovaTurma()
    {
        await TurmaService.AddTurmaAsync(NovaTurma);
        MostrarModalCriar = false;
        Turmas = await TurmaService.GetTurmasAsync() ?? new();
    }

    void Editar(Turma t)
    {
        EditarTurma = new Turma
        {
            Id = t.Id,
            Nome = t.Nome,
            Ano = t.Ano,
            Alunos = t.Alunos != null ? new List<Aluno>(t.Alunos) : new(),
            Professores = t.Professores?.Select(tp => new TurmaProfessor
            {
                TurmaId = tp.TurmaId,
                ProfessorId = tp.ProfessorId,
                Professor = tp.Professor
            }).ToList() ?? new()
        };
        MostrarModalEditar = true;
    }

    async Task SalvarEdicao()
    {
        await TurmaService.UpdateTurmaAsync(EditarTurma);
        MostrarModalEditar = false;
        Turmas = await TurmaService.GetTurmasAsync() ?? new();
    }

    async Task Remover(Turma t)
    {
        await TurmaService.RemoveTurmaAsync(t);
        Turmas = await TurmaService.GetTurmasAsync() ?? new();
    }

    void VerDetalhes(Turma t)
    {
        TurmaDetalhes = t;
        if (TurmaDetalhes.Alunos == null) TurmaDetalhes.Alunos = new();
        MostrarModalDetalhes = true;
    }

    async Task AdicionarAluno()
    {
        if (!string.IsNullOrWhiteSpace(AlunoNovo))
        {
            TurmaDetalhes.Alunos.Add(new Aluno { Nome = AlunoNovo });
            await TurmaService.UpdateTurmaAsync(TurmaDetalhes);
            AlunoNovo = "";
            Turmas = await TurmaService.GetTurmasAsync() ?? new();
        }
    }

    void AdicionarProfessor(ChangeEventArgs e)
    {
        if (e.Value == null || e.Value.ToString() == "0") return;
        int professorId = int.Parse(e.Value.ToString()!);
        var professor = Professores.FirstOrDefault(p => p.Id == professorId);

        if (professor != null && !NovaTurma.Professores.Any(tp => tp.ProfessorId == professorId))
        {
            NovaTurma.Professores.Add(new TurmaProfessor { ProfessorId = professor.Id, Professor = professor });
            StateHasChanged();
        }
    }

    void AdicionarProfessorEditar(ChangeEventArgs e)
    {
        if (e.Value == null || e.Value.ToString() == "0") return;
        int professorId = int.Parse(e.Value.ToString()!);
        var professor = Professores.FirstOrDefault(p => p.Id == professorId);

        if (professor != null && !EditarTurma.Professores.Any(tp => tp.ProfessorId == professorId))
        {
            EditarTurma.Professores.Add(new TurmaProfessor { ProfessorId = professor.Id, Professor = professor });
            StateHasChanged();
        }
    }
}
