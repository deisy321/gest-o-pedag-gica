@page "/admin/CriarModulo"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject ModuloService ModuloService
@inject ProfessorService ProfessorService
@inject TurmaService TurmaService
@inject DisciplinaService DisciplinaService
@inject NavigationManager Nav

<div class="main-content">
    <div class="page-admin">
        @* Cabeçalho com o Estilo de Gradiente *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-gradient mb-0">Novo Módulo / UFCD</h2>
                <p class="text-muted">Registe uma nova unidade de formação no sistema.</p>
            </div>
            <button class="user-profile-btn border" @onclick='() => Nav.NavigateTo("/admin/GerirModulos")'>
                <i class="bi bi-arrow-left me-2"></i> Voltar à Lista
            </button>
        </div>

        <div class="custom-card shadow-sm border-0 p-4">
            @if (IsLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Carregando dados da base de dados...</p>
                </div>
            }
            else
            {
                <EditForm Model="novoModulo" OnValidSubmit="SalvarModulo">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        @* Seleção de Disciplina (Obrigatório) *@
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Disciplina Pertencente</label>
                            <InputSelect @bind-Value="SelectedDisciplinaId" class="form-select bg-light border-0 py-2" style="border-radius: 10px;">
                                <option value="0">-- Selecione a Disciplina --</option>
                                @foreach (var disc in ListaDisciplinas)
                                {
                                    <option value="@disc.Id">@disc.Nome</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Nome do Módulo</label>
                            <InputText @bind-Value="novoModulo.Nome" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="Ex: Programação C#" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Número / UFCD</label>
                            <InputText @bind-Value="novoModulo.Numero" class="form-control bg-light border-0 py-2" style="border-radius: 10px;" placeholder="Ex: 0778" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Professor Responsável (Opcional)</label>
                            <InputSelect @bind-Value="SelectedProfessorId" class="form-select bg-light border-0 py-2" style="border-radius: 10px;">
                                <option value="0">Selecione depois...</option>
                                @foreach (var prof in ListaProfessores)
                                {
                                    <option value="@prof.Id">@prof.Nome</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Vincular à Turma (Opcional)</label>
                            <InputSelect @bind-Value="SelectedTurmaId" class="form-select bg-light border-0 py-2" style="border-radius: 10px;">
                                <option value="0">Vincular depois...</option>
                                @foreach (var turma in ListaTurmas)
                                {
                                    <option value="@turma.Id">@turma.Nome</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger border-0 shadow-sm mt-4" style="border-radius: 12px;">
                            <i class="bi bi-exclamation-triangle me-2"></i> @ErrorMessage
                        </div>
                    }

                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="qa-item blue border-0 px-5 py-2 shadow-sm"
                                style="margin-bottom:0; border-radius:50px; color: white !important;"
                                disabled="@(IsSaving || SelectedDisciplinaId == 0)">
                            <i class="bi bi-check-lg me-2"></i>
                            @(IsSaving ? "Gravando..." : "Criar Módulo")
                        </button>

                        <button type="button" class="btn btn-light rounded-pill px-4" @onclick='() => Nav.NavigateTo("/admin/GerirModulos")'>
                            Cancelar
                        </button>
                    </div>

                    @if (SelectedDisciplinaId == 0)
                    {
                        <div class="mt-3 text-muted small">
                            <i class="bi bi-info-circle me-1"></i> Selecione uma disciplina acima para habilitar a gravação.
                        </div>
                    }
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private Modulo novoModulo = new();
    private List<Professor> ListaProfessores = new();
    private List<Turma> ListaTurmas = new();
    private List<Disciplina> ListaDisciplinas = new();

    private int SelectedTurmaId;
    private int SelectedProfessorId;
    private int SelectedDisciplinaId;

    private bool IsLoading = true;
    private bool IsSaving = false;
    private string ErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carregamento resiliente para evitar erro 500.30
            var resP = await ProfessorService.GetProfessoresAsync();
            ListaProfessores = resP ?? new();

            var resT = await TurmaService.GetTurmasSimplesAsync();
            ListaTurmas = resT ?? new();

            var resD = await DisciplinaService.GetDisciplinasAsync();
            ListaDisciplinas = resD ?? new();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Erro ao carregar dados: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SalvarModulo()
    {
        if (SelectedDisciplinaId == 0)
        {
            ErrorMessage = "Deve selecionar uma disciplina obrigatoriamente.";
            return;
        }

        try
        {
            IsSaving = true;
            ErrorMessage = "";

            novoModulo.DisciplinaId = SelectedDisciplinaId;

            if (SelectedProfessorId > 0)
                novoModulo.ProfessorId = SelectedProfessorId;
            else
                novoModulo.ProfessorId = null;

            // 1. Criar o Módulo
            await ModuloService.AddModuloAsync(novoModulo);

            // 2. Vincular à Turma se necessário
            if (SelectedTurmaId > 0 && novoModulo.Id > 0)
            {
                await TurmaService.AddTurmaModuloAsync(SelectedTurmaId, novoModulo.Id);
            }

            Nav.NavigateTo("/admin/GerirModulos");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erro ao salvar: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }
}
