@page "/admin/GerirModulos"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

@using gestaopedagogica.Services
@using gestaopedagogica.Models

@inject ModuloService ModuloService
@inject ProfessorService ProfessorService
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0"><i class="bi bi-journal-text me-2"></i>Gestão de Módulos</h4>
            <!-- Redireciona para a página de criação que já configurámos -->
            <button class="btn btn-success rounded-pill px-4" @onclick='() => Nav.NavigateTo("/admin/CriarModulo")'>
                <i class="bi bi-plus-circle me-2"></i>Novo Módulo
            </button>
        </div>

        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@Message
                    <button type="button" class="btn-close" @onclick='() => Message = ""'></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Nº/UFCD</th>
                            <th>Nome do Módulo</th>
                            <th>Professor Responsável</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Modulos == null || !Modulos.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhum módulo registado.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in Modulos)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@m.Numero</td>
                                    <td>@m.Nome</td>
                                    <td>
                                        <span class="badge @(m.Professor != null ? "bg-info text-dark" : "bg-light text-muted")">
                                            <i class="bi bi-person me-1"></i>@(m.Professor?.Nome ?? "Não definido")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(m)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Remover(m.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (MostrarModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 15px;">
                <div class="modal-header bg-primary text-white" style="border-radius: 15px 15px 0 0;">
                    <h5 class="modal-title">Editar Módulo</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Cancelar"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome do Módulo</label>
                        <input class="form-control rounded-pill" @bind="EditarModulo.Nome" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Número/UFCD</label>
                        <input class="form-control rounded-pill" @bind="EditarModulo.Numero" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Professor</label>
                        <select class="form-select rounded-pill" @bind="EditarModulo.ProfessorId">
                            <option value="0">Selecione um professor...</option>
                            @foreach (var p in Professores)
                            {
                                <option value="@p.Id">@p.Nome</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3">
                    <button class="btn btn-light rounded-pill px-4" @onclick="Cancelar">Cancelar</button>
                    <button class="btn btn-primary rounded-pill px-4" @onclick="Salvar">Guardar Alterações</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Modulo> Modulos = new();
    private List<Professor> Professores = new();
    private Modulo EditarModulo = new();
    private bool MostrarModal = false;
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        Professores = await ProfessorService.GetProfessoresAsync() ?? new();
        await CarregarModulos();
    }

    private async Task CarregarModulos()
    {
        // Usa o método com Include para mostrar os nomes dos professores
        Modulos = await ModuloService.GetModulosComProfessorAsync() ?? new();
    }

    private void Editar(Modulo m)
    {
        EditarModulo = new Modulo
        {
            Id = m.Id,
            Nome = m.Nome,
            Numero = m.Numero,
            ProfessorId = m.ProfessorId
        };
        MostrarModal = true;
    }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(EditarModulo.Nome))
        {
            Message = "O nome do módulo é obrigatório!";
            return;
        }

        try
        {
            // Como é edição, o Id já existe (> 0)
            await ModuloService.UpdateModuloAsync(EditarModulo);
            Message = "Módulo atualizado com sucesso!";
            MostrarModal = false;
            await CarregarModulos();
        }
        catch (Exception ex)
        {
            Message = "Erro ao atualizar: " + ex.Message;
        }
    }

    private async Task Remover(int id)
    {
        var modulo = Modulos.FirstOrDefault(m => m.Id == id);
        if (modulo != null)
        {
            await ModuloService.RemoveModuloAsync(modulo);
            Message = "Módulo removido permanentemente!";
            await CarregarModulos();
        }
    }

    private void Cancelar() => MostrarModal = false;
}
