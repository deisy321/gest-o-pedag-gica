@page "/aluno/Historico"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject TrabalhoService TrabalhoService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Histórico de Conclusão</h3>
        <div class="text-end">
            <span class="badge bg-dark p-2">
                Módulos Concluídos: @DisciplinasAgrupadas.Sum(d => d.Modulos.Count(m => m.Status == "Aprovado")) / @DisciplinasAgrupadas.Sum(d => d.Modulos.Count)
            </span>
        </div>
    </div>

    @if (DisciplinasAgrupadas.Any())
    {
        @foreach (var disciplina in DisciplinasAgrupadas)
        {
            <div class="card shadow-sm border-0 mb-5" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="fw-bold m-0 text-primary">
                        <i class="bi bi-book me-2"></i>@disciplina.DisciplinaNome
                    </h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 15%;">Ano Letivo</th>
                                <th style="width: 30%;">Módulo</th>
                                <th style="width: 20%;">Professor</th>
                                <th class="text-center" style="width: 10%;">Média Final</th>
                                <th class="text-center" style="width: 15%;">Estado Técnico</th>
                                <th class="text-end pe-4" style="width: 10%;">Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in disciplina.Modulos)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@item.AnoLetivo</td>
                                    <td><div class="fw-bold">@item.ModuloNome</div></td>
                                    <td>@item.Professor</td>
                                    <td class="text-center">
                                        @if (item.Status == "Bloqueado")
                                        {
                                            <span class="text-danger fw-bold">@item.MediaFinal.ToString("F1")</span>
                                        }
                                        else if (item.Status == "Aprovado")
                                        {
                                            <span class="fw-bold text-success">@item.MediaFinal.ToString("F1")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">--</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @switch (item.Status)
                                        {
                                            case "Aprovado":
                                                <span class="badge rounded-pill bg-success-subtle text-success border border-success">Concluído</span>
                                                break;
                                            case "Bloqueado":
                                                <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger">Retido (Técnico)</span>
                                                break;
                                            default:
                                                <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning">Em Curso</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (item.Status == "Aprovado")
                                        {
                                            <button class="btn btn-sm btn-outline-primary shadow-sm">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>
                                        }
                                        else if (item.Status == "Bloqueado")
                                        {
                                            <i class="bi bi-info-circle text-danger" title="Módulo retido devido a vertente negativa."></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card shadow-sm border-0 p-5 text-center text-muted" style="border-radius: 15px;">
            <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
            Ainda não existem módulos registados.
        </div>
    }
</div>

@code {
    private List<DisciplinaHistoricoUI> DisciplinasAgrupadas = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(userId);
            ProcessarHistorico(trabalhos);
        }
    }

    private void ProcessarHistorico(List<Trabalho> trabalhos)
    {
        if (trabalhos == null) return;

        DisciplinasAgrupadas = trabalhos
            .GroupBy(t => t.Disciplina?.Nome ?? "Outros")
            .Select(gd => new DisciplinaHistoricoUI
            {
                DisciplinaNome = gd.Key,
                Modulos = gd.GroupBy(t => new
                {
                    t.ModuloId,
                    Nome = t.Modulo?.Nome ?? "N/D",
                    ProfessorNome = t.Professor?.UserName ?? "N/D",
                    HorasTotais = t.Modulo?.TotalHoras ?? 25
                })
                .Select(g =>
                {
                    var melhoresNotas = g.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                        .Where(v => v.Nota.HasValue)
                        .GroupBy(v => v.Tipo)
                        .Select(gv => gv.Max(v => v.Nota!.Value))
                        .ToList();

                    var horasFeitas = g.Sum(t => t.HorasAtribuidas);
                    var concluidoHoras = horasFeitas >= g.Key.HorasTotais;
                    var temBloqueioTecnico = melhoresNotas.Any(nota => nota < 9.5m);

                    string status = (concluidoHoras && temBloqueioTecnico) ? "Bloqueado" :
                                    (concluidoHoras) ? "Aprovado" : "Em Curso";

                    var primeiraData = g.Min(x => x.DataCriacao);

                    return new HistoricoModuloUI
                    {
                        AnoLetivo = $"{primeiraData.Year}/{(primeiraData.Year + 1).ToString().Substring(2)}",
                        ModuloNome = g.Key.Nome,
                        Professor = g.Key.ProfessorNome,
                        MediaFinal = melhoresNotas.Any() ? melhoresNotas.Average() : 0,
                        Status = status
                    };
                }).OrderBy(m => m.ModuloNome).ToList()
            }).OrderBy(d => d.DisciplinaNome).ToList();
    }

    public class DisciplinaHistoricoUI
    {
        public string DisciplinaNome { get; set; } = "";
        public List<HistoricoModuloUI> Modulos { get; set; } = new();
    }

    public class HistoricoModuloUI
    {
        public string AnoLetivo { get; set; } = "";
        public string ModuloNome { get; set; } = "";
        public string Professor { get; set; } = "";
        public decimal MediaFinal { get; set; }
        public string Status { get; set; } = "";
    }
}