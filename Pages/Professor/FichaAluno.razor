@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.Security.Claims
@inject AlunoService AlunoService
@inject TrabalhoService TrabalhoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<style>
    @@keyframes pulse-red {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
        }

        70% {
            transform: scale(1);
            box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
        }

        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }

    .btn-recuperar-urgente {
        animation: pulse-red 2s infinite;
    }

    .modal-backdrop {
        opacity: 0.5;
    }

    .progress-label {
        font-size: 0.75rem;
        font-weight: bold;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0 text-dark">Ficha Técnica: @(AlunoSelecionado?.Nome ?? "Carregando...")</h2>
            <p class="text-muted mb-0">Controle de Carga Horária e Aproveitamento por Módulo</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success rounded-pill px-4 shadow-sm" @onclick="IrParaAvaliacao">
                <i class="bi bi-plus-circle me-2"></i>Avaliar Aluno
            </button>
            <button class="btn btn-outline-secondary rounded-pill" @onclick="VoltarParaDashboard">Voltar</button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 30%;">Módulo / Disciplina</th>
                            <th style="width: 20%;">Carga Horária (Progresso)</th>
                            <th style="width: 30%;">Média por Vertente</th>
                            <th class="text-center" style="width: 20%;">Média Final / Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in PanoramaModulos)
                        {
                            // REGRAS DE INTEGRIDADE
                            bool temVertentesNegativas = m.MediasPorTipo.Any(v => v.Value < 9.5m);
                            bool cargaHorariaCompleta = m.HorasConsumidas >= m.HorasTotais && m.HorasTotais > 0;
                            bool emRecuperacao = VertentesCriticas.Any(vc => vc.ModuloId == m.ModuloId && vc.TemRecuperacaoAtiva);

                            <tr>
                                <td>
                                    <div class="fw-bold text-primary mb-0" style="font-size: 1.1rem;">@m.ModuloNome</div>
                                    <div class="text-muted small">@m.DisciplinaNome</div>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="progress-label">@m.HorasConsumidas / @m.HorasTotais h</span>
                                        @if (cargaHorariaCompleta)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                    </div>
                                    <div class="progress" style="height: 8px; border-radius: 4px;">
                                        <div class="progress-bar @(cargaHorariaCompleta ? "bg-success" : "bg-primary")"
                                             style="width: @(m.CalcularPercentualHoras())%"></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var v in m.MediasPorTipo)
                                        {
                                            <span class="badge @(v.Value >= 9.5m ? "bg-light text-success border-success" : "bg-light text-danger border-danger") border px-2 py-1">
                                                @v.Key: @v.Value.ToString("F1")
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (!cargaHorariaCompleta)
                                    {
                                        <div class="py-1">
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary fw-bold px-3 py-2">
                                                <i class="bi bi-clock-history me-1"></i> AGUARDAR HORAS
                                            </span>
                                        </div>
                                    }
                                    else if (temVertentesNegativas)
                                    {
                                        @if (emRecuperacao)
                                        {
                                            <span class="badge bg-warning text-dark border border-warning fw-bold px-3 py-2">
                                                <i class="bi bi-arrow-repeat me-1"></i> EM REVISÃO
                                            </span>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column align-items-center gap-1">
                                                <span class="badge bg-danger text-white fw-bold px-3 py-2 shadow-sm">
                                                    <i class="bi bi-lock-fill me-1"></i> BLOQUEADO
                                                </span>
                                                <small class="text-danger fw-bold" style="font-size: 0.7rem;">VERTENTE ABAIXO DE 9.5</small>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        @* LIBERADO: Carga completa e notas OK *@
                                        <div class="d-flex flex-column align-items-center">
                                            <span class="badge bg-success fs-5 px-4 shadow-sm" style="border-radius: 10px;">
                                                @m.MediaGlobal.ToString("F1")
                                            </span>
                                            <small class="text-success fw-bold" style="font-size: 0.7rem; margin-top: 4px;">APROVADO</small>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? AlunoSelecionado;
    private List<ModuloAnalise> PanoramaModulos = new();
    private List<CriticaModel> VertentesCriticas = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        try
        {
            IsLoading = true;
            AlunoSelecionado = await AlunoService.GetAlunoByIdAsync(AlunoId);
            if (AlunoSelecionado?.UserId != null)
            {
                var trabalhos = await TrabalhoService.GetTrabalhosDoAlunoComVertentesAsync(AlunoSelecionado.UserId);
                ProcessarDados(trabalhos ?? new List<Trabalho>());
            }
        }
        finally { IsLoading = false; }
    }

    private void ProcessarDados(List<Trabalho> trabalhos)
    {
        VertentesCriticas.Clear();
        PanoramaModulos.Clear();

        // Agrupamento por ModuloId para garantir que tratamos cada módulo individualmente
        var grupos = trabalhos.GroupBy(t => t.ModuloId);

        foreach (var grupo in grupos)
        {
            var primeiro = grupo.FirstOrDefault(t => t.Modulo != null) ?? grupo.First();
            var moduloId = grupo.Key ?? 0;

            // Médias por tipo de vertente
            var mediasVertentes = grupo.SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                .Where(v => v.Nota.HasValue)
                .GroupBy(v => v.Tipo)
                .Select(g => new { Tipo = g.Key ?? "Geral", Media = g.Average(v => v.Nota!.Value) })
                .ToDictionary(x => x.Tipo, x => x.Media);

            // Identificar se há recuperações pendentes (não avaliadas) para este módulo
            bool recAtiva = trabalhos.Any(t => t.ModuloId == moduloId && t.IsPlanoRecuperacao && t.Status != "Avaliado");

            // Mapeia para a lista de críticas se houver nota baixa
            foreach (var mv in mediasVertentes.Where(x => x.Value < 9.5m))
            {
                VertentesCriticas.Add(new CriticaModel
                {
                    ModuloId = moduloId,
                    ModuloNome = primeiro.Modulo?.Nome ?? "Módulo Desconhecido",
                    TipoVertente = mv.Key,
                    NotaMedia = mv.Value,
                    TemRecuperacaoAtiva = recAtiva
                });
            }

            PanoramaModulos.Add(new ModuloAnalise
            {
                ModuloId = moduloId,
                ModuloNome = primeiro.Modulo?.Nome ?? "Módulo " + moduloId,
                DisciplinaNome = primeiro.Disciplina?.Nome ?? "N/A",
                HorasTotais = primeiro.Modulo?.TotalHoras ?? 0,
                HorasConsumidas = grupo.Sum(x => x.HorasAtribuidas),
                MediasPorTipo = mediasVertentes,
                MediaGlobal = mediasVertentes.Any() ? mediasVertentes.Values.Average() : 0
            });
        }
    }

    private void IrParaAvaliacao() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}");
    private void VoltarParaDashboard() => Nav.NavigateTo("/professor/DashboardProfessor");

    public class ModuloAnalise
    {
        public int ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string DisciplinaNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public decimal MediaGlobal { get; set; }
        public Dictionary<string, decimal> MediasPorTipo { get; set; } = new();
        public double CalcularPercentualHoras() => HorasTotais > 0 ? Math.Min(100, (double)(HorasConsumidas * 100) / HorasTotais) : 0;
    }

    public class CriticaModel
    {
        public int ModuloId { get; set; }
        public string ModuloNome { get; set; } = "";
        public string TipoVertente { get; set; } = "";
        public decimal NotaMedia { get; set; }
        public bool TemRecuperacaoAtiva { get; set; }
    }
}