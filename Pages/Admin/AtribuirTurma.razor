@page "/admin/AtribuirTurma"
@namespace gestaopedagogica.Pages.Admin
@layout MainLayout
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject TurmaService TurmaService
@inject ProfessorService ProfessorService
@inject AlunoService AlunoService
@inject ModuloService ModuloService
@inject DisciplinaService DisciplinaService
@inject NavigationManager NavigationManager

<div class="container mt-4 animate-fade-in">
    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header bg-primary text-white p-4">
            <div class="d-flex align-items-center">
                <div class="icon-box me-3">
                    <i class="bi bi-link-45deg fs-3"></i>
                </div>
                <div>
                    <h4 class="mb-0 fw-bold">Vincular à Turma</h4>
                    <small class="opacity-75">Gestão de professores, alunos e módulos por turma</small>
                </div>
            </div>
        </div>

        <div class="card-body p-4 bg-light-subtle">
            @if (IsLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-grow text-primary" role="status"></div>
                    <p class="mt-3 text-muted fw-semibold">Carregando dados do sistema...</p>
                </div>
            }
            else
            {
                <div class="mb-5 text-center">
                    <label class="form-label fw-bold text-secondary mb-3">O QUE DESEJA VINCULAR?</label>
                    <div class="d-flex justify-content-center">
                        <div class="btn-group p-1 bg-white shadow-sm rounded-pill" role="group">
                            <button type="button" class="btn rounded-pill px-4 @(TipoVinculo == "Professor" ? "btn-primary" : "btn-light")" @onclick='() => SetTipo("Professor")'>
                                <i class="bi bi-person-badge me-2"></i>Professor
                            </button>
                            <button type="button" class="btn rounded-pill px-4 @(TipoVinculo == "Aluno" ? "btn-primary" : "btn-light")" @onclick='() => SetTipo("Aluno")'>
                                <i class="bi bi-people me-2"></i>Aluno
                            </button>
                            <button type="button" class="btn rounded-pill px-4 @(TipoVinculo == "Modulo" ? "btn-success" : "btn-light")" @onclick='() => SetTipo("Modulo")'>
                                <i class="bi bi-journal-text me-2"></i>Módulo
                            </button>
                        </div>
                    </div>
                </div>

                <div class="row g-4 justify-content-center">
                    @if (TipoVinculo == "Professor")
                    {
                        <div class="col-md-5">
                            <div class="form-group-custom">
                                <label class="form-label fw-bold"><i class="bi bi-person me-2"></i>Professor</label>
                                <select class="form-select rounded-pill shadow-sm" @bind="SelectedProfessorId">
                                    <option value="0">Selecione o professor...</option>
                                    @foreach (var prof in ListaProfessores)
                                    {
                                        <option value="@prof.Id">@prof.Nome</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="form-group-custom">
                                <label class="form-label fw-bold text-primary"><i class="bi bi-book me-2"></i>Disciplina a Lecionar</label>
                                <select class="form-select rounded-pill shadow-sm border-primary" @bind="SelectedDisciplinaId">
                                    <option value="0">Selecione a disciplina...</option>
                                    @foreach (var disc in ListaDisciplinas)
                                    {
                                        <option value="@disc.Id">@disc.Nome</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }
                    else if (TipoVinculo == "Aluno")
                    {
                        <div class="col-md-10">
                            <div class="form-group-custom">
                                <label class="form-label fw-bold"><i class="bi bi-person-bounding-box me-2"></i>Aluno</label>
                                <select class="form-select rounded-pill shadow-sm" @bind="SelectedAlunoId">
                                    <option value="0">Selecione um aluno...</option>
                                    @foreach (var aluno in ListaAlunos)
                                    {
                                        <option value="@aluno.Id">@aluno.Nome (@(aluno.Turma?.Nome ?? "Sem Turma"))</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }
                    else if (TipoVinculo == "Modulo")
                    {
                        <div class="col-md-10">
                            <div class="form-group-custom">
                                <label class="form-label fw-bold"><i class="bi bi-collection me-2"></i>Módulo</label>
                                <select class="form-select rounded-pill shadow-sm" @bind="SelectedModuloId">
                                    <option value="0">Selecione um módulo...</option>
                                    @foreach (var modulo in ListaModulos)
                                    {
                                        <option value="@modulo.Id">@modulo.Nome</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }

                    <div class="col-md-10 mt-4">
                        <div class="p-4 border-dashed rounded-4 text-center bg-white shadow-sm">
                            <label class="form-label fw-bold text-uppercase small text-muted d-block mb-3">Turma de Destino</label>
                            <div class="d-flex justify-content-center">
                                <select class="form-select rounded-pill shadow-sm w-75 border-warning" @bind="SelectedTurmaId" style="border-width: 2px;">
                                    <option value="0">--- Selecione a Turma Alvo ---</option>
                                    @foreach (var turma in ListaTurmas)
                                    {
                                        <option value="@turma.Id">@turma.Nome</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Message))
                {
                    <div class="row justify-content-center mt-4">
                        <div class="col-md-8">
                            <div class="alert @(Message.Contains("✅") ? "alert-success" : "alert-warning") border-0 shadow-sm animate-bounce-in">
                                <div class="d-flex align-items-center">
                                    <span class="fs-4 me-3">@(Message.Contains("✅") ? "✔️" : "⚠️")</span>
                                    <div>@Message</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-5 d-flex justify-content-center gap-3">
                    <button class="btn btn-success rounded-pill px-5 py-2 fw-bold shadow-sm" @onclick="HandleAtribuicao" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-circle me-2"></i>Confirmar Vinculação
                    </button>
                    <a href="/admin/DashboardAdmin" class="btn btn-outline-secondary rounded-pill px-5 py-2">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // ... (Mantém o teu código C# original aqui, ele está correto logicamente)
    // Apenas certifique-se de que o href do cancelar aponte para "DashboardAdmin" como no @page anterior
    private List<Professor> ListaProfessores = new();
    private List<Aluno> ListaAlunos = new();
    private List<Turma> ListaTurmas = new();
    private List<Modulo> ListaModulos = new();
    private List<Disciplina> ListaDisciplinas = new();

    private int SelectedProfessorId;
    private int SelectedAlunoId;
    private int SelectedTurmaId;
    private int SelectedModuloId;
    private int SelectedDisciplinaId;

    private string TipoVinculo = "Professor";
    private bool IsLoading = true;
    private bool IsSaving = false;
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        Message = "";
        try
        {
            ListaDisciplinas = await DisciplinaService.GetDisciplinasAsync() ?? new();
            ListaProfessores = await ProfessorService.GetProfessoresAsync() ?? new();
            ListaAlunos = await AlunoService.GetAlunosAsync() ?? new();
            ListaModulos = await ModuloService.GetModulosAsync() ?? new();
            ListaTurmas = await TurmaService.GetTurmasSimplesAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        IsLoading = false;
    }

    private void SetTipo(string tipo)
    {
        TipoVinculo = tipo;
        Message = "";
        StateHasChanged();
    }

    private async Task HandleAtribuicao()
    {
        if (SelectedTurmaId == 0) { Message = "⚠️ Selecione uma turma destino."; return; }
        IsSaving = true;
        Message = "";

        try
        {
            if (TipoVinculo == "Professor")
            {
                if (SelectedProfessorId == 0 || SelectedDisciplinaId == 0)
                { Message = "⚠️ Selecione o professor e a disciplina."; }
                else
                {
                    await TurmaService.AddTurmaProfessorAsync(SelectedTurmaId, SelectedProfessorId, SelectedDisciplinaId);
                    Message = "✅ Professor vinculado com sucesso!";
                }
            }
            else if (TipoVinculo == "Aluno")
            {
                if (SelectedAlunoId == 0) { Message = "⚠️ Selecione um aluno."; }
                else
                {
                    var aluno = await AlunoService.GetAlunoByIdAsync(SelectedAlunoId);
                    if (aluno != null)
                    {
                        aluno.TurmaId = SelectedTurmaId;
                        await AlunoService.UpdateAlunoAsync(aluno);
                        Message = "✅ Aluno movido para a turma com sucesso!";
                    }
                }
            }
            else if (TipoVinculo == "Modulo")
            {
                if (SelectedModuloId == 0) { Message = "⚠️ Selecione um módulo."; }
                else
                {
                    await TurmaService.AddTurmaModuloAsync(SelectedTurmaId, SelectedModuloId);
                    Message = "✅ Módulo vinculado à turma com sucesso!";
                }
            }

            if (Message.StartsWith("✅"))
            {
                SelectedProfessorId = 0;
                SelectedAlunoId = 0;
                SelectedModuloId = 0;
                SelectedDisciplinaId = 0;
            }
        }
        catch (Exception ex)
        {
            Message = "❌ Erro ao gravar: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }
}