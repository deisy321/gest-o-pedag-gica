@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@using System.Globalization
@inject TrabalhoService TrabalhoService
@inject AlunoService AlunoService
@inject NavigationManager Nav

<div class="container-fluid animate-fade-in pb-5">
    @if (aluno == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="mb-4">
            <h1 class="fw-bold mb-0">Ficha Técnica: @aluno.Nome</h1>
            <p class="text-muted">Controle de Carga Horária e Aproveitamento por Módulo</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Módulo / Disciplina</th>
                            <th>Carga Horária (Progresso)</th>
                            <th>Média por Vertente</th>
                            <th class="text-center">Média Final / Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in ModulosProcessados)
                        {
                            <tr class="@(m.StatusCritico == "Vermelho" ? "table-danger" : m.StatusCritico == "Amarelo" ? "table-warning" : "")">
                                <td class="ps-4">
                                    <h6 class="text-primary fw-bold mb-0">@m.Nome</h6>
                                    @if (m.StatusCritico == "Vermelho")
                                    {
                                        <span class="badge bg-danger mt-1"><i class="fas fa-exclamation-triangle"></i> Vertente Crítica Detectada</span>
                                    }
                                    else if (m.StatusCritico == "Amarelo")
                                    {
                                        <span class="badge bg-warning text-dark mt-1"><i class="fas fa-clock"></i> Plano de Recuperação em Curso</span>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Desempenho Regular</small>
                                    }
                                </td>
                                <td style="width: 250px;">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-bold">@m.HorasConsumidas / @m.HorasTotais h</small>
                                        @if (m.HorasConsumidas >= m.HorasTotais)
                                        {
                                            <i class="fas fa-check-circle text-success"></i>
                                        }
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        @{
                                            var percent = m.HorasTotais > 0 ? Math.Min((m.HorasConsumidas * 100) / m.HorasTotais, 100) : 0;
                                        }
                                        <div class="progress-bar bg-success" style="width: @(percent)%"></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <div class="d-flex gap-2">
                                            <span class="badge border @(m.MediaCompParcial < 9.5 && m.MediaCompParcial > 0 ? "text-danger border-danger" : "text-muted") p-2">Comp: @m.MediaCompParcial.ToString("F1")</span>
                                            <span class="badge border @(m.MediaConhParcial < 9.5 && m.MediaConhParcial > 0 ? "text-danger border-danger" : "text-muted") p-2">Conh: @m.MediaConhParcial.ToString("F1")</span>
                                            <span class="badge border @(m.MediaAptParcial < 9.5 && m.MediaAptParcial > 0 ? "text-danger border-danger" : "text-muted") p-2">Apt: @m.MediaAptParcial.ToString("F1")</span>
                                        </div>

                                        @if (m.StatusCritico == "Vermelho")
                                        {
                                            <button class="btn btn-sm btn-danger mt-2 fw-bold" @onclick="() => AbrirModalRecuperacao(m.ModuloId, m.Nome)">
                                                <i class="fas fa-tools"></i> Criar Plano de Recuperação
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (m.ProntoParaMediaFinal)
                                    {
                                        <div class="bg-success text-white rounded p-2 d-inline-block" style="min-width: 80px;">
                                            <h4 class="mb-0 fw-bold">@m.MediaGlobal.ToString("F1")</h4>
                                        </div>
                                        <div class="small text-success fw-bold mt-1">APROVADO</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2">PENDENTE</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 mb-5">
            <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" @onclick="Voltar">
                <i class="fas fa-arrow-left"></i> Voltar
            </button>
            <button type="button" class="btn btn-success px-4 shadow-sm" @onclick="IrParaAvaliar">
                <i class="fas fa-plus"></i> Avaliar Aluno
            </button>
        </div>
    }
</div>

@if (exibirModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-tools"></i> Novo Plano de Recuperação</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    <p>Módulo: <strong>@moduloSelecionadoNome</strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Atividade de Recuperação</label>
                        <textarea class="form-control" rows="3" @bind="descricaoRecuperacao" placeholder="Descreva o que o aluno deve realizar..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="FecharModal">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="SalvarRecuperacao">Salvar e Atribuir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? aluno;
    private List<ModuloResumoUI> ModulosProcessados = [];
    private List<Trabalho> ListaOriginalTrabalhos = [];
    private bool exibirModal = false;
    private int moduloSelecionadoId;
    private string moduloSelecionadoNome = "";
    private string descricaoRecuperacao = "";

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        aluno = await AlunoService.GetAlunoByIdAsync(AlunoId);
        if (aluno != null)
        {
            ListaOriginalTrabalhos = await TrabalhoService.GetTrabalhosByAlunoAsync(aluno.UserId);
            ProcessarLogicaVisual(ListaOriginalTrabalhos);
        }
    }

    private void Voltar() => Nav.NavigateTo("/professor/DashboardProfessor");
    private void IrParaAvaliar() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}");
    private void AbrirModalRecuperacao(int id, string nome) { moduloSelecionadoId = id; moduloSelecionadoNome = nome; exibirModal = true; }
    private void FecharModal() => exibirModal = false;

    private async Task SalvarRecuperacao()
    {
        if (aluno == null || string.IsNullOrWhiteSpace(descricaoRecuperacao)) return;

        var refTrabalho = ListaOriginalTrabalhos.FirstOrDefault(t => t.ModuloId == moduloSelecionadoId);
        var resumoModulo = ModulosProcessados.FirstOrDefault(m => m.ModuloId == moduloSelecionadoId);

        if (resumoModulo == null) return;

        try
        {
            var trabalhoQualquer = ListaOriginalTrabalhos.FirstOrDefault();

            var novoTrabalho = new Trabalho
            {
                Titulo = "Recuperação",
                ConteudoTexto = descricaoRecuperacao,
                AlunoId = aluno.UserId,
                ModuloId = moduloSelecionadoId,
                DisciplinaId = refTrabalho?.DisciplinaId ?? trabalhoQualquer?.DisciplinaId,
                ProfessorId = refTrabalho?.ProfessorId ?? trabalhoQualquer?.ProfessorId ?? "",
                Status = "Pendente",
                IsPlanoRecuperacao = true,
                DataCriacao = DateTime.Now,
                PrazoEntrega = DateTime.Now.AddDays(7),
                HorasAtribuidas = 0,
                Ativo = true
            };

            var trabalhoId = await TrabalhoService.AddTrabalhoAsync(novoTrabalho);

            string tipoVertente = "Conhecimento";
            if (resumoModulo.MediaCompParcial < 9.5 && resumoModulo.MediaCompParcial > 0) tipoVertente = "Competência";
            else if (resumoModulo.MediaAptParcial < 9.5 && resumoModulo.MediaAptParcial > 0) tipoVertente = "Aptidão";

            await TrabalhoService.AddVertenteAsync(new TrabalhoVertente
            {
                TrabalhoId = trabalhoId,
                Tipo = tipoVertente,
                ConteudoTexto = "Recuperação de: " + tipoVertente
            });

            descricaoRecuperacao = "";
            exibirModal = false;
            await CarregarDados();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao salvar recuperação: {ex.Message}");
        }
    }

    private void ProcessarLogicaVisual(List<Trabalho> trabalhos)
    {
        ModulosProcessados = trabalhos
            .GroupBy(t => t.ModuloId)
            .Select(grupo =>
            {
                var moduloId = grupo.Key ?? 0;
                var modulo = grupo.First().Modulo;
                var lista = grupo.ToList();

                double ObterNotaFinalVertente(string termoBusca)
                {
                    termoBusca = termoBusca.ToLower();

                    // 1. BUSCA NA RECUPERAÇÃO (Prioridade Máxima)
                    // Buscamos se existe nota na vertente, independente do status do trabalho pai
                    var notaRec = lista
                        .Where(t => t.Titulo != null && t.Titulo.ToLower().Contains("recuper"))
                        .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                        .Where(v => v.Tipo != null &&
                                    v.Tipo.ToLower().Contains(termoBusca.Substring(0, 4)) &&
                                    v.Nota.HasValue)
                        .OrderByDescending(v => v.Id)
                        .Select(v => (double?)v.Nota)
                        .FirstOrDefault();

                    if (notaRec.HasValue) return notaRec.Value;

                    // 2. MÉDIA DOS TRABALHOS NORMAIS
                    var notasNormais = lista
                        .Where(t => t.Titulo == null || !t.Titulo.ToLower().Contains("recuper"))
                        .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                        .Where(v => v.Tipo != null &&
                                    v.Tipo.ToLower().Contains(termoBusca.Substring(0, 4)) &&
                                    v.Nota.HasValue)
                        .Select(v => (double)v.Nota!)
                        .ToList();

                    return notasNormais.Any() ? notasNormais.Average() : 0;
                }

                // Obtendo médias usando radicais para evitar erros de acentuação
                double mComp = ObterNotaFinalVertente("comp");
                double mConh = ObterNotaFinalVertente("conh");
                double mApt = ObterNotaFinalVertente("apti");

                // Lógica de Status Baseada em Dados
                var trabalhosRec = lista.Where(t => t.Titulo != null && t.Titulo.ToLower().Contains("recuper")).ToList();
                bool existeRec = trabalhosRec.Any();

                // Uma recuperação é considerada "Avaliada" se houver pelo menos uma nota lançada em suas vertentes
                bool recAvaliada = trabalhosRec.Any(t => t.TrabalhoVertentes != null && t.TrabalhoVertentes.Any(v => v.Nota.HasValue));
                bool recupPendente = existeRec && !recAvaliada;

                bool temNotaBaixa = (mComp > 0 && mComp < 9.5) || (mConh > 0 && mConh < 9.5) || (mApt > 0 && mApt < 9.5);

                string statusCor = "Verde";
                if (recupPendente) statusCor = "Amarelo";
                else if (temNotaBaixa) statusCor = "Vermelho";

                // Verificação de Aprovação (Horas + Notas + Sem Pendências)
                int hCons = lista.Sum(t => t.HorasAtribuidas);
                int hTot = modulo?.TotalHoras ?? 0;
                bool aprovado = hCons >= hTot && mComp >= 9.5 && mConh >= 9.5 && mApt >= 9.5 && !recupPendente;

                return new ModuloResumoUI
                {
                    ModuloId = moduloId,
                    Nome = modulo?.Nome ?? "Módulo",
                    HorasTotais = hTot,
                    HorasConsumidas = hCons,
                    MediaCompParcial = mComp,
                    MediaConhParcial = mConh,
                    MediaAptParcial = mApt,
                    MediaGlobal = (mComp + mConh + mApt) / 3,
                    ProntoParaMediaFinal = aprovado,
                    StatusCritico = statusCor
                };
            }).ToList();
    }

    public class ModuloResumoUI
    {
        public int ModuloId { get; set; }
        public string Nome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public double MediaCompParcial { get; set; }
        public double MediaConhParcial { get; set; }
        public double MediaAptParcial { get; set; }
        public double MediaGlobal { get; set; }
        public bool ProntoParaMediaFinal { get; set; }
        public string StatusCritico { get; set; } = "Verde";
    }
}