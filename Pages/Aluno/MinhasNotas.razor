@page "/aluno/MinhasNotas"
@using gestaopedagogica.Services
@using gestaopedagogica.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject TrabalhoService TrabalhoService

<div class="container mt-4">
    <h3 class="fw-bold mb-4">O Meu Desempenho</h3>

    @if (DisciplinasAgrupadas != null && DisciplinasAgrupadas.Any())
    {
        @foreach (var disciplina in DisciplinasAgrupadas)
        {
            <div class="mb-5">
                <!-- Título da Disciplina -->
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary rounded-circle me-2" style="width: 12px; height: 12px;"></div>
                    <h4 class="fw-bold m-0 text-dark">@disciplina.Key</h4>
                    <hr class="flex-grow-1 ms-3 opacity-25">
                </div>

                <div class="row">
                    @foreach (var modulo in disciplina.Modulos)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card shadow-sm border-0 @(modulo.EstaBloqueado ? "border-start border-danger border-5" : "border-start border-primary border-5")" style="border-radius: 12px;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h5 class="fw-bold mb-0">@modulo.ModuloNome</h5>
                                            <small class="text-muted">@modulo.HorasTotais h totais</small>
                                        </div>
                                        <div class="text-end">
                                            @if (modulo.EstaBloqueado)
                                            {
                                                <div class="text-danger" title="Módulo retido por negativa em vertente específica">
                                                    <i class="bi bi-lock-fill fs-5"></i>
                                                    <span class="d-block fw-bold" style="font-size: 0.7rem;">BLOQUEADO</span>
                                                </div>
                                            }
                                            else if (modulo.Concluido)
                                            {
                                                <span class="badge bg-success fs-6 shadow-sm">Nota Final: @modulo.Media.ToString("F1")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Em Curso</span>
                                            }
                                        </div>
                                    </div>

                                    @if (modulo.EstaBloqueado)
                                    {
                                        <div class="alert alert-danger py-1 px-2 mb-2" style="font-size: 0.8rem;">
                                            <i class="bi bi-exclamation-circle me-1"></i>
                                            Recuperação em: <strong>@string.Join(", ", modulo.VertentesCriticas)</strong>
                                        </div>
                                    }

                                    <div class="mt-3">
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>Progresso: @modulo.HorasAtuais h</span>
                                            <span>@(modulo.HorasTotais > 0 ? (modulo.HorasAtuais * 100 / modulo.HorasTotais) : 0)%</span>
                                        </div>
                                        <div class="progress" style="height: 8px; border-radius: 4px; background-color: #e9ecef;">
                                            <div class="progress-bar @(modulo.EstaBloqueado ? "bg-warning" : (modulo.Concluido ? "bg-success" : "bg-primary"))"
                                                 role="progressbar"
                                                 style="width: @(modulo.HorasTotais > 0 ? Math.Min(100, modulo.HorasAtuais * 100 / modulo.HorasTotais) : 0)%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center p-5 text-muted">
            <i class="bi bi-folder-x fs-1"></i>
            <p>Nenhum registo encontrado.</p>
        </div>
    }

    <!-- Histórico Detalhado -->
    <div class="card shadow-sm border-0 p-4 mt-4" style="border-radius: 15px;">
        <h5 class="fw-bold mb-3">Histórico de Avaliações</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Trabalho / Módulo</th>
                        <th>Vertente</th>
                        <th class="text-center">Nota</th>
                        <th>Feedback do Professor</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @if (trabalhos != null && trabalhos.Any())
                    {
                        @foreach (var trabalho in trabalhos.OrderByDescending(t => t.DataCriacao))
                        {
                            @foreach (var vert in trabalho.TrabalhoVertentes.Where(v => v.Nota.HasValue || !string.IsNullOrEmpty(v.Feedback)))
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@trabalho.Titulo</div>
                                        <small class="text-muted">@trabalho.Modulo?.Nome</small>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@vert.Tipo</span></td>
                                    <td class="text-center">
                                        <span class="fw-bold @(vert.Nota >= 9.5m ? "text-success" : "text-danger")">
                                            @(vert.Nota.HasValue? vert.Nota.Value.ToString("F1") : "-")
                                        </span>
                                    </td>
                                    <td class="small text-muted" style="max-width: 300px;">
                                        @(!string.IsNullOrEmpty(vert.Feedback) ? vert.Feedback : "Sem comentários")
                                    </td>
                                    <td><small>@(vert.DataEnvio?.ToShortDateString() ?? "-")</small></td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Trabalho> trabalhos = new();
    private List<DisciplinaAgrupada> DisciplinasAgrupadas = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            // CORREÇÃO: Nome do método ajustado para GetTrabalhosDoAlunoAsync
            trabalhos = await TrabalhoService.GetTrabalhosDoAlunoAsync(userId);
            ProcessarResumoPorDisciplina();
        }
    }

    private void ProcessarResumoPorDisciplina()
    {
        if (trabalhos == null) return;

        DisciplinasAgrupadas = trabalhos
            .GroupBy(t => t.Disciplina?.Nome ?? "Outros")
            .Select(gd => new DisciplinaAgrupada
            {
                Key = gd.Key,
                Modulos = gd.GroupBy(m => new { m.ModuloId, Nome = m.Modulo?.Nome ?? "Geral", Horas = m.Modulo?.TotalHoras ?? 25 })
                .Select(g =>
                {
                    var statusVertentes = g.SelectMany(t => t.TrabalhoVertentes)
                        .Where(v => v.Nota.HasValue)
                        .GroupBy(v => v.Tipo)
                        .Select(vType => new
                        {
                            Tipo = vType.Key,
                            MelhorNota = (double)vType.Max(x => x.Nota!.Value)
                        }).ToList();

                    var criticas = statusVertentes.Where(x => x.MelhorNota < 9.5).Select(x => x.Tipo ?? "Indefinida").ToList();

                    return new ModuloResumo
                    {
                        ModuloNome = g.Key.Nome,
                        HorasTotais = g.Key.Horas,
                        HorasAtuais = g.Sum(t => t.HorasAtribuidas),
                        Media = statusVertentes.Any() ? statusVertentes.Average(v => v.MelhorNota) : 0,
                        VertentesCriticas = criticas
                    };
                }).ToList()
            }).OrderBy(d => d.Key).ToList();
    }

    public class DisciplinaAgrupada
    {
        public string Key { get; set; } = "";
        public List<ModuloResumo> Modulos { get; set; } = new();
    }

    public class ModuloResumo
    {
        public string ModuloNome { get; set; } = "";
        public int HorasTotais { get; set; }
        public int HorasAtuais { get; set; }
        public double Media { get; set; }
        public List<string> VertentesCriticas { get; set; } = new();
        public bool EstaBloqueado => VertentesCriticas.Any();
        public bool Concluido => HorasAtuais >= HorasTotais && !EstaBloqueado;
    }
}