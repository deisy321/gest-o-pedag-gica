@page "/admin/GerirUtilizadores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using gestaopedagogica.Data
@using Microsoft.EntityFrameworkCore
@using gestaopedagogica.Services

@attribute [Authorize(Roles = "Administrador")]
@inject RoleManager<IdentityRole> RoleManager
@inject UserManager<ApplicationUser> UserManager
@inject UserService UserService
@inject IJSRuntime JS

@namespace gestaopedagogica.Pages.Admin
@layout MainLayout

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Gerir Utilizadores</h3>
    <button class="btn btn-primary" @onclick="MostrarCriar">Novo Utilizador</button>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Email</th>
            <th>Perfil</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (Usuarios == null || !Usuarios.Any())
        {
            <tr><td colspan="4" class="text-center">Nenhum utilizador encontrado.</td></tr>
        }
        else
        {
            @foreach (var user in Usuarios)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@(UserRoles.ContainsKey(user.Id) ? string.Join(", ", UserRoles[user.Id]) : "Sem Perfil")</td>
                    <td>
                        <button class="btn btn-warning btn-sm me-1" @onclick="() => ResetarSenha(user)">Resetar Senha</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => Remover(user)">Remover</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@if (MostrarModalCriar)
{
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:flex;justify-content:center;align-items:center;z-index:1000;">
        <div style="background:white;padding:20px;border-radius:8px;width:400px;">
            <h4>Novo Utilizador</h4>
            <input class="form-control mb-2" placeholder="Username" @bind="NovoUser.UserName" />
            <input class="form-control mb-2" placeholder="Email" @bind="NovoUser.Email" />
            <select class="form-control mb-2" @bind="NovoRole">
                @foreach (var r in Roles)
                {
                    <option value="@r">@r</option>
                }
            </select>
            <div class="mt-3">
                <button class="btn btn-success me-2" @onclick="SalvarNovo">Guardar</button>
                <button class="btn btn-secondary" @onclick="() => MostrarModalCriar = false">Cancelar</button>
            </div>
        </div>
    </div>
}

@code {

    private List<ApplicationUser> Usuarios = new();
    private Dictionary<string, List<string>> UserRoles = new();
    private List<string> Roles = new();
    private ApplicationUser NovoUser = new();
    private string NovoRole = "Professor";
    private bool MostrarModalCriar = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarUsuarios();
    }

    private async Task CarregarUsuarios()
    {
        Usuarios = await UserManager.Users.AsNoTracking().ToListAsync();
        Roles = await RoleManager.Roles.Select(r => r.Name!).ToListAsync();

        UserRoles.Clear();

        foreach (var u in Usuarios)
        {
            var rolesForUser = await UserManager.GetRolesAsync(u);
            UserRoles[u.Id] = rolesForUser.ToList();
        }
    }

    private void MostrarCriar()
    {
        NovoUser = new ApplicationUser();
        NovoRole = Roles.FirstOrDefault() ?? "Professor";
        MostrarModalCriar = true;
    }

    private async Task SalvarNovo()
    {
        if (string.IsNullOrWhiteSpace(NovoUser.UserName) || string.IsNullOrWhiteSpace(NovoUser.Email))
        {
            await JS.InvokeVoidAsync("alert", "Preencha todos os campos.");
            return;
        }

        var result = await UserManager.CreateAsync(new ApplicationUser
        {
            UserName = NovoUser.UserName,
            Email = NovoUser.Email
        }, "Temp123!");

        if (result.Succeeded)
        {
            var created = await UserManager.FindByNameAsync(NovoUser.UserName);

            if (created != null)
                await UserManager.AddToRoleAsync(created, NovoRole);

            await JS.InvokeVoidAsync("alert", "Criado com sucesso! Senha: Temp123!");
            MostrarModalCriar = false;

            await CarregarUsuarios();
        }
        else
        {
            await JS.InvokeVoidAsync("alert",
                "Erro ao criar: " + string.Join(", ", result.Errors.Select(e => e.Description)));
        }
    }

    private async Task ResetarSenha(ApplicationUser user)
    {
        var dbUser = await UserManager.FindByIdAsync(user.Id);

        if (dbUser == null)
        {
            await JS.InvokeVoidAsync("alert", "Utilizador não encontrado.");
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(dbUser);
        var result = await UserManager.ResetPasswordAsync(dbUser, token, "Temp123!");

        string msg = result.Succeeded ? "Senha resetada para Temp123!" : "Erro ao resetar.";

        await JS.InvokeVoidAsync("alert", msg);
    }

    private async Task Remover(ApplicationUser user)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja mesmo remover {user.UserName}?");

        if (!confirmado) return;

        try
        {
            await UserService.ExcluirUsuarioAsync(user.Id);
            await CarregarUsuarios();
            await JS.InvokeVoidAsync("alert", "Utilizador removido.");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro: " + ex.Message);
        }
    }

}