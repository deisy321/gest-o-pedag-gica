@page "/professor/FichaAluno/{AlunoId:int}"
@using gestaopedagogica.Models
@using gestaopedagogica.Services
@inject TrabalhoService TrabalhoService
@inject AlunoService AlunoService
@inject NavigationManager Nav

<div class="container-fluid animate-fade-in pb-5">
    @if (aluno == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="mb-4">
            <h1 class="fw-bold mb-0">Ficha Técnica: @aluno.Nome</h1>
            <p class="text-muted">Controle de Carga Horária e Aproveitamento por Módulo</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Módulo / Disciplina</th>
                            <th>Carga Horária</th>
                            <th>Média por Vertente</th>
                            <th class="text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in ModulosProcessados)
                        {
                            <tr class="@(m.StatusCritico == "Vermelho" ? "table-danger" : m.StatusCritico == "Amarelo" ? "table-warning" : "")">
                                <td class="ps-4">
                                    <h6 class="text-primary fw-bold mb-0">@m.Nome</h6>
                                    @if (m.StatusCritico == "Vermelho")
                                    {
                                        <span class="badge bg-danger mt-1"><i class="fas fa-exclamation-triangle"></i> Nota Crítica</span>
                                    }
                                    else if (m.StatusCritico == "Amarelo")
                                    {
                                        <span class="badge bg-warning text-dark mt-1"><i class="fas fa-clock"></i> Recuperação em Aberto</span>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Concluído/Regular</small>
                                    }
                                </td>
                                <td style="width: 200px;">
                                    <small class="fw-bold">@m.HorasConsumidas / @m.HorasTotais h</small>
                                    <div class="progress" style="height: 6px;">
                                        @{
                                            var percent = m.HorasTotais > 0 ? Math.Min((m.HorasConsumidas * 100) / m.HorasTotais, 100) : 0;
                                        }
                                        <div class="progress-bar bg-success" style="width: @(percent)%"></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <span class="badge border @(m.MediaCompParcial < 9.5 ? "text-danger border-danger" : "bg-light text-dark") p-2">
                                            Comp: @m.MediaCompParcial.ToString("F1")
                                        </span>
                                        <span class="badge border @(m.MediaConhParcial < 9.5 ? "text-danger border-danger" : "bg-light text-dark") p-2">
                                            Conh: @m.MediaConhParcial.ToString("F1")
                                        </span>
                                        <span class="badge border @(m.MediaAptParcial < 9.5 ? "text-danger border-danger" : "bg-light text-dark") p-2">
                                            Apt: @m.MediaAptParcial.ToString("F1")
                                        </span>
                                    </div>
                                    @if (m.StatusCritico == "Vermelho")
                                    {
                                        <button class="btn btn-sm btn-outline-danger mt-2" @onclick="() => AbrirModalRecuperacao(m.ModuloId, m.Nome)">
                                            + Plano de Recuperação
                                        </button>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (m.ProntoParaMediaFinal)
                                    {
                                        <span class="badge bg-success px-3 py-2">APROVADO (@m.MediaGlobal.ToString("F1"))</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">@m.StatusTexto</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <button class="btn btn-outline-secondary" @onclick="Voltar">Voltar</button>
            <button class="btn btn-primary" @onclick="IrParaAvaliar">Avaliar Aluno</button>
        </div>
    }
</div>

@if (exibirModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Novo Plano de Recuperação</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    <label>Descrição da Atividade:</label>
                    <textarea class="form-control" @bind="descricaoRecuperacao"></textarea>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FecharModal">Sair</button>
                    <button class="btn btn-danger" @onclick="SalvarRecuperacao">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int AlunoId { get; set; }
    private Aluno? aluno;
    private List<ModuloResumoUI> ModulosProcessados = new();
    private List<Trabalho> ListaOriginalTrabalhos = new();
    private bool exibirModal = false;
    private int moduloSelecionadoId;
    private string moduloSelecionadoNome = "";
    private string descricaoRecuperacao = "";

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        aluno = await AlunoService.GetAlunoByIdAsync(AlunoId);
        if (aluno != null)
        {
            // Importante: Verifique se o serviço está trazendo as Vertentes incluídas (.Include(t => t.TrabalhoVertentes))
            ListaOriginalTrabalhos = await TrabalhoService.GetTrabalhosByAlunoAsync(aluno.UserId);
            ProcessarLogicaVisual(ListaOriginalTrabalhos);
        }
    }

    private void ProcessarLogicaVisual(List<Trabalho> trabalhos)
    {
        ModulosProcessados = trabalhos
            .GroupBy(t => t.ModuloId)
            .Select(grupo =>
            {
                var moduloId = grupo.Key ?? 0;
                var modulo = grupo.First().Modulo;
                var todosTrabalhosMódulo = grupo.ToList();

                double ObterNotaDefinitiva(string tipo)
                {
                    // 1. Procurar em trabalhos de Recuperação AVALIADOS (do mais novo para o mais antigo)
                    var notaRecuperacao = todosTrabalhosMódulo
                        .Where(t => t.Titulo != null && t.Titulo.Contains("Recuperação") && t.Status == "Avaliado")
                        .OrderByDescending(t => t.Id) // O mais recente primeiro
                        .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                        .FirstOrDefault(v => v.Tipo == tipo && v.Nota.HasValue)?.Nota;

                    if (notaRecuperacao.HasValue) return (double)notaRecuperacao.Value;

                    // 2. Se não achou recuperação, faz a média dos normais
                    var notasNormais = todosTrabalhosMódulo
                        .Where(t => t.Titulo == null || !t.Titulo.Contains("Recuperação"))
                        .SelectMany(t => t.TrabalhoVertentes ?? new List<TrabalhoVertente>())
                        .Where(v => v.Tipo == tipo && v.Nota.HasValue)
                        .ToList();

                    return notasNormais.Any() ? notasNormais.Average(v => (double)v.Nota!) : 0;
                }

                double mediaComp = ObterNotaDefinitiva("Competência");
                double mediaConh = ObterNotaDefinitiva("Conhecimento");
                double mediaApt = ObterNotaDefinitiva("Aptidão");

                // CRÍTICO: Um módulo só é "AMARELO" se existir um trabalho de recuperação que ainda NÃO foi avaliado
                bool temRecuperacaoPendente = todosTrabalhosMódulo.Any(t =>
                    t.Titulo != null &&
                    t.Titulo.Contains("Recuperação") &&
                    t.Status != "Avaliado");

                bool notaBaixa = (mediaComp > 0 && mediaComp < 9.5) ||
                                 (mediaConh > 0 && mediaConh < 9.5) ||
                                 (mediaApt > 0 && mediaApt < 9.5);

                string statusCor = "Verde";
                if (temRecuperacaoPendente) statusCor = "Amarelo";
                else if (notaBaixa) statusCor = "Vermelho";

                int hCons = todosTrabalhosMódulo.Sum(t => t.HorasAtribuidas);
                int hTot = modulo?.TotalHoras ?? 0;

                bool aprovado = hCons >= hTot && mediaComp >= 9.5 && mediaConh >= 9.5 && mediaApt >= 9.5 && !temRecuperacaoPendente;

                return new ModuloResumoUI
                {
                    ModuloId = moduloId,
                    Nome = modulo?.Nome ?? "Módulo",
                    HorasTotais = hTot,
                    HorasConsumidas = hCons,
                    MediaCompParcial = mediaComp,
                    MediaConhParcial = mediaConh,
                    MediaAptParcial = mediaApt,
                    MediaGlobal = (mediaComp + mediaConh + mediaApt) / 3,
                    ProntoParaMediaFinal = aprovado,
                    StatusCritico = statusCor,
                    StatusTexto = aprovado ? "APROVADO" : (temRecuperacaoPendente ? "RECUPERAÇÃO EM CURSO" : "PENDENTE")
                };
            }).ToList();
    }

    // Métodos de navegação e modal (SalvarRecuperacao, AbrirModalRecuperacao, etc.) permanecem iguais aos anteriores
    private void Voltar() => Nav.NavigateTo("/professor/dashboard");
    private void IrParaAvaliar() => Nav.NavigateTo($"/professor/AvaliarAlunos/{AlunoId}");
    private void AbrirModalRecuperacao(int id, string nome) { moduloSelecionadoId = id; moduloSelecionadoNome = nome; exibirModal = true; }
    private void FecharModal() => exibirModal = false;

    private async Task SalvarRecuperacao()
    {
        if (aluno != null && !string.IsNullOrWhiteSpace(descricaoRecuperacao))
        {
            var refTrabalho = ListaOriginalTrabalhos.FirstOrDefault(t => t.ModuloId == moduloSelecionadoId);
            var resumo = ModulosProcessados.FirstOrDefault(m => m.ModuloId == moduloSelecionadoId);

            if (refTrabalho != null && resumo != null)
            {
                var novoTrabalho = new Trabalho
                {
                    Titulo = "Recuperação",
                    ConteudoTexto = descricaoRecuperacao,
                    AlunoId = aluno.UserId,
                    ModuloId = moduloSelecionadoId,
                    DisciplinaId = refTrabalho.DisciplinaId,
                    ProfessorId = refTrabalho.ProfessorId,
                    Status = "Pendente",
                    DataCriacao = DateTime.Now
                };

                var tid = await TrabalhoService.AddTrabalhoAsync(novoTrabalho);

                string vertenteAlvo = "Conhecimento";
                if (resumo.MediaCompParcial < 9.5) vertenteAlvo = "Competência";
                else if (resumo.MediaAptParcial < 9.5) vertenteAlvo = "Aptidão";

                await TrabalhoService.AddVertenteAsync(new TrabalhoVertente
                {
                    TrabalhoId = tid,
                    Tipo = vertenteAlvo,
                    ConteudoTexto = "Recuperação"
                });
            }
        }
        exibirModal = false;
        await CarregarDados();
    }

    public class ModuloResumoUI
    {
        public int ModuloId { get; set; }
        public string Nome { get; set; }
        public int HorasTotais { get; set; }
        public int HorasConsumidas { get; set; }
        public double MediaCompParcial { get; set; }
        public double MediaConhParcial { get; set; }
        public double MediaAptParcial { get; set; }
        public double MediaGlobal { get; set; }
        public bool ProntoParaMediaFinal { get; set; }
        public string StatusCritico { get; set; }
        public string StatusTexto { get; set; }
    }
}